        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_380,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_381,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_382,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "ba84508756a0f6a18fef09c7d34ec721"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 6, sentence number 2 on page 9"^^xsd:string ;
    neo:text "Insights into the nature of things include insights into the nature of our own practice, insights into the nature of awareness, insights into the nature of the things we observe and experience, insights into the nature of things as they are and more."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_38 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "66d408b2a3d3f5520321e09e3338ad16"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Acknowledgements, paragraph number 2, sentence number 1 on page vii"^^xsd:string ;
    neo:text "I want to express my appreciation to all yogis."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_383 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_261,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_384,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_385 ;
    neo:id "0b1b41069117a26816bf37349d486d2a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 6, sentence number 3 on page 9"^^xsd:string ;
    neo:text "Although we may not always realize it, just persevering and noticing is the main skill we need."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_386 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387 ;
    neo:id "237889336db537988803fd5821680632"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 6, sentence number 4 on page 9"^^xsd:string ;
    neo:text "Whenever awareness is established and strong, and we have an insight, we will begin to see nature in ways that we had never conceived of before and see things in ways we had never seen before."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_388 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "eb39ee791d8c0a012c700c0cbe6895e1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 6, sentence number 5 on page 9"^^xsd:string ;
    neo:text "This is the growth of wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_389 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_390,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_391,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_392 ;
    neo:id "5a52126faf939fbce9908bc13104819b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 6, sentence number 6 on page 9"^^xsd:string ;
    neo:text "Our work and our practice is always changing with this wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_393 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "8617d6230bdeba117c1e337f8f6bc6c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 7, sentence number 1 on page 9"^^xsd:string ;
    neo:text "Wisdom is one word but it encompasses so much and operates in many ways."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_394 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_395,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_396 ;
    neo:id "d1393dc72580af4283147b5165d154d3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 7, sentence number 2 on page 9"^^xsd:string ;
    neo:text "Sometimes we miss the fact that it is there and doing its work because we are not familiar with the nature of wisdom and its various job descriptions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_397 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_398,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_399,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "4c79f7263f8c1f95bb81071fc91212b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 7, sentence number 3 on page 9"^^xsd:string ;
    neo:text "We are more familiar with making an effort, like yogis making a physical effort not to be sleepy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_4 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_5,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_6,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_7,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_8 ;
    neo:id "e74dffb2ed813db2b68329c47c665687"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 3, sentence number 1 on page iii"^^xsd:string ;
    neo:text "Edited by Laura Zan Namo Tassa Bhagavato Arahato Sammā-Sambuddhassa"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_400 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_373,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401 ;
    neo:id "e2bb9565a8fd75047e33b5e9e086c694"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 7, sentence number 4 on page 9"^^xsd:string ;
    neo:text "Instead, when we are sleepy we could actually check out the sleepiness, if we are curious, and wisdom would at once be at work: Why is there sleepiness now?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_402 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "0e1cd58a2a6b720a0eb41d4d4191cea0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 2 on page 113"^^xsd:string ;
    neo:text "What has brought it on?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_404 a neo:Document ;
    neo:id "1d6c4e3564a8621b03a6d15280692899"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 3 on page 113"^^xsd:string ;
    neo:text "What does it feel like?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_405 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "2260647b182ce87454d285765ea9d861"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 7, sentence number 7 on page 9"^^xsd:string ;
    neo:text "What we mostly do instead is resist this state because of our belief that sleepiness is not good when we are meditating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_406 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "32a2feddeff2d9f826c487447f6a6920"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 2 on page 10"^^xsd:string ;
    neo:text "We react negatively as a result and try to do something immediately to fix the experience rather than seeing it as it is and checking it out."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_407 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_408 ;
    neo:id "eb62247a7163db5357e57eca9c17fc4f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 3 on page 10"^^xsd:string ;
    neo:text "I recall my teacher’s first lesson to me: when I notice anything about myself, it means there is awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_409 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_410 ;
    neo:id "ce7d69047b3dbf61192019e952502869"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 4 on page 10"^^xsd:string ;
    neo:text "That is a good thing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_41 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_42,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_43,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_44,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_45,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_46 ;
    neo:id "e25b9bba11bb5667b55869ef5ebc233e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Acknowledgements, paragraph number 2, sentence number 2 on page vii"^^xsd:string ;
    neo:text "Their questions and difficulties have once again inspired many of the explanations in this book."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_411 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_412 ;
    neo:id "26c6655be92e2050f06a0a536220888f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 1 on page 10"^^xsd:string ;
    neo:text "I also had a first taste of the importance of the mind after an incident with a bed bug."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_413 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_414,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_415,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_416,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_417 ;
    neo:id "bf8d907e7fca8b5371fedbf13a13d3e8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 2 on page 10"^^xsd:string ;
    neo:text "I loved the feeling of calm that came with continuous mindfulness and the attendant samādhi (stability of mind) so much that I would forgo sleep to enjoy this bliss."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_418 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_412,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_419 ;
    neo:id "0b372d576ae97bfa9fa0933f32855317"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 3 on page 10"^^xsd:string ;
    neo:text "One night a bed bug bit me while I was meditating in my room in the middle of the night."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_420 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_421 ;
    neo:id "253ea9e15bed6b4ba94af223bb946d2c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 4 on page 10"^^xsd:string ;
    neo:text "Even though this disrupted the blissful feelings, I was unperturbed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_423 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "ef93abf8d3c6bf58b7e184e023ef5739"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 5 on page 10"^^xsd:string ;
    neo:text "I knew I could get it back so I continued meditating but it didn’t come back."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_424 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_425 ;
    neo:id "be1f71f66c1a0078b01ed238097da14b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 6 on page 10"^^xsd:string ;
    neo:text "I tried harder, I walked, I sat, and I still did not sleep."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_428 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_429 ;
    neo:id "2466d6849f46e69c02f66596b0ead12e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 7 on page 10"^^xsd:string ;
    neo:text "I became obsessed with regaining the blissful feeling, to no avail."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_430 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_431,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_433,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_434 ;
    neo:id "0fd0b248a8b501e40a3fe28a7339697d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 8 on page 10"^^xsd:string ;
    neo:text "I continued to the morning, the whole day, the next night, the next day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_435 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_436,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_437 ;
    neo:id "e139afe1d958bccf45cafb508e8ff904"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 9 on page 10"^^xsd:string ;
    neo:text "By day three I had a headache but I didn’t give up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_438 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_439,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_440,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_441,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_442 ;
    neo:id "a9ca90b46a7ec9e0598ee16e2653bbc2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 10 on page 10"^^xsd:string ;
    neo:text "I put medicated plasters that relieve muscle soreness at my temples and continued my efforts, until finally it got too much and too painful, that I gave up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_443 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_444 ;
    neo:id "11caf911a4f49a6139f2fcef24856da1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 11 on page 10"^^xsd:string ;
    neo:text "I surrendered."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_445 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_417 ;
    neo:id "dcf4f7ff08164f0134106b2b88ba743e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 12 on page 10"^^xsd:string ;
    neo:text "Never mind if I couldn’t have that bliss back, I thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_446 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_417 ;
    neo:id "afa29578b775982f2fa2c762f924a4b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 13 on page 10"^^xsd:string ;
    neo:text "I just dropped it and continued to meditate without any more desire to achieve that bliss."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_447 a neo:Document ;
    neo:id "a8f7c0912ddf745d9bfb587f5615b956"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 14 on page 10"^^xsd:string ;
    neo:text "It came back, just like that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_448 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_417 ;
    neo:id "7ac2f42393c60cbf7658c43ad0941e6f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 8, sentence number 15 on page 10"^^xsd:string ;
    neo:text "As I simply paid attention to what I was doing, without a thought of having any more of the bliss, it was back."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_449 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_408,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_450 ;
    neo:id "6c0ca9dbc1b02b97f578d654520d0010"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 9, sentence number 2 on page 11"^^xsd:string ;
    neo:text "And I learned this huge lesson about meditation, which has stayed with me ever since, and I ran all the way to my teacher’s kuti (cottage) to tell him and he hammered home the bitter lesson, saying, “Well if you can get it by doing it, then do it.”"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_451 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "b233b3e23e8033f8757698add2980a95"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 9, sentence number 1 on page 11"^^xsd:string ;
    neo:text "I didn’t know the mind directly then, but I just realized very deeply that greed was neither useful nor helpful when practicing meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_452 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_453 ;
    neo:id "0a1e18c788e0e56e4ecab8843c7d5148"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 9, sentence number 2 on page 11"^^xsd:string ;
    neo:text "It had no place in getting me results."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_454 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "4c8ae7068841c91dde0f85a8932ed354"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 9, sentence number 3 on page 11"^^xsd:string ;
    neo:text "So I never had greed when I meditated anymore."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_456 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "9dc7ac1eb014eb798903fb042d4afb4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 9, sentence number 4 on page 11"^^xsd:string ;
    neo:text "Ironically that did not prevent me from having greed in many other aspects of my life, so much so that it led to depression."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_458 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_340,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_459,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "b35a199356fc3fa2f2f2e7dc1b033914"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 10, sentence number 1 on page 11"^^xsd:string ;
    neo:text "When I was around 18 to 20 years old on one of my retreats with my teacher, I remember Sayadawgyi mentioning that we can ask what the mind is aware of."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_460 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_315,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_461,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_462,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "be249bfa0218fe23429472073b6e2979"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 10, sentence number 2 on page 11"^^xsd:string ;
    neo:text "Until then, in all my retreats over the years, although I was totally dedicated to being mindful on retreat, I simply watched my body movements and sensations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_463 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_315,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_464,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_465 ;
    neo:id "faea7822a77fbe94daddb102fb5da5a7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 10, sentence number 3 on page 11"^^xsd:string ;
    neo:text "When thoughts were noticed, I acknowledged them then returned to the task of being aware of all my bodily movements and sensations, over and over again all day long."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_466 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_139,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_431,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_467 ;
    neo:id "2baf9a29e27b3c52ea9941bfbef565bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 10, sentence number 4 on page 11"^^xsd:string ;
    neo:text "I recalled my teacher’s words the next morning as I was brushing my teeth and when I posed the question, it felt like a weight was suddenly taken off my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_468 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_469,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_470,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_472,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_473 ;
    neo:id "62d4788d9e02cca9731fb58bb06e3370"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 10, sentence number 5 on page 11"^^xsd:string ;
    neo:text "As it was, my practice had built up quite a bit of momentum on the retreat so when the attention turned to what the mind was aware of, and what the mind knew, there was suddenly so much to know!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_47 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_49,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "903122603f00daea583ce8172872557a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Acknowledgements, paragraph number 2, sentence number 3 on page vii"^^xsd:string ;
    neo:text "I really hope that this book will help yogis better understand mindfulness meditation and deepen their practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_474 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_475 ;
    neo:id "feb0a9207894c9dd89ec6f814dc2292a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 2 on page 12"^^xsd:string ;
    neo:text "It took off!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_476 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_477 ;
    neo:id "5028a74f5b175799bf97e1ac79d4a462"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 3 on page 12"^^xsd:string ;
    neo:text "I saw the mind and whatever it knew."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_478 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_469,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_479 ;
    neo:id "cd23753c29deaad40467bcbd19ef8bf9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 4 on page 12"^^xsd:string ;
    neo:text "From then on, my practice changed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_480 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_481,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "3eb46a1ca52f05951d74abfb2739bedb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 5 on page 12"^^xsd:string ;
    neo:text "Whenever I went on retreat, I would, in sitting and in all activities, lead with the question: What is the mind knowing?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_482 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "fb82ddfed37c87a39ca8085c9019d251"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 6 on page 12"^^xsd:string ;
    neo:text "What is the mind aware of?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_483 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "2284ad4fa8139222b5daeb79042174c7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 7 on page 12"^^xsd:string ;
    neo:text "This opened up the practice immensely at the center."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_484 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_485,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "50eb88e9012831ba2adde9adccf6e536"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 1 on page 12"^^xsd:string ;
    neo:text "At home, the practice was forgotten and I got busy having fun with my friends."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_486 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_485,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_487,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_488,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_489 ;
    neo:id "5ad0a8ce11c7701f6ced05ff6776ec75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 2 on page 12"^^xsd:string ;
    neo:text "At University to study engineering, I became so involved in having so much fun with my friends that I flunked my second year of Regional College."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_490 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_491,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_492,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_493,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_494,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_495,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_496,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_497,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_498 ;
    neo:id "1f29300f717aa2f13df18205b594d93e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 3 on page 12"^^xsd:string ;
    neo:text "At about this time, my oldest brother passed away from leukemia at the age of 43, and my father needed help running his menswear shop in a bustling wholesale center in downtown Yangon, a walking distance from our home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_499 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_487,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_500,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_501,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_502 ;
    neo:id "284947fc92dd236d037606051f996a4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 4 on page 12"^^xsd:string ;
    neo:text "My father decided to take me out of University, no doubt a fact that I was a non-doctor in a family filled with brothers and a sister studying medicine."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_503 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_487,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_494,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_504,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_505 ;
    neo:id "fb59c7ad619c4e3cd01668561306dc58"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 11, sentence number 5 on page 12"^^xsd:string ;
    neo:text "The only other brother not studying medicine had already finished University and was helping my father with the shop."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_506 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_485,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_487,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507 ;
    neo:id "1c6f84b06a733cde25bca73476cff7a5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 12, sentence number 1 on page 12"^^xsd:string ;
    neo:text "I wanted so much to continue to be with my friends that I actually, while helping out at the shop, still tried to repeat my second year at University on my own."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_508 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_488,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_489,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_509 ;
    neo:id "fe1b5858c47b8c3bb8a9386d6d66083a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 2 on page 13"^^xsd:string ;
    neo:text "It was not as much fun anymore by then because all my friends had already moved on to the main Rangoon University for their third year in Engineering studies while I was still at the Regional College."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_51 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_46,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_52 ;
    neo:id "9d0012ffd2e996ff9cd3777ab5e64012"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Acknowledgements, paragraph number 3, sentence number 1 on page vii"^^xsd:string ;
    neo:text "Finally, I would like to thank everyone who has contributed to the completion of this book."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_510 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_511 ;
    neo:id "8b203ac5c31d47b003abbc6fd2310e2d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 3 on page 13"^^xsd:string ;
    neo:text "It was discouraging, so I stopped trying to repeat the year."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_512 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_513,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_515 ;
    neo:id "c3b7ca0ea196b8ceb41e0917c94add89"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 4 on page 13"^^xsd:string ;
    neo:text "I slowly descended into depression from resentment, fear, dissatisfaction, having to do what I did not want to, and not being able to do what I wanted to do."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_516 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_517,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_518 ;
    neo:id "dd0c59bfa8697fddb5287cc71af8eff9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 5 on page 13"^^xsd:string ;
    neo:text "It was the love, or actually greed for fun that indirectly led to my years of depression."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_519 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_520 ;
    neo:id "fbb178a0b91c4a27580e29d93c7ad317"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 1 on page 13"^^xsd:string ;
    neo:text "Initially I forgot about my unhappiness after a while, because it wasn’t very strong then and the depression seemed to go away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_521 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_522 ;
    neo:id "96aedf9d70f762a653749c7bd8979af7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 13, sentence number 2 on page 13"^^xsd:string ;
    neo:text "When it returned a second time, I got fed up of feeling mopey and angrily railed against the emotion and willed myself to overcome it that way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_523 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_500,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_72 ;
    neo:id "94f3cca7b4d30235d78afbb45758cc80"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 14, sentence number 1 on page 13"^^xsd:string ;
    neo:text "While I was working with my father, I got more of an opportunity to go for longer retreats at my teacher’s monastery too, than when I had been in school."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_524 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_494,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_525 ;
    neo:id "2c4db8d4004e6b4d177d3743ef74166f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 14, sentence number 2 on page 13"^^xsd:string ;
    neo:text "My father had no objections to my going and I mostly did the customary days off during the Burmese New Year."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_526 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_528 ;
    neo:id "93954f00d99058d152cf79933d5abad5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 14, sentence number 3 on page 13"^^xsd:string ;
    neo:text "At one point I thought I wanted to be a monk for life and told my family and my teacher and they were all happy for me."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_529 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_530 ;
    neo:id "0756bc6aedd4602d0f810e2202101e73"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 14, sentence number 4 on page 13"^^xsd:string ;
    neo:text "Ten months in, my mind had changed again, and I just could not stay at the center any longer."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_53 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "5933fb8c69e35456a8588079f5bce9c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 1, sentence number 1 on page ix"^^xsd:string ;
    neo:text "It doesn’t take long for a yogi (meditator) new to Sayadaw U Tejaniya to notice humor permeating his teachings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_531 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344 ;
    neo:id "b2ff29f60345d5952f54e0437dc2abc3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 14, sentence number 5 on page 13"^^xsd:string ;
    neo:text "My teacher gently tried to persuade me to stay but when my mind was made up there was no changing it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_532 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "df62102c04dc0a1a0fedee969a34775f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 2 on page 15"^^xsd:string ;
    neo:text "I went home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_533 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_534,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "2b976cfe463f642151e4b25f40000819"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 3 on page 15"^^xsd:string ;
    neo:text "Ironically it was right on the way home in the taxi from that retreat that I actually descended into the deepest depression of my life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_535 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_537 ;
    neo:id "ff429012b594c36c38b6e904eabcd393"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 4 on page 15"^^xsd:string ;
    neo:text "In hindsight, I think the feelings that came up had something to do with some insights into dukkha not being fully understood or realized."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_538 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_534,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "61bca3cd51276fcdcf72f79d1457d686"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 5 on page 15"^^xsd:string ;
    neo:text "Sitting in the taxi on the way home I began to feel irrational fears."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_539 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_540,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_541 ;
    neo:id "e256f306cd631a33e81f58a0efbfd29c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 6 on page 15"^^xsd:string ;
    neo:text "I was sure the policeman on the street knew about all my misbehaviors."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_542 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "0042783ecde7e405d4fff2d4b9a4b053"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 7 on page 15"^^xsd:string ;
    neo:text "I went home fearful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_544 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_72,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "980bbaf6f31a05c1b78ae502982eb739"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 8 on page 15"^^xsd:string ;
    neo:text "This time I could not shake the feelings that overtook me and it was two long years of depression at home before I finally turned in desperation to meditation again, but this time I did not go to the monastery."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_545 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_546 ;
    neo:id "cb874e676068285664c0b242f41423b5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 9 on page 15"^^xsd:string ;
    neo:text "Circumstances did not permit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_547 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_494 ;
    neo:id "e1e2ae0353cfa6f7c4b4b20d7cde0ca3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 10 on page 15"^^xsd:string ;
    neo:text "My father was getting older and I could not take time off like I had done before."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_548 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_485,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_549,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_550 ;
    neo:id "49720a7d2b89faa520edeff3e0055d24"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 11 on page 15"^^xsd:string ;
    neo:text "I did try to take short holidays to places I had gone to with my friends before but nothing helped."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_551 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "c2f27586815b3834f01781ee57d79c23"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 12 on page 15"^^xsd:string ;
    neo:text "I could not be happy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_552 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0c78cc1956b399a870e7ee4257b9fc60"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 13 on page 15"^^xsd:string ;
    neo:text "I only sought out meditation when it became my very last resort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_553 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_459 ;
    neo:id "0e3fda7f06b621ad32ad54482dc0a4d1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 1 on page 15"^^xsd:string ;
    neo:text "When I finally, in my exhausted and suffering mind, decided maybe I should try meditating at home, something I’d never done before then, I went to speak to my teacher."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_554 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_340 ;
    neo:id "b1f4553b8a39ecd4dc8609765b1087aa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 2 on page 15"^^xsd:string ;
    neo:text "Sayadawgyi just told me to try."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_555 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_459,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_556,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_557,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_558 ;
    neo:id "1174a616c344c4a32d78a28af58b7228"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 3 on page 15"^^xsd:string ;
    neo:text "I accompanied my teacher for a four– to five–day retreat to a monastery about 10 miles out of Bago that he was visiting to give myself a boost."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_559 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_72 ;
    neo:id "d65b7b79db1975653d921ff3c8ad9ab8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 15, sentence number 4 on page 15"^^xsd:string ;
    neo:text "It was probably my time because I had three insights while meditating at that monastery that gave me some impetus to persevere when I went home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_560 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_72 ;
    neo:id "8add3d35dd969433eed195033e4ad2a3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 2 on page 16"^^xsd:string ;
    neo:text "When I got to the monastery, I spent my time practicing as I already knew well how to."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_561 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_562,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_563 ;
    neo:id "a7e60f951918e593d820dc750145defb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 3 on page 16"^^xsd:string ;
    neo:text "The second day, I sat under a tree because there was not much to do out there, except to watch."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_564 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_565,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_566,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_567 ;
    neo:id "8d68ad57cf87c511a29d1cfa5b355f46"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 4 on page 16"^^xsd:string ;
    neo:text "It was all trees, with just stillness and as I sat there I guess the silence turned the mind inwards."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_568 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_513,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_569,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_570,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_571 ;
    neo:id "f594f6e2eea48ad4a6b890a614096b61"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 5 on page 16"^^xsd:string ;
    neo:text "Suddenly, I saw all the rage, resentment, fear, desires, and frustrations that were racing through my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_57 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_59 ;
    neo:id "cf9583bb19749f4cd752cabbecda9cb2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 1, sentence number 2 on page ix"^^xsd:string ;
    neo:text "Whether it is making an observation on his surroundings or commenting on the environment of the mind, Sayadaw, or “the Teacher” as his disciples fondly call him, delivers his teachings with a good dose of wit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_572 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "b78f763a64c4cd89023f18bc30d3e845"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 6 on page 16"^^xsd:string ;
    neo:text "I was shocked."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_573 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_574 ;
    neo:id "0fcdb429ef1272b7a2cfdc1b638cf284"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 7 on page 16"^^xsd:string ;
    neo:text "I saw it was all negative thinking in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_575 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_576,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "ad699b441063000deddd66f634590991"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 8 on page 16"^^xsd:string ;
    neo:text "I realized if I died with the mind in this state, it was not going to a good state/place."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_578 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_576,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_579,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_580 ;
    neo:id "cde21cfafe934941fcba45c1beafcf2b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 9 on page 16"^^xsd:string ;
    neo:text "That was the first thing that made me afraid to die, not in general, but right then in that state."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_581 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_583,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_584,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_586,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_587 ;
    neo:id "231e54055ac2e1d2839e7c801c2e191a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 1 on page 16"^^xsd:string ;
    neo:text "The next day as I was taking a shower at a well, pulling up one pail of water after another and pouring it over myself in the heat, a man came running down a hillside."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_588 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_589,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "156b87f469795389f1b9ca9d8b188185"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 2 on page 16"^^xsd:string ;
    neo:text "He was large and very dark, his skin almost black, that he must have been in the heat a long time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_590 a neo:__Entity__ ;
    neo:AFFECTED_BY ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "Heat"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_591 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_583,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_584,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "6c38f88368dabde8b444825e9467d293"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 3 on page 16"^^xsd:string ;
    neo:text "He was sweating profusely and panting hard and he said to me as he ran towards me, “Water, water” and silently I handed him the pail full of water that I pulled up from the well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_592 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_584,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "eef41cdf6142d60c1896a92e05a29f0c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 4 on page 16"^^xsd:string ;
    neo:text "He turned the pail up to drink directly from it and drank till all the water was gone!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_593 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "0b3d23e1c8f2e490328503e3c464955a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 5 on page 16"^^xsd:string ;
    neo:text "Then he ran off."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_594 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_11,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "32fab569bdfab197ba84bba81e9217fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 6 on page 16"^^xsd:string ;
    neo:text "I just stared at him."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_595 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_596,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "d7a5bc7f1f77d9f8d373206564987d30"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 7 on page 16"^^xsd:string ;
    neo:text "Then it dawned on me after he left that I was all alone in that area."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_597 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_598,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_599 ;
    neo:id "0f9b9cbbff86a11d6d9ab83eeda565f5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 8 on page 16"^^xsd:string ;
    neo:text "The monastery had a lot of land."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_60 a neo:__Entity__ ;
    neo:FONDLY_CALL ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "Disciples"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_600 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_136,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_583 ;
    neo:id "4986cc6fbc6c1472eed0939cc5718089"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 9 on page 16"^^xsd:string ;
    neo:text "My watch, which I had taken off, was on the edge of the well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_601 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_596,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_602 ;
    neo:id "0ea3b448bac6a75a5289a53abffbe703"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 16, sentence number 10 on page 16"^^xsd:string ;
    neo:text "I knew the area had prisons somewhere."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_603 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_604 ;
    neo:id "a7278bb41a6e92dd59a9d81703dd35b7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 2 on page 17"^^xsd:string ;
    neo:text "And the appearance of the man was not ordinary."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_605 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_606 ;
    neo:id "1d4775b166412e9344a992fc105828f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 3 on page 17"^^xsd:string ;
    neo:text "I got the chills."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_607 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "92cfb6e43235af1b5b76387f42858641"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 4 on page 17"^^xsd:string ;
    neo:text "I could have been robbed and killed if he had had any ill intentions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_608 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_609 ;
    neo:id "33597ec32ee3ad56e1c5584ef6e6f02a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 5 on page 17"^^xsd:string ;
    neo:text "Again, the thought came to me that I was not ready to die in my current state of mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_61 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "9b8d7addab9a0a042fb3a20d5a0ab027"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 2, sentence number 1 on page ix"^^xsd:string ;
    neo:text "While the delivery may come with a bit of levity, Sayadaw is quite serious about the subject of Dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_610 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_611 ;
    neo:id "243211bc708b3051c4e7dbab1864ae04"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 1 on page 17"^^xsd:string ;
    neo:text "Then the next night, in my last night with my teacher before I was going to battle it out on my own at home, he asked me to get him medicine from the dining cottage."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_612 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_599,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_613,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_614,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_615,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_616 ;
    neo:id "8c23a9e8708d05e0d02ad75ec03e384d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 2 on page 17"^^xsd:string ;
    neo:text "The monks’ kutis were far from each other and it was pitch dark but I knew the land well and there was moonlight so I walked without lighting the flashlight I had with me."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_617 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_450,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_616 ;
    neo:id "1d50380e5f7bf776fae40c36bd8411d1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 3 on page 17"^^xsd:string ;
    neo:text "As I walked back to my teacher’s kuti at one point I just felt like using the flashlight so I flashed it and stopped dead."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_618 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_619 ;
    neo:id "9045daee05fd92382a99b7cce906a328"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 4 on page 17"^^xsd:string ;
    neo:text "Right in front of me was a viper."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_62 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "1e871fa2110bd2233ffe1861d01f19bf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 2, sentence number 2 on page ix"^^xsd:string ;
    neo:text "Using his own experiences as guide and gradually honing his presentation, Sayadaw encourages meditators to always be persistent, experiment, and dig deeper into the Dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_620 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_621,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_622 ;
    neo:id "1982a9ae3002a22fdc09a04565716700"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 5 on page 17"^^xsd:string ;
    neo:text "One more step and my foot would have been struck."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_623 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_624,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_625 ;
    neo:id "862367e2ca7391b47233a070a411eaef"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 6 on page 17"^^xsd:string ;
    neo:text "My blood ran cold, the hair on my head (although shaved bald) stood and all I could do was stand."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_626 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514 ;
    neo:id "f1f783bfbe16c00aa0df04213d5e87bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 7 on page 17"^^xsd:string ;
    neo:text "I was so transfixed with fear that I could not move."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_627 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_450,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_628,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_629 ;
    neo:id "9f57be7ad00b3f917c115419a3322acb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 8 on page 17"^^xsd:string ;
    neo:text "The snake moved away by itself but I remained there, standing still until my teacher sent his attendant monk to come find me and I followed him back to my teacher’s kuti."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_630 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_631 ;
    neo:id "6948d5168affc954669e2fe688f22f37"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 9 on page 17"^^xsd:string ;
    neo:text "I really felt the fear of death then."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_632 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_633 ;
    neo:id "31bba5cf7f6dace63b3d8b847eeeb420"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 17, sentence number 10 on page 17"^^xsd:string ;
    neo:text "I was really afraid that I might die."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_634 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "250300f6655fcb822ed6d459c7e19207"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 18, sentence number 1 on page 17"^^xsd:string ;
    neo:text "Of course mindfulness was not continuous when I got home from that “kick-starter” retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_635 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_316,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_636,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_637 ;
    neo:id "e162c7dc38489103daeba4d232dd38a2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 18, sentence number 2 on page 17"^^xsd:string ;
    neo:text "I knew how to watch the mind, I knew about the watching mind or awareness of awareness and I could use the six sense objects just fine, and although I often speak to yogis about using questions, I myself initially had none."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_638 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "bd63b335868fe0402b59b70039ceba77"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 2 on page 18"^^xsd:string ;
    neo:text "I was only meditating to calm the mind a little, as much as possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_639 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_640 ;
    neo:id "95fed0ae61a2d294ae19b73d9a287cbb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 3 on page 18"^^xsd:string ;
    neo:text "Fear and anxiety overwhelmed me, and when the feelings were really strong, I would sometimes use the feeling as the object and watch them continuously until the feeling subsided."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_64 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_66,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_67,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_68,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_69 ;
    neo:id "6f62387c110f552cc0565873540b467e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 2, sentence number 3 on page ix"^^xsd:string ;
    neo:text "He relates to his lay students through pithy business metaphors and regularly describes his own experiences in learning to meditate in the midst of managing the family business and before ordaining permanently in 1996."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_641 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_643,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_644,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_645 ;
    neo:id "1786d143c05156c85b09291a1ba1d277"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 4 on page 18"^^xsd:string ;
    neo:text "Other times, they wouldn’t hold my attention long enough and I used my breath to anchor my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_646 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "90aad6cffb26de725ed9fa0ad9347fcc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 5 on page 18"^^xsd:string ;
    neo:text "These objects of the feelings and the breath were familiar to me and I knew how to use these objects to anchor the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_648 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "f20d7a54752bc630be57a04aa5914c8d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 6 on page 18"^^xsd:string ;
    neo:text "I did not begin using other objects until months afterwards."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_649 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_640,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_650,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_651,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_652,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_653 ;
    neo:id "cc72283685f7bd7b6c41e530b8464dac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 7 on page 18"^^xsd:string ;
    neo:text "Without attention on an object, the fear and anxiety could quickly become scary, and, if they became overwhelming, I used the inhaler because the sharp menthol smell and the sensation in my sinuses and forehead would bring my attention to these sensations and off the thoughts that fueled the emotions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_654 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "d706fb88dc9a25ec8aee0e4cfcd59a94"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 1 on page 18"^^xsd:string ;
    neo:text "The suffering feeling reminded me to be mindful and that mindfulness made me feel a bit better each time I was mindful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_656 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "83222e359cf10eb5daf4789f191c1a8e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 2 on page 18"^^xsd:string ;
    neo:text "I visited my teacher every week or two and told him about my practice and complained about how hard it was to keep practicing at home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_657 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "1a7b743c2aeec32b28a49a60edeadbb6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 3 on page 18"^^xsd:string ;
    neo:text "He would tell me it takes time to find our footing and encouraged me to keep trying."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_658 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_659,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_660 ;
    neo:id "9018c861d91596afed1d5c573de0726c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 4 on page 18"^^xsd:string ;
    neo:text "My problem was not one of ability to practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_661 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662 ;
    neo:id "11f9515db8943649599a955674412250"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 5 on page 18"^^xsd:string ;
    neo:text "It was more because the peace I got from meditation was not lasting."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_663 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_664,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_665 ;
    neo:id "45575f9f2f2c3cb245fbc18ef76b2015"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 19, sentence number 6 on page 18"^^xsd:string ;
    neo:text "I already benefited from keeping up the mindfulness—it did give me relief from the suffering—but it did not give a lasting peace, which I craved."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_666 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "c6e1b6caddc562184eb40e8eb7288c99"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 2 on page 19"^^xsd:string ;
    neo:text "I didn’t want to suffer and the temporary peace I got did not satisfy the mind’s craving."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_669 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_670 ;
    neo:id "dc90a55a472caa2a1a0e704abe2c5c63"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 3 on page 19"^^xsd:string ;
    neo:text "It was demotivating yet I had to keep at it; otherwise, the mental suffering came back."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_671 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_672,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_673,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_674 ;
    neo:id "035a9fb4417cc2a66c255cbbcb066e98"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 4 on page 19"^^xsd:string ;
    neo:text "This in hindsight was a blessing in disguise!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_675 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_500,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507 ;
    neo:id "c74608f26679d4ab77daadbad73e02e2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 1 on page 19"^^xsd:string ;
    neo:text "I worked at my father’s shop, trying to cope with the demands of the business in my state of anxiety, uncertainty, and fear."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_676 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_677 ;
    neo:id "83c263b4911ded5119761359a1b7457a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 2 on page 19"^^xsd:string ;
    neo:text "I often felt unable to make the decisions that had to be made."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_678 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_679 ;
    neo:id "2eb7b2ca9ef31b52b98f5340471958ad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 3 on page 19"^^xsd:string ;
    neo:text "Very often, the decisions just had to be made, without regard as to whether they were right or wrong, because my state of mind did not allow me this perspective."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_680 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_681 ;
    neo:id "05960f0a345f4d9c11da5a7bd9ce72a7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 4 on page 19"^^xsd:string ;
    neo:text "Sometimes I would make the wrong decisions and had to deal with the fall out of that too."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_682 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "c61df98cd67928c8fd53f32cb4eef542"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 5 on page 19"^^xsd:string ;
    neo:text "Through it all, I would turn my attention to the suffering, or the breath as much as I could."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_683 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_684 ;
    neo:id "0f6f590dd522d5c50ef1daf8dcd56f3e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 6 on page 19"^^xsd:string ;
    neo:text "If the feelings were particularly harsh, I could neither face those feelings nor watch the breath successfully, then I turned to the mentholated inhaler."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_685 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_686,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_687,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_688 ;
    neo:id "14a2657cb3edccee46cec5b6084675c9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 7 on page 19"^^xsd:string ;
    neo:text "The Vicks inhaler is a small tube with some mentholated ointment or oil inside that one can inhale through the tube."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_689 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_337,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_690,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_691,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_692 ;
    neo:id "a1d9699e5bdfd49e226a320dd50f7532"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 20, sentence number 8 on page 19"^^xsd:string ;
    neo:text "The sensation in the nose when I inhaled it would help to bring the mind’s attention back, and if I was really desperate I would inhale sharply to get a really strong sharp sensation that would get the mind’s attention, helping to gain control over getting mentally overwhelmed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_693 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_694,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_695 ;
    neo:id "4f483bfaf1940acceceb8ab560895cb3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 21, sentence number 1 on page 21"^^xsd:string ;
    neo:text "During these initial two months I also began reading the books of Mogok Sayadaw."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_696 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_694,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_697,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_698 ;
    neo:id "af9d091d7369f4847a208be5ad5a5b41"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 21, sentence number 2 on page 21"^^xsd:string ;
    neo:text "I happened to see my friend with one of a series of 36 books on Mogok Sayadaw’s teachings and eventually borrowed about six books over some months."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_699 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_694,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_700 ;
    neo:id "827fe61267fb959f7d1c5f6fbf455c75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 21, sentence number 3 on page 21"^^xsd:string ;
    neo:text "Reading a few pages of these books every night, I eventually realized that Mogok Sayadaw was pointing to check to see how the mind is reacting to whatever it is knowing, over and over, constantly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_70 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_72,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "09e8112324263c2a02e7f52d75d093db"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 3, sentence number 1 on page ix"^^xsd:string ;
    neo:text "Sayadaw is a strong proponent of applying the Buddha’s teachings to daily activities in a monastery, at home, and at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_701 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "76e6cdad8f181d541f4b2f357d2df38c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 1 on page 21"^^xsd:string ;
    neo:text "About two months after I began trying to practice at home and at work, the mind did begin to gain some balance."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_703 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_704,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_705,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_706 ;
    neo:id "0e74cbbdda6afa3c3f00ab9c9029ad89"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 2 on page 21"^^xsd:string ;
    neo:text "Where I could not previously think without the cloud and background of anxious fears and doubts, I now began to be able to consider things more rationally and logically."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_707 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_708 ;
    neo:id "84ad39a3293ec3dfad3aad102bbc0f6c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 3 on page 21"^^xsd:string ;
    neo:text "And one day I had a moment of clarity."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_709 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_702,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "d3925042e95ba304b0251f6262f70a79"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 4 on page 21"^^xsd:string ;
    neo:text "In a moment of balance in mindfulness I saw clearly that when there is mindfulness the mind is totally free of its suffering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_711 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "f2fd69e0300a8d76192b9f61d49b85ed"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 5 on page 21"^^xsd:string ;
    neo:text "Then the suffering returned, but the insight had been strong."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_712 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_713 ;
    neo:id "f02e29b865b3ffa29c994262a149122d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 6 on page 21"^^xsd:string ;
    neo:text "Although it was just a glimpse, the mind saw this truth unquestionably."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_714 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "cbd5afaa15ac3c6ec2e2b9364e210f3f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 7 on page 21"^^xsd:string ;
    neo:text "There is a place of utter peace."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_715 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_716,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_717 ;
    neo:id "ce2778fce024e346e86c3817e2ccb805"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 8 on page 21"^^xsd:string ;
    neo:text "And the conviction that it gave the mind provided me with the motivation to continue practicing with increased vigor."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_718 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_720,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "ef0d06a7aac499adab8f5c5082cf4d8b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 9 on page 21"^^xsd:string ;
    neo:text "I knew now that this was the way out, for sure, so there was a real desire to practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_722 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "f26ce77b3d123c856495342a6b18fa39"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 22, sentence number 10 on page 21"^^xsd:string ;
    neo:text "I began to think about practice daily, about how to practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_723 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "89528ffdea8e1fe6df150b92457141b0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 23, sentence number 1 on page 22"^^xsd:string ;
    neo:text "After about six months practicing at home, the depression had gradually disappeared and I began to notice that I would notice my reactions whenever I looked at people or when I heard something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_725 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "977d8e6fc57c24d145dd633e4f773e5a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 23, sentence number 2 on page 22"^^xsd:string ;
    neo:text "The thoughts and feelings had calmed down enough and the practice had gained enough momentum that I finally had the mental space and interest to use objects outside of the breath or feelings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_728 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_660,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_729,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_730,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_731,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_732,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_733 ;
    neo:id "c5533ddb86a0b02d9e6690d26e6a0f73"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 23, sentence number 3 on page 22"^^xsd:string ;
    neo:text "The practice became interesting in and of itself, and I began initially just one at a time to explore the mind’s ability to stay anchored, for example on one pair of fingertips touching while sitting in the shop, on myself when drinking coffee or tea during a break, or being aware of seeing while waiting for customers, and so on."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_734 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_735,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_736,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_737,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_738,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_739,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_740 ;
    neo:id "8cf5d6c622c23f12e981b00f2884ec2e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 24, sentence number 1 on page 22"^^xsd:string ;
    neo:text "And these accumulated practices of collecting the mind enabled me to then be more aware of the interactions within my own mind when I was making decisions, counting money or attending to customers."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_741 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_742,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_743 ;
    neo:id "b07206bf65f59cf0670c2eae475819bb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 24, sentence number 2 on page 22"^^xsd:string ;
    neo:text "I could notice when I lost my composure and devise a plan for maintaining it in my next interaction, always using the practice of collecting the mind as the basis for strengthening the mind’s composure."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_744 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_464,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_733,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_745,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_746,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_747,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_748 ;
    neo:id "5c26f304eea0b3c828cf05ef4959bff1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 24, sentence number 3 on page 22"^^xsd:string ;
    neo:text "As these interactions happened daily and routinely, this is how I learned what helped me to maintain the composure of my mind, what helped me to remain aware and maintain continuity—when I needed to pick up attention on one object, mainly when I was no longer interacting with someone else or doing a task and when I needed to be aware in a more fluid way as in when customers approached and I had to attend to them and interact with them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_749 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "22a60f9f93a0699285bc3b703d7877cd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 25, sentence number 2 on page 23"^^xsd:string ;
    neo:text "The awareness became closer to continuous and insights naturally arose more and more over time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_75 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_76,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_77,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_78 ;
    neo:id "0d4a17a61951fe564ffe54706a6265fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 3, sentence number 2 on page ix"^^xsd:string ;
    neo:text "When his long- time disciples make the migration to the Shwe Oo Min Dhamma Sukha Tawya Meditation Center in Yangon, Myanmar, one of his first questions is typically about their practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_752 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_753,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_754,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_755 ;
    neo:id "ec9e7172e3adb047866d258d1bbb401d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 25, sentence number 1 on page 23"^^xsd:string ;
    neo:text "A year in, I read an article about the ājīvaṭṭhamaka sīla, eight precepts with right livelihood as the eighth precept."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_756 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_757,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_758,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_759,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_760,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_761 ;
    neo:id "b981ffc88434d6dee170196003bceadf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 25, sentence number 2 on page 23"^^xsd:string ;
    neo:text "I was particularly interested in the expansion of the precept on not telling untruths, into four precepts for right speech: refraining from telling lies, slander, harsh speech, and idle chatter."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_762 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "f6b4a1d9cfcac4bea571ab5d1760b2b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 25, sentence number 3 on page 23"^^xsd:string ;
    neo:text "I was inspired to try this."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_763 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_764,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_765 ;
    neo:id "1e34ddf26b9d39d4cece86b5045c9f63"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 25, sentence number 4 on page 23"^^xsd:string ;
    neo:text "The depression had already made me quite subdued at the marketplace I worked at, compared to the joker I had been previously, and then practicing continuously made me quieter."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_766 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_761,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_767 ;
    neo:id "b845848b96600cddf55aa587e6256432"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 26, sentence number 1 on page 23"^^xsd:string ;
    neo:text "However, taking on the four right speech precepts left me with hardly anything to say because I now avoided idle chatter."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_768 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_770 ;
    neo:id "b591286c5e5f2243c5a3fde6497787fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 26, sentence number 2 on page 23"^^xsd:string ;
    neo:text "If someone came over to gossip about some other stallholder, they no longer found in me someone that sympathized."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_771 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "2e60cd6d4f57a793ecc259563dfa8422"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 26, sentence number 3 on page 23"^^xsd:string ;
    neo:text "I merely listened and did not contribute as I saw neither wisdom nor meaning in adding fuel to their fire."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_772 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_477,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_742,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_773 ;
    neo:id "8e8b3ff783bc41047fea51e1294bf506"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 26, sentence number 4 on page 23"^^xsd:string ;
    neo:text "The mindfulness became so much keener, aware of everything I said or planned to say and naturally the strength and composure of the mind also improved."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_774 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_775,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_776,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_777,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_778 ;
    neo:id "0535efa25c2ed0e29597df7364f706d5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 27, sentence number 1 on page 24"^^xsd:string ;
    neo:text "After two years of practicing dedicatedly I began to notice that I had been avoiding unnecessary interactions and I began to challenge myself to go to social functions as a representative of my family and maintain mindfulness, or to go out for dinner with old friends and maintain my mindfulness, composure, or my stand without frustration or rudeness when they tried to get me to join them in drinking alcohol."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_779 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_780 ;
    neo:id "7e9ce2adaae4669f972775885c0a0352"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 27, sentence number 2 on page 24"^^xsd:string ;
    neo:text "I even went for a boxing match and learned a lasting lesson that this was not the place for me any longer."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_782 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_783,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "11851912fad747dc33f9ccfc6ec991e9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 1 on page 24"^^xsd:string ;
    neo:text "I tell you this story to say this is possible for you as well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_785 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_287,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_786 ;
    neo:id "3eb4f6d9c86c05c7c4253a01a5474c85"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 2 on page 24"^^xsd:string ;
    neo:text "You just have to persevere, experiment, and use your wisdom to figure out what works until this also becomes a natural part of your life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_787 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "7b798bbbe0398ce99461c94689a2a5e5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 3 on page 24"^^xsd:string ;
    neo:text "I want to persuade you that this is possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_788 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "8bef4b9551c7883adb10bdf03cc85add"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 4 on page 24"^^xsd:string ;
    neo:text "I really want you to know that you can do it at home when you have become skillful in this practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_789 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_717,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_790 ;
    neo:id "209b7b1ded782bcd1bd3a5e6d600dbbf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 5 on page 24"^^xsd:string ;
    neo:text "This is my motivation to continue teaching."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_79 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_80,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_81 ;
    neo:id "8322acbfffd92df3ba265f7eb6ec367d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 4, sentence number 2 on page x"^^xsd:string ;
    neo:text "Some may reply in detail while others sheepishly answer that they have returned to jumpstart their flagging practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_791 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_792,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_793,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_794 ;
    neo:id "a0950a8046c739b97f32ace2e3920013"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 28, sentence number 6 on page 24"^^xsd:string ;
    neo:text "The only reason we aren’t able to bring it into our lives is because we don’t know enough yet or aren’t practicing enough yet."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_795 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_796,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797 ;
    neo:id "1873378ed8c0752d62a3f0e5dd5764ca"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 29, sentence number 1 on page 24"^^xsd:string ;
    neo:text "You may go on formal retreats to develop wholesome minds."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_798 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_799,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "466d95d45d3fc357b7085e71732637dd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 29, sentence number 2 on page 24"^^xsd:string ;
    neo:text "But it is very important that you continue meditating outside of retreats because unwholesome minds arise in the absence of wholesome minds."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_800 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "dff8e8b65371488f30c8ff87b10e4430"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 29, sentence number 3 on page 24"^^xsd:string ;
    neo:text "Right now, as soon as yogis leave a retreat, they have no idea where all the wholesome minds have disappeared!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_801 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_803,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "4c467fe5adee812f74cbada844c4fde7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 29, sentence number 4 on page 24"^^xsd:string ;
    neo:text "It seems as if wholesome minds just arise on retreat, only to be replaced by unwholesome mind states as soon as a person returns home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_804 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_805,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "3e73325c4defbdf423599faa4790ca01"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 2 on page 25"^^xsd:string ;
    neo:text "You have to cultivate your own energy and your own wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_807 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_808 ;
    neo:id "a43a8ec9ce39510f06a7e242d97a70be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 3 on page 25"^^xsd:string ;
    neo:text "If you are suffering, you will need to sit down and work out what to do about it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_809 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_810,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_811 ;
    neo:id "118b8b700abd62688490fee45779a5cf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 4 on page 25"^^xsd:string ;
    neo:text "If the parents always work things out for the child, the child will never learn for himself."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_812 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180 ;
    neo:id "b40a430595823170f30ab130767c361c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 1 on page 25"^^xsd:string ;
    neo:text "Finally, we all have to live, but we must ask ourselves: Are we truly alive?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_813 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_814,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_815,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_816 ;
    neo:id "eededa52e8fdd508ecab8717c6d80b95"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 2 on page 25"^^xsd:string ;
    neo:text "If we don’t change and grow, it is akin to being dead."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_817 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_818 ;
    neo:id "576f5782977c6cce0d85eccf49f513ab"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 3 on page 25"^^xsd:string ;
    neo:text "I encourage all of you to please continue practicing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_819 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_820,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_821 ;
    neo:id "c4947dc04169ecab2ac5b4461869a89f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 30, sentence number 4 on page 25"^^xsd:string ;
    neo:text "I make an aspiration for all of you to practice at home and to enjoy the fruits of your practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_822 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_824 ;
    neo:id "43a1c3f8c0edebc55fda1089de40058a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 31, sentence number 1 on page 26"^^xsd:string ;
    neo:text "When I know the mind is aware, there is a very strong feeling of goodness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_825 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_826 ;
    neo:id "ef6baa8314203baf20bde753c4b8c822"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 31, sentence number 2 on page 26"^^xsd:string ;
    neo:text "I greatly wish for yogis to understand and appreciate fully the value of awareness + wisdom and their role in helping develop all of the wholesome qualities of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_827 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_828 ;
    neo:id "db3112c8786401cd0173326d2edd5b17"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 31, sentence number 3 on page 26"^^xsd:string ;
    neo:text "This is the basic understanding that will carry the rest of the practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_829 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "eb544a352568b22e1617ead84b0df740"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 1 on page 27"^^xsd:string ;
    neo:text "When a retreat begins, defilements will negotiate with the yogi: “Okay, how long do you want to practice for?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_831 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_832 ;
    neo:id "2482fc6c659368c9461810ae1d278fd3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 2 on page 27"^^xsd:string ;
    neo:text "One month?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_833 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_834 ;
    neo:id "31e5a2a2b7491802aa2dafa345bf7ba4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 3 on page 27"^^xsd:string ;
    neo:text "Two months?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_835 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_836 ;
    neo:id "7ea72e09aeff0b52a9526fd3824a7f1d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 4 on page 27"^^xsd:string ;
    neo:text "Three months?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_837 a neo:Document ;
    neo:id "222f227eb9607fa6ba9475dafb50e648"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 5 on page 27"^^xsd:string ;
    neo:text "All right."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_838 a neo:Document ;
    neo:id "748a99b8dfd8437428ad9f1fd28bf249"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 6 on page 27"^^xsd:string ;
    neo:text "We’ll leave you alone for that long."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_839 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "4edc355519e9088c307a2738c9722559"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 7 on page 27"^^xsd:string ;
    neo:text "But when the retreat is over, then it’s our turn again!” And it really is their turn again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_84 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "2a19805b1a772339ba213f849087ec0e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 4, sentence number 1 on page x"^^xsd:string ;
    neo:text "Sayadaw often encourages yogis to continue cultivating their own energy and wisdom after a retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_840 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_841,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_842,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_843,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "47c06287419da83b81dcad856623bba6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 8 on page 27"^^xsd:string ;
    neo:text "Delusion loves hearing the line, “The retreat is over!” It is very common to think that we’ve finished meditating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_844 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "8885934c1fd1dc2eee411e5e6d67fa50"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 1, sentence number 9 on page 27"^^xsd:string ;
    neo:text "When this happens, it is now time for defilements to come back out to play."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_845 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "4a3cc26d3862d0726f8d1e0b83ad98bb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 1 on page 27"^^xsd:string ;
    neo:text "When I was younger, I went for long retreats of six to ten months at a time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_846 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_847,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "02853616623a2e7a66a4d57ae2e8bde0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 2 on page 27"^^xsd:string ;
    neo:text "My mind cleared up while I was in retreat but I stopped practicing back home and my mind went back to square one."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_848 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_849 ;
    neo:id "bc80736e87cb4318aaf6bca1c4e4265c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 3 on page 27"^^xsd:string ;
    neo:text "My life did not change."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_850 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_851,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_852 ;
    neo:id "787bbba1a0b8511e51c6c7f69b1f5cf1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 4 on page 27"^^xsd:string ;
    neo:text "I never listened to my teacher’s advice to continue practicing at home and got into deep trouble!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_853 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_852,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "1e7842f7d7e290ea284a7b6efaa72d1c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 5 on page 27"^^xsd:string ;
    neo:text "It was only when I was in the deepest trouble that I saw the need to work it out in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_854 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "5adc81d28eb995cb5b1f7edbfdf81383"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 2, sentence number 6 on page 27"^^xsd:string ;
    neo:text "I began to practice continuously at home and realized the need to meditate all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_855 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "435861d86ba53429b94777bc0d1fe631"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 3, sentence number 1 on page 27"^^xsd:string ;
    neo:text "When you return home, remember that you are there, at home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_856 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "95c95ed771a6fe9cf127ac0a454526d4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 3, sentence number 2 on page 27"^^xsd:string ;
    neo:text "You should remain in the present moment there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_858 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "d3bf8a3f2e8d09168200beef729db6d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 3, sentence number 3 on page 27"^^xsd:string ;
    neo:text "The present moment is the only real thing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_86 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_88,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_89,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_90,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_91 ;
    neo:id "d4f8b6c9bb587dc299023cb6f0e54ee9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 4, sentence number 2 on page x"^^xsd:string ;
    neo:text "To help post-retreat, some of Sayadaw’s retreats even have participants going mindfully about their business during the day in their own homes or workplaces and discussing their eperiences and discoveries in evening and weekend Q&A sessions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_860 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_284,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "1fa0fa6aeb510884008c5d668d70504e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 4, sentence number 2 on page 29"^^xsd:string ;
    neo:text "Stay where you are because the now is always now, there is no “after now.” You’re trying to have mindfulness in this mind and the only effort is to remember to be mindful in the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_861 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_862,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_863 ;
    neo:id "8adebfed123e0a8f752b41bc84d711fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 4, sentence number 3 on page 29"^^xsd:string ;
    neo:text "Through everything in your life you are remembering to be mindful, remembering how to be mindful, and building and maintaining samādhi, or stability of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_865 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_866,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_868,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_869 ;
    neo:id "532fa9d96a96f3ee643486cfec7857b7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 4, sentence number 1 on page 29"^^xsd:string ;
    neo:text "You use the information that you have, combined with intelligence, logic, and reasoning to figure out how to practice correctly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_870 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "3e6d3111f89a6fcbcc3432da724bbf9b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 4, sentence number 2 on page 29"^^xsd:string ;
    neo:text "Next, you learn how to keep these already developed insights alive."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_871 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "6a1af996d9852348da6786b92eecb68c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Mindfulness is a Lifestyle Change, paragraph number 4, sentence number 3 on page 29"^^xsd:string ;
    neo:text "Finally, you figure out how to develop even deeper levels of insight."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_872 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_862,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_873,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_874,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_875,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_876 ;
    neo:id "fc4e8a19db735d3d0c93288f879a02f3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 1 on page 29"^^xsd:string ;
    neo:text "We must be walking on the Noble Eightfold Path of sīla (moral conduct), samādhi (stability of mind), and paññā (wisdom)."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_877 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_878 ;
    neo:id "7a1b8a775b0f1de57fcd0a156c918032"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 2 on page 29"^^xsd:string ;
    neo:text "This particular aspect of meditation, where you need to be practicing it all the time for it to be alive and beneficial becomes apparent to someone who practices continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_879 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_880 ;
    neo:id "01cdb2f8052ad391eb940c56ab603ba2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 3 on page 29"^^xsd:string ;
    neo:text "We really need to be a close friend of the Dhamma in order to grow in the Dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_881 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_882 ;
    neo:id "ff2501681ad98d31c26b242370058872"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 4 on page 29"^^xsd:string ;
    neo:text "It is when we are in such close communion with the Dhamma that we can grow in it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_883 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_884 ;
    neo:id "60b6f99deb3efa6731a20ebdc3acb1e5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 5 on page 29"^^xsd:string ;
    neo:text "Otherwise, there is not much growth."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_885 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "febf62f9b33c33d890608253532ac1ef"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 1, sentence number 6 on page 29"^^xsd:string ;
    neo:text "How can the Dhamma grow in us if we are not always living the Dhamma?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_886 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_303,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "92c7e38bb6d5075849113e7f25770cd3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 2, sentence number 1 on page 30"^^xsd:string ;
    neo:text "The Buddha frequently reminded his followers to keep the Dhamma in mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_887 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "93aad98322ae83982ad19525d5445288"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 2, sentence number 2 on page 30"^^xsd:string ;
    neo:text "He didn’t say when to have the Dhamma in mind, but just said to have the Dhamma in mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_888 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "04b895f57a349537fa74c02a12af51f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 2, sentence number 3 on page 30"^^xsd:string ;
    neo:text "Unless we are always meditating, delusion will step in and hold the door open for all the other defilements to move in."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_889 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_891 ;
    neo:id "bd48e0b6f4b2bf8bbba08914082f5760"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 3, sentence number 1 on page 30"^^xsd:string ;
    neo:text "People talk about how long they have been practicing meditation but they are only counting the length of time from their first retreat up to now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_892 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_893,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_894 ;
    neo:id "783fb9bf2f84e40acb569968175a77bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 3, sentence number 2 on page 30"^^xsd:string ;
    neo:text "If they added up the hours that they were actually mindful, that would be a wholly different picture."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_895 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_896,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_897,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_898 ;
    neo:id "9fe37dac430eff820d11f9af0da2c528"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 3, sentence number 3 on page 30"^^xsd:string ;
    neo:text "The way we usually work is to put in a lot of effort over a small period of time in the hopes of getting some reward."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_899 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168 ;
    neo:id "b37e43129d136e2bdcfc417f1a791380"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 3, sentence number 4 on page 30"^^xsd:string ;
    neo:text "That’s greed at work!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_900 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_901,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_902 ;
    neo:id "73c0cd1af1dea9c2c2c2bab550d0683e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 1 on page 30"^^xsd:string ;
    neo:text "Right effort is staying in it for the long haul."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_903 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_904,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_905,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_906 ;
    neo:id "2c46bb998f318438c9ab68c18b6600ba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 2 on page 30"^^xsd:string ;
    neo:text "You need to become familiar with the work that you do, to always be in touch with it so that you become skillful at it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_907 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_901,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_908,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_909,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_910 ;
    neo:id "1a9a19364a381426edecc5d03b72e68f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 3 on page 30"^^xsd:string ;
    neo:text "Right effort is not letting it slack off, not giving up, and never stopping."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_911 a neo:Document ;
    neo:id "e4d73e83546d98f8ae927dda0b6a3e73"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 4 on page 30"^^xsd:string ;
    neo:text "Keep going."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_912 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_913 ;
    neo:id "31a29add7aae272b0e5a769f1c67e932"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 5 on page 30"^^xsd:string ;
    neo:text "That’s real, right effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_914 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_915 ;
    neo:id "fa8d2c03925061e4500b750333211013"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 6 on page 30"^^xsd:string ;
    neo:text "Wisdom considers the long term."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_916 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_917 ;
    neo:id "1d8a87288c07765237875feb634b6386"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 7 on page 30"^^xsd:string ;
    neo:text "There’s no hurry but we also do not rest."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_918 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_919,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_920 ;
    neo:id "e36f3a464e3846d44a34a820e47cd5be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 8 on page 30"^^xsd:string ;
    neo:text "The more we understand the forces of nature and how they work, the more we begin to rely on the laws of nature to let things unfold in a steady way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_92 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_93,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "3d7160e081aab34ee294630595c8fa2f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 4, sentence number 3 on page x"^^xsd:string ;
    neo:text "Other retreats have incorporated mindful talking periods during the day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_922 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_923 ;
    neo:id "47f32ffee6e6140286fc1fa5fb99eaaa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 9 on page 30"^^xsd:string ;
    neo:text "It is also not for nothing that I’m using this word nature over and over."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_924 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "058b3385ae36fefff302ce0e5f01ea32"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 10 on page 30"^^xsd:string ;
    neo:text "When something becomes your nature, really second nature, it means that the momentum of that nature is very strong in you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_925 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "fc1ba110186a2a1cf4e7242db89748be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 4, sentence number 11 on page 30"^^xsd:string ;
    neo:text "It has become your nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_926 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_927 ;
    neo:id "31a3a2b27a03402a50571e5ec4168eae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 5, sentence number 1 on page 31"^^xsd:string ;
    neo:text "Momentum is important in every sphere of our lives and it is what makes things better and better."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_929 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_930 ;
    neo:id "0f413a35334addc95e0b1e6ffdf72b7e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 5, sentence number 2 on page 31"^^xsd:string ;
    neo:text "When there is momentum, it’s not only easier to do what we have to do but also easier to grow our expertise and improve."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_932 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_933,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_934 ;
    neo:id "a8682eb0711920d56ed68251f3aa12be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 5, sentence number 3 on page 31"^^xsd:string ;
    neo:text "If you were a high jumper, you would run to gain momentum so you can jump over the hurdle."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_935 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_934 ;
    neo:id "07bf52e7e2d45b8c89aff8fd9506b411"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 5, sentence number 4 on page 31"^^xsd:string ;
    neo:text "Right now, you may run towards the hurdle, look up, realize how high it is, stop, turn, and walk back!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_936 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_937 ;
    neo:id "0e77b6144f2d1fbd409b49db8801da42"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 5, sentence number 5 on page 31"^^xsd:string ;
    neo:text "You didn’t have enough momentum to take the jump."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_938 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "290a82aaa52b5fc16cfa1819c7199259"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 1 on page 31"^^xsd:string ;
    neo:text "I would ask you to look at your mind right now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_939 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_940 ;
    neo:id "025dede35ea187e9b584d8db3935a7ba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 2 on page 31"^^xsd:string ;
    neo:text "How often do defilements come in unnoticed?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_941 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_942 ;
    neo:id "bd273e905cb24b8318e04eb4b9bf9cdb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 3 on page 31"^^xsd:string ;
    neo:text "You’ve got to turn that whole paradigm upside down so that what is natural and unnoticed and always going on in your mind is awareness, stability of mind, and wisdom, just as the defilements are present right now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_943 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_944 ;
    neo:id "4522d03bec848fd5add303192eb7b3e1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 4 on page 31"^^xsd:string ;
    neo:text "If you ask me about setting aside time for meditation, yes, we should do that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_945 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_362,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_946 ;
    neo:id "cf7f17753f5cef0a7bb92d6d0263bd2e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 5 on page 31"^^xsd:string ;
    neo:text "It is a time, whether we sit or use some other form, that we determine that we will have in mind to be mindful most continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_95 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_100,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_98,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_99 ;
    neo:id "15f9982a767eccd8cf9db0f9b4c3c947"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 5, sentence number 1 on page x"^^xsd:string ;
    neo:text "Meditating in daily life means building up these skills with diligence and right inquiry."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_950 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "605ff9641082dc592246960782c0edc1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 6 on page 31"^^xsd:string ;
    neo:text "When I was at home, I sat before I went to work in the morning and before I went to sleep at night."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_951 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_952 ;
    neo:id "4df9c3fd91ef38b90b80003fa9fc9156"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 7 on page 31"^^xsd:string ;
    neo:text "I also sat from time to time throughout the day in my shop or at the coffee shop."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_953 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "d5e839d16d5351260431092f257571be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 8 on page 31"^^xsd:string ;
    neo:text "When there was a lull in my work or I had 5 or 10 minutes, I would be still and do meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_954 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "8d40fc7f8233824ae44a64e21c3ee6d8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 6, sentence number 9 on page 31"^^xsd:string ;
    neo:text "All of these things gathered my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_955 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "207105f9842c2198d8f02a61c0ef0495"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 7, sentence number 1 on page 31"^^xsd:string ;
    neo:text "We haven’t reached the point where practicing continuously in daily life feels essential for us, so much so that we cannot live without it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_956 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_200,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "45939fced75f8e7b134c58b7d5315028"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 7, sentence number 2 on page 31"^^xsd:string ;
    neo:text "If we felt that way about practice in our daily lives, we would maintain mindfulness so much more continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_957 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_958,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "a3fdc2308c65b679f286a2423825125f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 2 on page 32"^^xsd:string ;
    neo:text "When we want to maintain the peace in our mind for longer and longer periods, we begin to realize that all these elements of knowing what we are aware of must become part of our practice and skill."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_961 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_962,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_963 ;
    neo:id "3de37bce5152c6fac5fa975c58879139"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 3 on page 32"^^xsd:string ;
    neo:text "Otherwise, we cannot maintain the peacefulness of the mind because we lose it when we lose awareness like a leaky faucet loses water."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_964 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_962,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_965,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_966,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_967 ;
    neo:id "d1c94d1e7b7695181ba6eb2634bf7950"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 4 on page 32"^^xsd:string ;
    neo:text "We leak peacefulness when we lose mindfulness while talking, walking or going about our daily business."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_968 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_969,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_970 ;
    neo:id "31077e1e886173ed1d61250d7dfdaab6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 1 on page 32"^^xsd:string ;
    neo:text "Let’s use a business analogy to think about meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_971 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_969,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_972,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_973 ;
    neo:id "29ed9354f1a3bbc73a792b55cf8907ac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 2 on page 32"^^xsd:string ;
    neo:text "You secure some initial funding and you need to use your seed capital appropriately to start a business."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_974 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "cdde8f7f6dd0d6ff60efa7f7bf6b45bb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 3 on page 32"^^xsd:string ;
    neo:text "So far, you have done retreats."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_975 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_976,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_977 ;
    neo:id "5e6026d1db8907af92e5e7ee3635f14e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 4 on page 32"^^xsd:string ;
    neo:text "Once the cash starts coming in, you learn to maintain that cash flow."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_978 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "8c87c68a92e90bf43c8a4dadeca116b8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 5 on page 32"^^xsd:string ;
    neo:text "In meditation, you now have to consider how to keep insights alive in your daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_979 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_818 ;
    neo:id "36edc5124b4ca55f95f93988881c1e20"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 6 on page 32"^^xsd:string ;
    neo:text "Do you know how to do that?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_980 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_981 ;
    neo:id "a49f278f150a91ea8a36f8a0503f57ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 7 on page 32"^^xsd:string ;
    neo:text "To keep insights from fading, you have to allow these understandings to arise over and over in your mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_982 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "fc3119956976da66f287dae158c304c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 8 on page 32"^^xsd:string ;
    neo:text "Continue practicing at home, as you would on a retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_983 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_969 ;
    neo:id "5c12cb326ddadc42895b23184931d9dd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 9 on page 32"^^xsd:string ;
    neo:text "Once you can keep your insights alive and developing and keep your practice going, your business is now well established."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_984 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "6bd80a23fbd12ead4f3bfd2bbf9165d7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 10 on page 32"^^xsd:string ;
    neo:text "You can grow it even more."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_985 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_969,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_986 ;
    neo:id "b18dd4d47543e4effd6eafcbdb324ea0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 11 on page 32"^^xsd:string ;
    neo:text "You can dedicate yourself to expanding your business."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_987 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_988,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_989 ;
    neo:id "6f07bde39d4b2d36914daca90d6638b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 8, sentence number 12 on page 32"^^xsd:string ;
    neo:text "If you do not, instead of being like entrepreneurs, you may be like day laborers who make just enough money to survive day-to-day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_990 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_991,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_992,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_993,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_994 ;
    neo:id "ea9de8b56c11dcc28736cd40b4c194d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 1 on page 33"^^xsd:string ;
    neo:text "Does all this discourage you or propel you to press forward and go the distance?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_995 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_713 ;
    neo:id "12d5c7e2298fa2dc370e4cb71ceca71a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 2 on page 33"^^xsd:string ;
    neo:text "Sometimes it is hard to tell yogis the truth because I worry that I might make it all sound too difficult!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_996 a neo:Document ;
    neo:id "2e1807551295cd3a16393e9b5697508c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 3 on page 33"^^xsd:string ;
    neo:text "(Laughs.)"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_997 a neo:Document ;
    neo:id "d5a6e53c828ff38758f8cf0a2ac07731"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 4 on page 33"^^xsd:string ;
    neo:text "But it’s the truth."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_998 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "30d436b9e5c56432b9aa3acf9498d185"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 5 on page 33"^^xsd:string ;
    neo:text "Can you imagine how much practice that is going to take?"^^xsd:string .

