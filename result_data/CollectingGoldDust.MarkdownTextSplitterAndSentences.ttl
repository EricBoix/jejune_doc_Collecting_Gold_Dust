@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_0 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1 ;
    neo:id "aedd61165079f1f6b1ee9a9089e77b68"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Acknowledgements, paragraph number 3, sentence number 2 on page vii"^^xsd:string ;
    neo:text "Sayadaw U Tejaniya"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_10 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_11,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_12,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_13 ;
    neo:id "89095004187b2b7cd4da0d292a1cd53c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 4, sentence number 1 on page v"^^xsd:string ;
    neo:text "Homage to Him, the Blessed One, the Worthy One,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1003 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1004,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1005,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1006 ;
    neo:id "eeca0a58bcbac46ed49c3d2ef7002fb6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 7 on page 33"^^xsd:string ;
    neo:text "Now, when we look, it is natural for liking and disliking to arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1007 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1005,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1006,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_841 ;
    neo:id "6cea43f9ca707a5c8490ca6f769f9d7c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 8 on page 33"^^xsd:string ;
    neo:text "When we hear something, liking and disliking arises in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1008 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_284 ;
    neo:id "25066b107f10dce1008203f98cfa6621"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 9 on page 33"^^xsd:string ;
    neo:text "That is natural for us now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1009 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "65b4956e966d5ca7fa8cae37a83a7603"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 10 on page 33"^^xsd:string ;
    neo:text "Later, with more practice, it becomes natural for awareness + wisdom to be present when we look, hear, smell, touch, taste, or think."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_101 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_102,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_103,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_104,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_106 ;
    neo:id "314600fc8a0820b31bc3d5ab4880064a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 5, sentence number 2 on page x"^^xsd:string ;
    neo:text "It means asking the right questions at the right time to spur on an internal curiosity to investigate further."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1010 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "0205fd94afdc1c958924d5bbf189b8e0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEDITATING ALL THE TIME, paragraph number 9, sentence number 11 on page 33"^^xsd:string ;
    neo:text "Then we can begin to trust that awareness + wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1011 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1012,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "040ae45177fbcde15e2578b514a90d4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 1 on page 33"^^xsd:string ;
    neo:text "While I began practicing from a young age, I really started practicing at home in the midst of much suffering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1013 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1015,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_425 ;
    neo:id "0e01f18d194ad209e1bd34821c2a6dc5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 2 on page 33"^^xsd:string ;
    neo:text "I was in constant pain and sleep was my only rest."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1016 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_431 ;
    neo:id "510426238a3abdfbc5594cdffb040ed2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 3 on page 33"^^xsd:string ;
    neo:text "Every morning I woke up and the difficulty started again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1017 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "43dbc4a72528df0b66d1211102db5064"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 4 on page 33"^^xsd:string ;
    neo:text "I did not communicate much at the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1018 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_477 ;
    neo:id "d5c5dfbdbbc2aeb7f8fc5c0b11ab62ad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 5 on page 33"^^xsd:string ;
    neo:text "The only question I asked myself at that time was, “Why is the mind suffering?” This question really motivated me to keep watching the mind all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1020 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "127c83d21bc9adf59ca5775e02dda353"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 6 on page 33"^^xsd:string ;
    neo:text "At first it was just suffering and I didn’t know why."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1021 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_862 ;
    neo:id "12d601e23540752cb9fe380c98bb9ce7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 1, sentence number 7 on page 33"^^xsd:string ;
    neo:text "But slowly, from watching that continuously, awareness and samādhi grew and the mind became more peaceful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1022 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "18045bf12421558c63e8a7a774b9cea5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 2 on page 35"^^xsd:string ;
    neo:text "There was less suffering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1023 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662 ;
    neo:id "f79042e228b62cdf455d5d056c64b870"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 1 on page 35"^^xsd:string ;
    neo:text "When the mind began to have more peace then I made peace the main object for my awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1024 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_962 ;
    neo:id "d29368500bbd45292996a15d85b7d633"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 2 on page 35"^^xsd:string ;
    neo:text "Peacefulness became the anchor for my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1025 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1026,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "8d38d0a808786fbc30f3578f687bf923"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 3 on page 35"^^xsd:string ;
    neo:text "Knowing the peaceful mind, I was also aware of everything else that was happening in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1027 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_664 ;
    neo:id "7b437ee8b68ccbff4d574ad788965709"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 4 on page 35"^^xsd:string ;
    neo:text "I wasn’t interested in whatever level of wisdom I had achieved; I understood that if I were mindful, there would be some relief."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1028 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "6491f905164455478a938c7d357e4283"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 5 on page 35"^^xsd:string ;
    neo:text "I knew that whenever I meditated, the depression was reduced a little."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1029 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "e99051a5fcc559b57dbe4d2dbe46ee60"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 2, sentence number 6 on page 35"^^xsd:string ;
    neo:text "I understood that much."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1030 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_962 ;
    neo:id "f10b536b26243fd54494fd2187ac3c7f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 3, sentence number 1 on page 35"^^xsd:string ;
    neo:text "I kept an eye on the peacefulness and on whether it was being maintained or disturbed with whatever contact there was with external or internal experiences."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1033 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1026,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "78e1f6b1ad2ff6289a58171745c6b91d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 3, sentence number 2 on page 35"^^xsd:string ;
    neo:text "When you are aware of a peaceful mind, it continues to be peaceful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1034 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1035 ;
    neo:id "dc9b3d0a5008c83e7c6016aa5217da0a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 3, sentence number 3 on page 35"^^xsd:string ;
    neo:text "It becomes more and more peaceful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1036 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1026,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1037 ;
    neo:id "6da38479a1e7413c8a6ad8a74b1341fe"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 3, sentence number 4 on page 35"^^xsd:string ;
    neo:text "When you aren’t aware of the peaceful mind then the mind starts breaking down into chaos."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1038 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "ad86f79ef384c06f2e1f4a28b06dfd90"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 4, sentence number 1 on page 35"^^xsd:string ;
    neo:text "How long can you maintain stability of mind in daily life?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1039 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1040,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1041,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_303 ;
    neo:id "1ccabc502f5986b9a0d72f2c45509e7c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 5, sentence number 1 on page 35"^^xsd:string ;
    neo:text "The Buddha said that when there are leaves covering the surface of a lake, you can’t see your reflection."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1043 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585 ;
    neo:id "0a7341e84190459ba039a8ddb137d372"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 5, sentence number 2 on page 35"^^xsd:string ;
    neo:text "Also when the water is turbulent, you can’t see your reflection."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1044 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "4a54f26099f4cd1295cf90e32b1ee101"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 5, sentence number 3 on page 35"^^xsd:string ;
    neo:text "It is the same with the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1045 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1046,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "eb92ae52d422d8aea1f6676572632faf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 5, sentence number 4 on page 35"^^xsd:string ;
    neo:text "Stability and wisdom cannot arise when the mind is covered with defilements."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1047 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313 ;
    neo:id "be3ca001bc6ef618aba71ec601b95b51"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 6, sentence number 1 on page 36"^^xsd:string ;
    neo:text "We give wisdom more opportunities to arise when awareness and stability of mind are present for longer and longer periods."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1048 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1049,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1050 ;
    neo:id "1f59c8fb264e2bdec6a4c666dc8109d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 6, sentence number 2 on page 36"^^xsd:string ;
    neo:text "Once you recognize the agitated mind and continue to know that agitated mind, it starts to become peaceful and clear again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1051 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1052,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1053 ;
    neo:id "2db849a3bf35ed346078829b5551649c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 6, sentence number 3 on page 36"^^xsd:string ;
    neo:text "Not being aware of the agitation or confusion only leads it to spiral into more agitation or confusion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1054 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1026,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055 ;
    neo:id "e5165d47fbbfd80d7410f3bfc5793846"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 6, sentence number 4 on page 36"^^xsd:string ;
    neo:text "When you know the peaceful mind continuously and you know everything that’s happening in the mind, you’ll also immediately notice when a speck of defilement comes to disturb that peace."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1056 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1026,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1049,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057 ;
    neo:id "43c7ec066e0558d71286979dc79d1a89"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 6, sentence number 5 on page 36"^^xsd:string ;
    neo:text "At this point, you can immediately recognize the thought that preceded that shift from a peaceful mind to an agitated mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1058 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1059,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "80cd4fbb837ecc71e50005e8fde65ffd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 7, sentence number 1 on page 36"^^xsd:string ;
    neo:text "Sometimes, even if you’re not watching a lot of objects, you can know the main object, which is the state of your mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1060 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_679,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "9be632ad826157e82011b9197747ebf5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 7, sentence number 2 on page 36"^^xsd:string ;
    neo:text "When you know the state of your mind, you also know the feeling, body, and mind simultaneously so there is no need to go after many objects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1062 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1035,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1063,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_679 ;
    neo:id "2f2b0cb4f732e7570bd0842f4349c38c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 7, sentence number 3 on page 36"^^xsd:string ;
    neo:text "Instead, just know the state of your mind—whether it is peaceful or agitated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1064 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1065 ;
    neo:id "79e5a3d248666d79d0a44c6aae045e25"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 7, sentence number 4 on page 36"^^xsd:string ;
    neo:text "Keep that as your anchor as you know everything else and as you go about your business."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1066 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "18c3523d79a73d3c3cc1738bbfc2311b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 8, sentence number 1 on page 36"^^xsd:string ;
    neo:text "Yogis want to improve the quality of the mind but if you haven’t seen the mind, the mind cannot change!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1067 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "87db603ae3566902a49fcf9b3e6839a8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 8, sentence number 2 on page 36"^^xsd:string ;
    neo:text "In daily life, you may put in a lot of effort into your work with little energy left for awareness and awareness needs some energy as well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1068 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1069,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "a0db6d64beb08ae6b17115ffd3a7f520"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 8, sentence number 3 on page 36"^^xsd:string ;
    neo:text "If you are not skillful at using just enough energy for awareness, you’ll use too much energy and won’t have enough to do normal work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_107 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_108,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_110,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_43,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "c1f75f2d7a79824abc6d5706a07ba84a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 5, sentence number 3 on page x"^^xsd:string ;
    neo:text "The answers will reveal themselves to appropriate questions so long as we apply right view and perseverance to our meditation, Sayadaw reassures us."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1070 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "2b7be45f6490be7075d85348ae1fc494"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 9, sentence number 2 on page 37"^^xsd:string ;
    neo:text "Learn to use just enough energy, and then practice continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1071 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1072,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "4834cdaef40fdcedaf6bc4b0720fd276"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MAINTAINING A STABLE MIND, paragraph number 9, sentence number 3 on page 37"^^xsd:string ;
    neo:text "You will become skillful if you do this every day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1073 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1074,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "46983e4c3ccd60d87af72999b8499995"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BECOMING ENERGIZED, paragraph number 1, sentence number 1 on page 37"^^xsd:string ;
    neo:text "It’s very important to know the meditating mind that is at work because it allows us to see cause and effect and also helps us to continue doing the work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1076 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "186ec87dea4a2bb69d1312e5cf287be6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BECOMING ENERGIZED, paragraph number 1, sentence number 2 on page 37"^^xsd:string ;
    neo:text "It strengthens and energizes the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1077 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "79c8c0d0275c7b0a06f405d5fe858902"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BECOMING ENERGIZED, paragraph number 1, sentence number 3 on page 37"^^xsd:string ;
    neo:text "Even when we observe that awareness is present, we must also be clear about the object it is knowing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1078 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "51016344ffb799ef1a078bdcc693ee50"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BECOMING ENERGIZED, paragraph number 1, sentence number 4 on page 37"^^xsd:string ;
    neo:text "Both must be clear in order to have a complete picture of the workings of awareness in the present moment and thus for wisdom to arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1079 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "cbb541d8f6e1a66609ed9df9496f3d8d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 1, sentence number 1 on page 37"^^xsd:string ;
    neo:text "For most of us, awareness + wisdom are not ready and on standby so defilements are allowed to arise over and over."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1080 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1081,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1082,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662 ;
    neo:id "5a68296a38c48d28b2aa5701930dac56"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 1, sentence number 2 on page 37"^^xsd:string ;
    neo:text "It’s a vicious cycle: we can’t get peace; then we can’t make inroads into the practice; so we can’t get peace."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1083 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_793 ;
    neo:id "a187b588ff73b78bd991eea2bc6c8f97"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 1, sentence number 3 on page 37"^^xsd:string ;
    neo:text "Even if we forget about wisdom for a while, we are not even able to really continuously maintain just awareness and stability of mind in our lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1084 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1085,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1086,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "d1325642b22e3ed0fcf66998195bd9de"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 2, sentence number 1 on page 38"^^xsd:string ;
    neo:text "Most of us become skillful at mindfulness of body and feelings but we don’t become skillful with mindfulness of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1087 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1086,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1088,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1089,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1090,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1091 ;
    neo:id "b26834e76f28db6070228c5e5d831690"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 2, sentence number 2 on page 38"^^xsd:string ;
    neo:text "Particularly on shorter retreats, we do not become skillful in the third and fourth foundations of mindfulness—mindfulness of the mind and the dhammas."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1092 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1093,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1096,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1097,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1098 ;
    neo:id "f3593452d4a098b294d3209d6ea26b61"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 2, sentence number 3 on page 38"^^xsd:string ;
    neo:text "Short retreats give us time to calm our minds a bit and we go through the first and second foundations but we don’t really get established in the third or the fourth."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1099 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "4249275536bd7d6063891ce964752edd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 2, sentence number 4 on page 38"^^xsd:string ;
    neo:text "Then when we go home and stop practicing, and we have to start all over again when we return for another retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1100 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1101,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1102,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1103 ;
    neo:id "9d91a1897006a9b7c122d0e191a2017c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 1 on page 38"^^xsd:string ;
    neo:text "When we are learning to be skillful at something, like putting in golf for instance, we putt again and again and assess whether the energy we have used is sufficient."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1104 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1105 ;
    neo:id "10f452400710da3a94919ea51bac318a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 2 on page 38"^^xsd:string ;
    neo:text "We then adjust our game and try again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1106 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1107,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "1bbb6307b5a9ebf220375c2656401bf5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 3 on page 38"^^xsd:string ;
    neo:text "We need to bring that same approach to our meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1108 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1110,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1111,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "a8d9f2dafb1ff717a9eafcdcd22df06e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 4 on page 38"^^xsd:string ;
    neo:text "Instead of a forced focus, it is a light attention and full interest in the process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_111 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "b97f51bdd03bc9da34351d7b16b7f0e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 5, sentence number 4 on page x"^^xsd:string ;
    neo:text "When meditation gathers momentum, awareness becomes more natural."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1112 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1113,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "174b8260cfcbfd4374868c92ad96dcd1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 5 on page 38"^^xsd:string ;
    neo:text "People who cook will know what I mean."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1114 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1115,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1116 ;
    neo:id "2b7380485af9f49d31bbbef0aed890b1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 6 on page 38"^^xsd:string ;
    neo:text "How will an extra onion change the taste of this dish?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1117 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1116,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "c134f35e1ba5127c42d120ae7b60c385"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 7 on page 38"^^xsd:string ;
    neo:text "How would it taste if we were to cook the onion a bit longer?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1118 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1120,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1121 ;
    neo:id "1d5e10666950acb4eae48c3b2615d13a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 8 on page 38"^^xsd:string ;
    neo:text "How would the taste change if we added soy sauce instead of salt?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1122 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_793,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867 ;
    neo:id "44bdec74306062632328331e2c174110"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 9 on page 38"^^xsd:string ;
    neo:text "When we do everything else in our lives, we know how to use our intelligence to figure out how to do something best."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1123 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "4e1caf33bb02c40ac5f82e0eb8067cd9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 10 on page 38"^^xsd:string ;
    neo:text "Why don’t we do this with meditation?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1124 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1125,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "c0d8940a21aa6903c5fc410b4138d464"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 11 on page 38"^^xsd:string ;
    neo:text "Why do we just blindly follow instructions without getting personally invested and involved?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1126 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1127,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1128 ;
    neo:id "a25884878833b390ca4939ba1464dcb0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 3, sentence number 12 on page 38"^^xsd:string ;
    neo:text "If we get an instruction to focus, we may just start doing it without considering whether it is helpful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1129 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1131 ;
    neo:id "f065974a089a0cb376c9266c570bde8d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 2 on page 39"^^xsd:string ;
    neo:text "We need to assess for ourselves: Is this working?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_113 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_114,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_115 ;
    neo:id "ac5727b9ef69a65b549498facd339852"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 5, sentence number 5 on page x"^^xsd:string ;
    neo:text "There is less doing and more recognizing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1132 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1133 ;
    neo:id "615f8790091daa76d0be496d1dbde872"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 3 on page 39"^^xsd:string ;
    neo:text "What is the effect?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1134 a neo:Document ;
    neo:id "15230348d4d51163de5101f501d6c0cc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 4 on page 39"^^xsd:string ;
    neo:text "How is it?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1135 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1136,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1137,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "a2fba25ba5789b21b921408e1a4158df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 5 on page 39"^^xsd:string ;
    neo:text "I want you to open the door to possibilities through your own understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1138 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_459 ;
    neo:id "dbae7b40517ac3205a726d527cdb297b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 1 on page 39"^^xsd:string ;
    neo:text "When I first began practicing, my teacher would ask me questions and leave them unanswered."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1139 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "a744c065afd845c60ab1d50d071ba10a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 2 on page 39"^^xsd:string ;
    neo:text "I wanted to know the answers so I would go and observe in my meditation with his questions in mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1140 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0610c946032f0ddf6de64a97893db217"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 3 on page 39"^^xsd:string ;
    neo:text "As a result, I learned."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1141 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "952ba8c852331f28fe2c873c50f7eded"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 4 on page 39"^^xsd:string ;
    neo:text "At first, it was just greed in wanting to know, and that didn’t work!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1142 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "ade1e63f0fe38fa545aaff159c72b938"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 5 on page 39"^^xsd:string ;
    neo:text "I then learned what did not work and what worked, and slowly found my way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1143 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_340,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "840d15d3cf5488d30447100647f59220"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 4, sentence number 6 on page 39"^^xsd:string ;
    neo:text "I was fortunate in starting young and having a very good teacher in Sayadawgyi."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1144 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1145,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "8c2b0977b70a9693ded54d1626426450"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 5, sentence number 1 on page 39"^^xsd:string ;
    neo:text "Skill and understanding of how to do right practice is very important."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1146 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1147,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_259,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_793 ;
    neo:id "1576bc667ddda04242e4900506262bae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 5, sentence number 2 on page 39"^^xsd:string ;
    neo:text "When we become skillful at observing all six of the sense doors and really have a handle on it, that’s when we find ourselves confident about practicing at home in our lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1148 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_546,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "11e3f59e8f6a873334e1d4fd9ddcd646"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 5, sentence number 3 on page 39"^^xsd:string ;
    neo:text "We don’t know what circumstances are going to come up and we can’t predict what people or situations are going to hit us."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1149 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1150,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1151,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "9f80b80a2937f358bd825a52bd3b8e77"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 6, sentence number 1 on page 39"^^xsd:string ;
    neo:text "I would liken mindfulness to a mother tending to a baby."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1152 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1153,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1154 ;
    neo:id "2c4227b55211cba452cb556b8cfb9ac7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 6, sentence number 2 on page 39"^^xsd:string ;
    neo:text "Having children is a huge enterprise, as all mothers will know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1155 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1150,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1156,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1157 ;
    neo:id "74a563180046190817040fcea6cf8454"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 6, sentence number 3 on page 39"^^xsd:string ;
    neo:text "I once observed a mother caring for her two-year-old and saw just how skillful she was with the toddler as he sat on her lap."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1158 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1160,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_811 ;
    neo:id "3edad84dc613840b0c76930dac0b455c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 6, sentence number 4 on page 39"^^xsd:string ;
    neo:text "She held a conversation with four other people while feeding the child."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_116 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48 ;
    neo:id "e52ee246716722a0e2080c4528e96b7f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 6, sentence number 1 on page x"^^xsd:string ;
    neo:text "This book was compiled as a continuing thread to the question of what net?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1161 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_11,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1162 ;
    neo:id "092782673f59e9a15d4421607545922c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 7, sentence number 2 on page 41"^^xsd:string ;
    neo:text "As the toddler moved in her lap, she adjusted along with him, and every now and then gave him some food, and if he didn’t like what she gave him, she would put the piece down and give him a different piece and later on pick up the original piece again to give the child."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1163 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1164 ;
    neo:id "bde551992189e57fb5fc7fa48ed7f81d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 7, sentence number 3 on page 41"^^xsd:string ;
    neo:text "Sometimes she would eat it herself, always going with the flow, not making judgments of the child."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1165 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "544d258dc853fd0a24c195e33c64b60f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 7, sentence number 4 on page 41"^^xsd:string ;
    neo:text "Meditation is like this."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1166 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1167,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "c7b1ea076be755739acefe682e010c01"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW DO WE MAKE INROADS?, paragraph number 7, sentence number 5 on page 41"^^xsd:string ;
    neo:text "We may find it difficult in the beginning to mind what we are doing and be mindful as well but it’s all practice and habits."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1169 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318 ;
    neo:id "41f256cc58872253c9dad4286523d788"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 1 on page 41"^^xsd:string ;
    neo:text "If thoughts are too subtle, and you don’t catch the thoughts, then the causes will not show themselves."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1170 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313 ;
    neo:id "cd20e853cee70c7e97f6d9ea75356a3c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 2 on page 41"^^xsd:string ;
    neo:text "So there can be awareness and stability of mind, but wisdom is missing from the picture."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1171 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_175 ;
    neo:id "d708aa9dd1a5c92f76f39bb8c8668d28"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 3 on page 41"^^xsd:string ;
    neo:text "There needs to be a little bit of inquiry."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1172 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "3d568f1ef344cd0eb7b865c7ab1d4981"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 4 on page 41"^^xsd:string ;
    neo:text "First, we are mindful of what is happening as we move around in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1173 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1174,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "bbde996067ef806725d9790d3523f557"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 5 on page 41"^^xsd:string ;
    neo:text "Then, later on, we’ll begin to notice why our limbs are moving like that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1175 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_792 ;
    neo:id "fc3c4ee363cbca4158afbe44d25db734"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 6 on page 41"^^xsd:string ;
    neo:text "There’s a reason behind it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1176 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1177,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "687f02db2ec513af3f9f70415f6779cd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 7 on page 41"^^xsd:string ;
    neo:text "Whether it’s action, speech or mind, there’s some kind of idea behind these actions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_118 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_120,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_122,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_123,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "879cbc65a596822f44baabcd3363a2e2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 6, sentence number 2 on page x"^^xsd:string ;
    neo:text "We each have our own versions of the first few days of retreat ecitement calming down to a steady mind, building momentum over a week or two, only to see it crumble in the anticipation of reentering daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1180 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1177,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179 ;
    neo:id "0434321916ca30366bdc1689bca618a3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 1, sentence number 8 on page 41"^^xsd:string ;
    neo:text "There is no speech or action without some idea fueling it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1181 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1182,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "34e004bbb473648eba3e83c3bbae1c1b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 2, sentence number 1 on page 41"^^xsd:string ;
    neo:text "Why are you wearing the shirt you are wearing right now?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1183 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1184,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1185 ;
    neo:id "a8f545c1a13a96fa7692daef2e48c5fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 2, sentence number 2 on page 41"^^xsd:string ;
    neo:text "Why did you place your keys, for example, over here, instead of in the corner somewhere?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1186 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1187,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "6eb469bb3e4accacce259810847effc4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 2 on page 42"^^xsd:string ;
    neo:text "There are ideas in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1188 a neo:Document ;
    neo:id "ed48b049dc2b2da23372baaee27dded8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 3 on page 42"^^xsd:string ;
    neo:text "Notice what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1189 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "0fea98d5d5e25956b0443e2c59a0503b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 4 on page 42"^^xsd:string ;
    neo:text "If you are at the point where you can be aware of the mind, begin to pay attention to how it is feeling or what it is thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1190 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309 ;
    neo:id "9c2752f950c9d795d6dffa5c69d06a85"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 5 on page 42"^^xsd:string ;
    neo:text "You will then begin to see causes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1191 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1192,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "e7129628e9deec109057690479ca4179"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 6 on page 42"^^xsd:string ;
    neo:text "The mind is knowing, aware and feeling."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1193 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "0dd51e136987a9a15097ea914bdc5828"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 7 on page 42"^^xsd:string ;
    neo:text "Pay attention to the mind that wants to do things or that wants something to happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1194 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1195 ;
    neo:id "6a209eebe21efcbfef35bd271bab2ac8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 1 on page 42"^^xsd:string ;
    neo:text "These mental intentions are present everywhere in the body."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1196 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1197,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_966 ;
    neo:id "9afa47cb37c0d6c813616a4e4ebebb25"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 2 on page 42"^^xsd:string ;
    neo:text "What intentions are you aware of while you are walking?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1198 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_481,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "922ab6b109076dd560cebeb060bad6f4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 3 on page 42"^^xsd:string ;
    neo:text "What are you aware of when you are sitting?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1199 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "80cb1d74cbfe6021b3182543be46f4fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 4 on page 42"^^xsd:string ;
    neo:text "What are you aware of when you are working?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1200 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1202 ;
    neo:id "1089f26a599f0e3ff700abe8403e1967"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 5 on page 42"^^xsd:string ;
    neo:text "Do you notice the wanting to move?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1203 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1204,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1205,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1206,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "496bae47cf833c11ed2812fd7b4150c3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 6 on page 42"^^xsd:string ;
    neo:text "What do you want to move?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1207 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1208,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1209 ;
    neo:id "3c9256f25c8c14072afc901b0a8ff9ad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 7 on page 42"^^xsd:string ;
    neo:text "Every movement involves mental intentions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1210 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1197,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1211 ;
    neo:id "48b5a3bfc72a7d81f39b683197b043d1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 8 on page 42"^^xsd:string ;
    neo:text "If you’re moving both arms, there are intentions involved in both of them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1212 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "cff6e6d0aa226dea6f56b7f9dcbee1e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 9 on page 42"^^xsd:string ;
    neo:text "You can see these things if you’re watching the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1213 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1214,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_230 ;
    neo:id "5a74b774196b4f47a23f4e4b1c0aea3b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 10 on page 42"^^xsd:string ;
    neo:text "What are you aware of while you’re reading this?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1215 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_894 ;
    neo:id "f07df1c5c982e0116af9861c4dbdff8a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 11 on page 42"^^xsd:string ;
    neo:text "If you only watch the body, you will not see a complete picture."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1216 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "30f6c562803588090c8a58cf92bdf49d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 3, sentence number 12 on page 42"^^xsd:string ;
    neo:text "When you begin to see a more comprehensive picture of how the mind and body are operating, then you will also come to see causes and effects and it becomes very interesting."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1217 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "08acf5b3c8f6a96e8e44ecd92293d8f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 4, sentence number 1 on page 42"^^xsd:string ;
    neo:text "Defilements can still enter any time if there is awareness and stability of mind but no wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1218 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1219,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "5a5e3b965baed47f0e05e9715f2e32ee"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 4, sentence number 2 on page 42"^^xsd:string ;
    neo:text "So, even with the first two present, a little wrong turn in attitude can let in defilements!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1220 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514 ;
    neo:id "d62194b213861e66c55d3b7d9cf4d174"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 4, sentence number 3 on page 42"^^xsd:string ;
    neo:text "Fear can arise in just one thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1221 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1222,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1223 ;
    neo:id "98a959aa0d3efd14faf7cfe5e7895780"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 4, sentence number 4 on page 42"^^xsd:string ;
    neo:text "When you see one complete process, it will also be very clear that there’s no need to go around in circles."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1224 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514 ;
    neo:id "9901aa97f28060abab5c1420ecbfcf4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 2 on page 43"^^xsd:string ;
    neo:text "The mind understands that because of this thought, this effect of fear happens."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1225 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1226,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "18f887bd75389bd8057541e2bb2d66bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 3 on page 43"^^xsd:string ;
    neo:text "A yogi who pays attention to the way these causes and effects work will come to own this knowledge of cause and effect."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1227 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1228,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662 ;
    neo:id "08f17420a409a69abaee3646c9dfdfc5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 1 on page 43"^^xsd:string ;
    neo:text "When I was trying to understand the emotion of anger, I asked myself whether I was happy or at peace when there was anger."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1230 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "ce75cd217af04251f113a07d1a2b847a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 2 on page 43"^^xsd:string ;
    neo:text "Why was there anger?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1232 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "06e6e387e5cf6d024d02be9e3393c5fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 3 on page 43"^^xsd:string ;
    neo:text "What was I angry with?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1233 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "5ec111ba5d753bd3ee241714bd9e8d23"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 4 on page 43"^^xsd:string ;
    neo:text "When the mind is angry at something, there is some sort of underlying idea in there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1234 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1235 ;
    neo:id "4026afd0cc85de00aa134f3c751048a4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 5 on page 43"^^xsd:string ;
    neo:text "The mind is holding onto a certain belief and getting angry over it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1236 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_477,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "bfbbf5740134607a0fe004f427fe2caf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 5, sentence number 6 on page 43"^^xsd:string ;
    neo:text "As soon as I saw this happening in the mind, the anger just slid away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1237 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "56be218f53bf0aacc57c7d1bff18294d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 6, sentence number 1 on page 43"^^xsd:string ;
    neo:text "Sometimes people don’t even have an idea of what they’re angry about."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1238 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "2288f6202f09a2e6e0819622b39160e2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 6, sentence number 2 on page 43"^^xsd:string ;
    neo:text "So many things have accumulated over time that it’s hard to pull apart the strands."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1239 a neo:Document ;
    neo:id "15534e2ae64ac1e6720bfe781be15490"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 6, sentence number 3 on page 43"^^xsd:string ;
    neo:text "It’s all jumbled up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_124 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_125,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "8039969627053a2960817fa7ff3b0d7b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 2 on page xi"^^xsd:string ;
    neo:text "Forgetfulness sets in as we leave Sayadaw’s presence and the supportive environment of the center."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1240 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_520,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "7c9bdaffc69742314167210930734842"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 6, sentence number 4 on page 43"^^xsd:string ;
    neo:text "I sometimes ask people why they’re unhappy and they don’t even know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1241 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "210b60decb69ef2f29b5b9e2c5a0b7c4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 1 on page 43"^^xsd:string ;
    neo:text "You have to watch every time anger arises."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1242 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1243 ;
    neo:id "5c1af648638ef63361e19698e5e47855"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 2 on page 43"^^xsd:string ;
    neo:text "This anger wasn’t here a moment ago."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1244 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "9d12bde1e79708affd0ff96d7ca7f78b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 3 on page 43"^^xsd:string ;
    neo:text "Look at this feeling very closely."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1245 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "510bd52625ef0af6c26a299f825c6e52"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 4 on page 43"^^xsd:string ;
    neo:text "It has something to do with the conditions surrounding your experience at this moment because the mind has certain presumptions about these conditions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1248 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "8512a91fa196c1de44dfb6fd0f82f9c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 5 on page 43"^^xsd:string ;
    neo:text "Is it a person?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1249 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1250,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "15104a5c6aab5dea4a51a99be2c1a130"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 6 on page 43"^^xsd:string ;
    neo:text "Is it something in the environment?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1251 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "dd71f87ba84ebc47399ace0adc61d0d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 7, sentence number 7 on page 43"^^xsd:string ;
    neo:text "Is it you?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1252 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "af9d2ab0f6a2915e565209fa5c6ea5ea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 8, sentence number 1 on page 43"^^xsd:string ;
    neo:text "For example, people feel that they shouldn’t get angry when they’re on retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1253 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "29217abff8524c3e7a77f2a2c583a231"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 8, sentence number 2 on page 43"^^xsd:string ;
    neo:text "Anger arises anyway."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1254 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "c1f13d7e8d033bebf440466cce4d8e34"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 8, sentence number 3 on page 43"^^xsd:string ;
    neo:text "Now they’re angry that there’s anger!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1255 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1256,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "90db4cd6e9391f49ba83287848107a1c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 8, sentence number 4 on page 43"^^xsd:string ;
    neo:text "This is possible!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1257 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "c5cc7c293803e784552a376fee3496d3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 2 on page 44"^^xsd:string ;
    neo:text "Yogis then get frustrated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1258 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1259 ;
    neo:id "8bfd0b255370435b10f17f03f560d60e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 3 on page 44"^^xsd:string ;
    neo:text "Sometimes the mind may be in a habit of getting angry at something specific so when this object appears, anger will arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1260 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1261 ;
    neo:id "ba38af284d9fe300abfa6242c4c9d856"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 4 on page 44"^^xsd:string ;
    neo:text "If you’re able to understand this as a natural phenomenon, then the anger will go down in intensity immediately."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1262 a neo:Document ;
    neo:id "56c903909e3aaed344385e32b00e5524"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 5 on page 44"^^xsd:string ;
    neo:text "How is that?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1263 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1264 ;
    neo:id "40d3c52acfdd93c954eed7c782c46e47"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 6 on page 44"^^xsd:string ;
    neo:text "It’s because there is now Right Understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1265 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "53a84117aa4b62b75a8ded455411b7bf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 1 on page 44"^^xsd:string ;
    neo:text "You want to watch and learn what and why something is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1266 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "5f781e3823e0a0793e70db62daf35dbb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 2 on page 44"^^xsd:string ;
    neo:text "You want to know why anger is present."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1267 a neo:Document ;
    neo:id "7be8596e2e68e43edcbfdff3c14f53c2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 3 on page 44"^^xsd:string ;
    neo:text "Why does this feeling arise?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1268 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_515,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "8e2c6bf6ddc176c14a531f9e07ad1ad1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 4 on page 44"^^xsd:string ;
    neo:text "Maybe you are dissatisfied."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1269 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_515,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "3335919058a6c741a37f8a053606737d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 5 on page 44"^^xsd:string ;
    neo:text "Why are you dissatisfied?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_127 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_128,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "24a9edbea38f25a0dc54bfc56a46f08b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 3 on page xi"^^xsd:string ;
    neo:text "Even in the occasional outing to the village or city while at the Shwe Oo Min Meditation Center, yogis often report to Sayadaw that there are just so many objects out there!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1270 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "4f7eb96310b8e3f214c1c836b021fd4b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 6 on page 44"^^xsd:string ;
    neo:text "You want certain things to happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1271 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1272,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1273,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "eaf5c2de2ca8e0a2f9f6ac26e58e9806"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 7 on page 44"^^xsd:string ;
    neo:text "Let’s say you don’t get what you want or what you want to happen does not happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1274 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "81536785967975144ca586ee79586039"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 8 on page 44"^^xsd:string ;
    neo:text "You want something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1275 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "cfdb2ebf09dd7c700df547a7fff7842f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 9 on page 44"^^xsd:string ;
    neo:text "Can you just watch this anger?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1276 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1277,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "3ed8ff594be0e44435aa6e99d9e46928"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 10 on page 44"^^xsd:string ;
    neo:text "It’s impossible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1278 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "175298581e657fdf32a330f608832008"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 11 on page 44"^^xsd:string ;
    neo:text "The anger is going to keep on going."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1279 a neo:Document ;
    neo:id "2673ce8234cc65bf5d5e81743172700b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 12 on page 44"^^xsd:string ;
    neo:text "Why?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1280 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1281 ;
    neo:id "9b842252ea6cffe0cbc9ecd9ceb58064"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 13 on page 44"^^xsd:string ;
    neo:text "Because there’s some cause that you have not addressed yet."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1282 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "0f4b2ab81417819b0a9227e47fd5f30c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 14 on page 44"^^xsd:string ;
    neo:text "If you want to know the intensity of the anger, you can look to the intensity of the wanting."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1283 a neo:Document ;
    neo:id "0d6c81ef9a639e28e9e27d011e9b65e2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 9, sentence number 15 on page 44"^^xsd:string ;
    neo:text "They are related."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1284 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1285,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "7c1d34bcaf81f2bb8c19073c48efe59f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 10, sentence number 1 on page 44"^^xsd:string ;
    neo:text "When you have some preconceived notions about something and things don’t turn out the way you wanted them to, anger will arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1286 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1287,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "b03588eadc886ea24801c331253b5c7b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 10, sentence number 2 on page 44"^^xsd:string ;
    neo:text "Or you may feel justified in being angry over something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1288 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1289,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1290 ;
    neo:id "1d5704debd4f30c5a13287d7cdbb6a23"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 10, sentence number 3 on page 44"^^xsd:string ;
    neo:text "You may be relating an event back to a friend and you might say, “You know I really ought to be angry about so and so…” What does this mean?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_129 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "3e5123b3c3858c902f77164c568d4fa0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 4 on page xi"^^xsd:string ;
    neo:text "To which Sayadaw often replies that there are only six sense doors and knowing is of only the six senses at the six sense doors inside and out of retreat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1291 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "abd8abf7a66b91ca4a1a330cea2689da"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 10, sentence number 4 on page 44"^^xsd:string ;
    neo:text "It’s just the mind preparing itself to let this defilement loose."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1292 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "f1f486e4a816b5338c07aa009e2b26e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: INQUIRY AS A PART OF PRACTICE, paragraph number 10, sentence number 5 on page 44"^^xsd:string ;
    neo:text "But it’s never good to let anger loose."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1293 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1294,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "d017e54c6a384295ab50edaa92e1d8e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 1 on page 45"^^xsd:string ;
    neo:text "Now is the time for you to get into the boxing ring."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1295 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1297,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "d59823cac5294bdf04fbe84e18e1209e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 2 on page 45"^^xsd:string ;
    neo:text "I am the coach but all I can do is yell from the sidelines."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1298 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "efdd4ff3ec92c77e8a91f04bc879152e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 3 on page 45"^^xsd:string ;
    neo:text "For beginners, I’ll shout strategies when you look to me for support."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1299 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1300,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1301 ;
    neo:id "f324655383a010fe2521fc5ac6f040b1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 4 on page 45"^^xsd:string ;
    neo:text "Amateurs will often look to the coach for further instructions while the old hands don’t need to; they can think for themselves and deliver the punch."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1302 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1303,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "694ac63fb9512c4538f99b9659e1ef1e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 5 on page 45"^^xsd:string ;
    neo:text "As a coach, I can yell what I want but you, as the yogi and boxer can only use the strategies you are familiar with."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1304 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1303,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1305,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1306 ;
    neo:id "14671e8b9b5720aa69eb4e7868a1da71"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 1, sentence number 6 on page 45"^^xsd:string ;
    neo:text "You are the boxer in the ring and you are facing the real deal."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1307 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "ea58c655f7cff74bb32a9a06a17de355"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 1 on page 45"^^xsd:string ;
    neo:text "When I practiced at home, I would talk with my teacher once every week or so."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1308 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "ac75645760cf81f2440f11876a12d8e1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 2 on page 45"^^xsd:string ;
    neo:text "If you are practicing at home and do not have anyone to ask, ask yourself the question then set it aside."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1309 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71 ;
    neo:id "131a3d027b6cd9c641c4a85f6b99801d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 3 on page 45"^^xsd:string ;
    neo:text "Later, consider what I’ve said and what the Buddha taught."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1312 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1204,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1314,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "6fa87e95f40e778c27f03f2233b7b25b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 4 on page 45"^^xsd:string ;
    neo:text "What have you tried before?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1315 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1316 ;
    neo:id "81ff68f19d3ab63fed846d144a7e5919"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 5 on page 45"^^xsd:string ;
    neo:text "What has worked?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1317 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1319 ;
    neo:id "7522a98fe497609fbee7483eed5b5dd7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 6 on page 45"^^xsd:string ;
    neo:text "Should you try one way or another way?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_132 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_133,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "1a54eadcdabdd627bfa4d6314b407107"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 5 on page xi"^^xsd:string ;
    neo:text "Sayadaw noted in a recent retreat in California that most of us meet a limited set of people in our daily lives and go about our lives with a limited set of people, pointing out that if we observed our reactions to others with right view, we could learn to resolve these challenges ourselves."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1320 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1321,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "a6280a4b85ec6b033c1995adda508e64"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 7 on page 45"^^xsd:string ;
    neo:text "Even those who do not meditate will sit down and really think through a life problem if it matters enough to them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1322 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1324,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "37cf35c838a22ec27e9d2ffdfc621975"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 2, sentence number 8 on page 45"^^xsd:string ;
    neo:text "The thinking we are referring to with meditation is not just random, abstract thinking but right thinking and use of wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1325 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_459 ;
    neo:id "062d9875e97ce65bc2e3036127ce4220"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 3, sentence number 1 on page 45"^^xsd:string ;
    neo:text "My teacher never told me not to think."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1327 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "a0ab252fb8869356b1db655618632e89"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 3, sentence number 2 on page 45"^^xsd:string ;
    neo:text "He didn’t exactly encourage me to think either, but he did ask me questions that required me to be aware and to reflect on how I was practicing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1328 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_108,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "3835121c00ddbc5483a6ea00d45d7139"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 3, sentence number 3 on page 45"^^xsd:string ;
    neo:text "I eventually discovered the answers and realized that one finds answers by being aware and by questioning."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1329 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867 ;
    neo:id "09c697d2db67f5185c4a28f60f7dcec5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 4, sentence number 2 on page 47"^^xsd:string ;
    neo:text "When you begin with the why, you are already bringing out your internal curiosity and intelligence."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1330 a neo:__Entity__ ;
    neo:RELATED_TO ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867 ;
    neo:id "Beginning With The Why"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1331 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1332,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1333 ;
    neo:id "c2537a111874c861274c338b828c04d9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 4, sentence number 3 on page 47"^^xsd:string ;
    neo:text "You’ll have many questions initially in the learning phase, but you won’t have that many in the wisdom phase."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1334 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "e895776dc5aacd3e7e99708a78969411"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 4, sentence number 4 on page 47"^^xsd:string ;
    neo:text "At that time, the mind will be clearer and less cluttered."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1335 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1336,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "dac9790f6a0f09492717909882ba3e0e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 4, sentence number 5 on page 47"^^xsd:string ;
    neo:text "The student is inside you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1337 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "818094ee8ffdb6871ddaeec0a3465433"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GETTING IN THE RING, paragraph number 4, sentence number 6 on page 47"^^xsd:string ;
    neo:text "The teacher is also inside you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1338 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1256,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1339 ;
    neo:id "78b5d93f4c2bb63ba10330a1f6084eb9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 1 on page 47"^^xsd:string ;
    neo:text "This work is possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_134 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "f1be4f50ce2dba20e16f3d2986f751aa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 6 on page xi"^^xsd:string ;
    neo:text "Mostly we don’t watch and often not with right view."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1340 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1341,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_461,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "8127e78eb29f0c90b432620b8fd277b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 2 on page 47"^^xsd:string ;
    neo:text "You need to be patient and work through it for a few years continuously and patiently."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1342 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "783c84ecf24223587c955cd8e8f3b7aa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 3 on page 47"^^xsd:string ;
    neo:text "You need to taste the full flavors of Dhamma: of knowing, of awareness, and of understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1343 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "789e3883065fe79e99438079e9295b54"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 4 on page 47"^^xsd:string ;
    neo:text "You all have to cultivate your own energy and your own wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1344 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "5386b5893310382e9f310aa966cdedff"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 5 on page 47"^^xsd:string ;
    neo:text "When you have tasted enough Dhamma, it will lead you along."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1345 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "31c5a5f0c58adcdddc6439077daf8010"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 6 on page 47"^^xsd:string ;
    neo:text "When I practiced like that, I finally understood the meaning of if you look after the Dhamma, the Dhamma will look after you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1346 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "4ca3595d814c2e5589a6ca34017f85cb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 7 on page 47"^^xsd:string ;
    neo:text "Or if you take care of the Dhamma, the Dhamma will take care of you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1347 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_915 ;
    neo:id "1887f31dd1de5d9868a5e66d9d78b891"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 8 on page 47"^^xsd:string ;
    neo:text "When you really practice long term, the practice just becomes nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1348 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1349,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "f1914d4594248ecf9d09c217e8e8f233"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 1, sentence number 9 on page 47"^^xsd:string ;
    neo:text "When the practice becomes nature, it also becomes your nature to understand dhamma nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1350 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1351,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1353,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63 ;
    neo:id "16262a035623e8016b398a7d8af6ac55"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 2, sentence number 1 on page 48"^^xsd:string ;
    neo:text "Sometimes meditators are under the impression that they must practice in a specific way to get certain results."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1354 a neo:Document ;
    neo:id "41a1b300a169b8a7aad3d3566914c5f8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 2, sentence number 2 on page 48"^^xsd:string ;
    neo:text "That’s not the case."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1355 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "93b3f97fc87cb1837aff85b81fb97faf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 2, sentence number 3 on page 48"^^xsd:string ;
    neo:text "The process itself is a learning process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1357 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "c649e900fcc65d692bed3632646d5b82"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: “IF YOU LOOK AFTER THE DHAMMA, THE DHAMMA WILL LOOK AFTER YOU”, paragraph number 3, sentence number 1 on page 48"^^xsd:string ;
    neo:text "You are learning how meditation operates."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1358 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1360,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1361,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1362,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1363,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330 ;
    neo:id "23026464dcf7d5b7c705ce7af277ed6b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Take a Closer Look, paragraph number 1, sentence number 1 on page 49"^^xsd:string ;
    neo:text "My teacher constantly reminded me that all the problems in the world originate from the trio of lobha, dosa, and moha."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1364 a neo:Document ;
    neo:id "c82aa848b44787614f8bb16771922e6c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Take a Closer Look, paragraph number 1, sentence number 2 on page 49"^^xsd:string ;
    neo:text "Keep an eye on them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1365 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1366,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1367 ;
    neo:id "65ed774b00604a11056a9243bc145324"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Take a Closer Look, paragraph number 1, sentence number 3 on page 49"^^xsd:string ;
    neo:text "Watching and keeping these unwholesome qualities at bay will allow the wholesome qualities to arise automatically."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1368 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1369 ;
    neo:id "e25e6f2abcafc6d9b4f35eed171f3b69"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 1, sentence number 1 on page 49"^^xsd:string ;
    neo:text "When there are lots of pleasant physical sensations, we may become greedy for more."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_137 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "67c22795594b72774305e8420328bd9e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 1 on page xi"^^xsd:string ;
    neo:text "It is our hope that Sayadaw’s words will inspire all of us to continue wholeheartedly, being as sincere and serious as Sayadaw is about being aware and cultivating awareness at home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1370 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "91c74a2060af2723b6ede7cd0eb42e62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 1, sentence number 2 on page 49"^^xsd:string ;
    neo:text "Watch this greed while continuing to keep an eye on awareness as much as possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1371 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "f7fe23704c25e8be24e52420c24a2e78"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 1, sentence number 3 on page 49"^^xsd:string ;
    neo:text "When the wanting is very subtle and not detectable, you are at least still able to recognize the presence of awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1372 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "8849c712f7256d22034bd74ae65fdf80"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 1, sentence number 4 on page 49"^^xsd:string ;
    neo:text "With an awareness of awareness, it is harder for the mind to get lost in the pleasant sensations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1373 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "df8971eab9b45c32eaecbe9140652fa6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 1, sentence number 5 on page 49"^^xsd:string ;
    neo:text "Additionally, having to work at being continuously aware makes it harder for greed to wallow in the feeling."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1374 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1375,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1377 ;
    neo:id "bef98be7848837381e609e3729d274d7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 2, sentence number 1 on page 49"^^xsd:string ;
    neo:text "Is a physical sensation of hunger in the stomach and wanting to eat the same thing?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1378 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "08d468f2b7cdcb7cd09822fe208f9e0d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 2, sentence number 2 on page 49"^^xsd:string ;
    neo:text "Without mindfulness, it becomes hard to disentangle these two and it seems like the same thing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1379 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1380,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1381,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1382,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "709a27e65aab6f590f5c739e7dae068c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 2 on page 50"^^xsd:string ;
    neo:text "As you practice more, you will begin to recognize the differences between a bodily function like the stomach growling and the desire to eat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1384 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1385,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "87939fb5120d6db103b051ff6ebe5082"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 3 on page 50"^^xsd:string ;
    neo:text "When you are eating something, do you notice the difference between the taste of the hot-and-sour soup and the feeling that it is something pleasant?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1386 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1375,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1382,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1387 ;
    neo:id "b1e3c339ada31e96687756f15f5a3c38"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 4 on page 50"^^xsd:string ;
    neo:text "Hunger happens in the body or materiality whereas that desire to eat happens in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1388 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1389,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1390 ;
    neo:id "00c06448be160169be09a5294bd5d305"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 5 on page 50"^^xsd:string ;
    neo:text "That pleasant feeling is called vedanā."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1391 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1361,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "2044d4065b3524942cbe60da6c5a4287"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 1 on page 50"^^xsd:string ;
    neo:text "Lobha entwines itself around an object."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1392 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "1f4f95954afbf74ba316d4198af4fa5c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 2 on page 50"^^xsd:string ;
    neo:text "Will it wrap itself around an object and then let it go or will it entwine itself around an object and think, “I can’t let it go, I need it near me, I want it all the time”?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1393 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1361,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "bf89e5418c927288fcce9cdd04b327c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 3 on page 50"^^xsd:string ;
    neo:text "How strong is this lobha for this object?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1394 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1395,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1396,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "59e23061f518bab722d1a0a6a89346f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 4 on page 50"^^xsd:string ;
    neo:text "Let’s say we see a flower growing on a roadside and some people may note that it’s a lovely flower and keep walking while others may look at the flower and think that they want to keep it for themselves and pluck it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1397 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1398,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1399,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1400 ;
    neo:id "ec988a3330e024278ee9b128fae6ce6b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 3, sentence number 5 on page 50"^^xsd:string ;
    neo:text "Some attachments are like post-it notes while others are more like superglue!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_14 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_15 ;
    neo:id "9c3488421d2316a734c6d2ace7a96153"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 5, sentence number 1 on page v"^^xsd:string ;
    neo:text "the Perfectly Self-Enlightened One"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1401 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "85196aa8ff5cb4595e7768239823a689"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 1 on page 50"^^xsd:string ;
    neo:text "Let’s deconstruct attachment down to its nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1403 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1404,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "41ac35620d45cf9992a4b1914cf694e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 2 on page 50"^^xsd:string ;
    neo:text "You may be attracted to a particular person and you think you like the person as a whole."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1405 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "196922795a323d08edf7d8d53436097b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 3 on page 50"^^xsd:string ;
    neo:text "What exactly is it that you like about this person?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1406 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_624 ;
    neo:id "7d2849bf2adc4d6cc931f47cdc9173de"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 4 on page 50"^^xsd:string ;
    neo:text "Do you like their eyes or hair?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1408 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1409,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1410,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "5215e57052c96524f3fa81da9a04440d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 5 on page 50"^^xsd:string ;
    neo:text "Do you like the way they behave or the way they smile?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_141 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_142,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_143,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "30ed450892fe68fd63b672c0544e215c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 2 on page xi"^^xsd:string ;
    neo:text "In compiling these pages, we asked ourselves: What are the most salient issues to practicing in daily life?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1411 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1404,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1412 ;
    neo:id "b3c2ae562d4354805e195ce278011668"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 6 on page 50"^^xsd:string ;
    neo:text "Are you attracted to a mental quality?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1413 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "ff723a65f326762a2a78bf68ed1164a4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 7 on page 50"^^xsd:string ;
    neo:text "Do you have some idea about this person?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1414 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1415,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "7ecd6239c45ac282a77d63a026ad4c3e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 8 on page 50"^^xsd:string ;
    neo:text "Are they kind?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1416 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "6063aef930c7e62542d9fa297570e140"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 9 on page 50"^^xsd:string ;
    neo:text "Do they evoke a certain feeling that you do not get elsewhere?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1417 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1418 ;
    neo:id "fd2d3aa900549d4eaf433efe6da073df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 4, sentence number 10 on page 50"^^xsd:string ;
    neo:text "What particular characteristic is the mind wrapping itself around?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1419 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1418,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "8139a73c54eb256fc56742d304043135"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 5, sentence number 2 on page 51"^^xsd:string ;
    neo:text "Delusion can be so strong that we are initially attracted to a particular characteristic but as we are trapped and move towards the object, we come to believe we like the whole thing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1420 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1421,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_410 ;
    neo:id "585ae022da528e95ecc99902332bde00"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 5, sentence number 3 on page 51"^^xsd:string ;
    neo:text "Delusion spreads the view that this whole thing is fantastic!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1422 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1423,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170 ;
    neo:id "ebb14cda7e7ac78043022a6d0043f9c4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 5, sentence number 4 on page 51"^^xsd:string ;
    neo:text "Only one or two characteristics reel us in and then delusion ensnares us whole."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1424 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1425,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "ad33edbe3a9b9f4c9fb89c15bbac81fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE SPECTRUM OF WANTING, paragraph number 5, sentence number 5 on page 51"^^xsd:string ;
    neo:text "Check what catches your own mind and notice the experiences you are trying to recreate or re-experience through this particular product, person or experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1426 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_52,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_668 ;
    neo:id "82b70e122779fd7006bc715c3b14e5fb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 1 on page 51"^^xsd:string ;
    neo:text "Everyone has a lot of craving, but there is one very strong, but elusive craving."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1427 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "cabea256858ca8dfbf207157e9771002"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 2 on page 51"^^xsd:string ;
    neo:text "It is the desire for everything in life to be okay."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1428 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1429,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1430,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_311,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "c25567a25710db243fd3946e7121ca65"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 3 on page 51"^^xsd:string ;
    neo:text "This desire for everything to be okay is very strong and powerful, but we are not aware of it because it hits us at the subconscious level."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1431 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_311 ;
    neo:id "7fe8e45ca1c2e612d7f6f217f406689b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 4 on page 51"^^xsd:string ;
    neo:text "We grow up thinking that everything must work out the way we want it to and become upset when something tiny goes wrong."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1433 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1434,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1435 ;
    neo:id "fded80c870efe5f8964849f7ac0ee7c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 5 on page 51"^^xsd:string ;
    neo:text "The mind immediately becomes frustrated at the slightest hiccup."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1436 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1437 ;
    neo:id "9c1fc46f621982ccfe9bea71d942d072"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 6 on page 51"^^xsd:string ;
    neo:text "For example, if we want 10 things and we get all of them, the mind calms down without a problem."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1438 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1052,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "9d6458d0882a63376f2ab30ced71754b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 7 on page 51"^^xsd:string ;
    neo:text "If we can’t get one or two out of ten, the mind becomes agitated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1439 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "08072e36b6aeb9bab3cd367c067bb10c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 8 on page 51"^^xsd:string ;
    neo:text "If we can’t get half, the mind goes into depression."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1440 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "69ab779b87b300f03cdcdf0aaa034559"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 1, sentence number 9 on page 51"^^xsd:string ;
    neo:text "If we can’t get any, the mind may go crazy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1441 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1429,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1442,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_311 ;
    neo:id "1617fcdf452e9e2f402e7ef8f07f5817"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 2, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Don’t expect that everything should be okay."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1443 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1444,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1445 ;
    neo:id "edf602b13f87fb19f8b478f1b565ceec"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 2, sentence number 2 on page 53"^^xsd:string ;
    neo:text "The future is open and there is a 50% chance that the things that we do not want can happen to us."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1447 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1448 ;
    neo:id "648ecea9c7bcfc58154e1a2cac3e69d8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 2, sentence number 3 on page 53"^^xsd:string ;
    neo:text "We need to be prepared for this eventuality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1449 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1450,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1451,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1452,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1453,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_633 ;
    neo:id "77aeb017f58439977baa81cd9385eb55"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 2, sentence number 4 on page 53"^^xsd:string ;
    neo:text "What is obvious is that we will age, become sick, be separated from our loved ones and die."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_145 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_146,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "e939217a3d8664e82e82b1b85b6f0192"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 3 on page xi"^^xsd:string ;
    neo:text "What might arise more off the cushion that we may not experience as much on retreat?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1454 a neo:__Entity__ ;
    neo:EXPERIENCE ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1450,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1451,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1452,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_633 ;
    neo:id "Human"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1455 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_537 ;
    neo:id "734cf4daf93897ffa1160c2d78b2bffb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE WISH FOR EVERYTHING TO BE OKAY, paragraph number 2, sentence number 5 on page 53"^^xsd:string ;
    neo:text "Dukkha is certain."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1456 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1457,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1458,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1459,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1460,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514 ;
    neo:id "1e44287314e06bd9ceda8bb5e0ba32ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 1 on page 53"^^xsd:string ;
    neo:text "Let’s talk about aversion and the gamut of emotions ranging from sadness, sorrow, and fear, to hatred, anger, ill will, and other forms of aversion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1461 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169 ;
    neo:id "a210b0468e7207adf45a1a02dda277dc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 2 on page 53"^^xsd:string ;
    neo:text "Why is there aversion?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1462 a neo:Document ;
    neo:id "9b4e806b6f46a56adcea62fdfc486fbc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 3 on page 53"^^xsd:string ;
    neo:text "Why is it happening?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1463 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169 ;
    neo:id "f6b1f151ca043805465e64768e07ca58"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 4 on page 53"^^xsd:string ;
    neo:text "Whose aversion is it?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1464 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1465,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_522 ;
    neo:id "2cf4acd1a41db17c6e84c08afc09ef1f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 5 on page 53"^^xsd:string ;
    neo:text "Study this emotion as it arises and as it is happening in order to understand its nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1466 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1467,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "180866caddf3b613f53febb3c4f208fb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 1, sentence number 6 on page 53"^^xsd:string ;
    neo:text "If there is some kind of understanding already about the nature of aversion, it is very hard for it to grow in intensity."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1468 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1465 ;
    neo:id "df307f541f05955d2ce97802b7639131"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 1 on page 53"^^xsd:string ;
    neo:text "When you are feeling angry about something, study all aspects of this anger each and every time it arises."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1469 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "28d9f8ebfc6b4b98ba7f82c569f9796b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 2 on page 53"^^xsd:string ;
    neo:text "Observe the feelings, thoughts, and anything else surrounding this anger."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_147 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_148,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_150,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_151,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "d52d2f6b0297f74e1d3727b4352532e5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 4 on page xi"^^xsd:string ;
    neo:text "What stories from Sayadaw’s own experiences can address the challenges of daily life practice?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1470 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "f320684a4f70c0766085e66cac9d5d79"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 3 on page 53"^^xsd:string ;
    neo:text "Observe the way the mind was thinking before this anger came up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1471 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "d798e559cd519715b40934ab8421fa7e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 4 on page 53"^^xsd:string ;
    neo:text "If you become aware only when anger is already underway, or when it has passed, then you might not notice its causes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1472 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1473,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_522 ;
    neo:id "b7d1d671f37d9e70dc42450086e3a465"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 5 on page 53"^^xsd:string ;
    neo:text "You need to see the train of thought that came before this emotion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1474 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1475 ;
    neo:id "5c8cc40f03f2298316f156301a8d1691"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 6 on page 53"^^xsd:string ;
    neo:text "By this we are not talking about conceptual ideas (i.e."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1476 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1477,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344 ;
    neo:id "b3ad39341da58d77d8fd1300c7b38f4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 2, sentence number 7 on page 53"^^xsd:string ;
    neo:text "“so and so is making me mad”)."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1478 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "be57b4c5374b18ad8f43800bb28d5dc1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 2 on page 54"^^xsd:string ;
    neo:text "If you are aware of the mind directly while it is angry, you can see its causes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1479 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "a2c0ebde740b6cc9cf24609c89821a6e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 3 on page 54"^^xsd:string ;
    neo:text "Pay attention to the thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1480 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "c422f8b454ae0e37c7ece1639fdd4304"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 4 on page 54"^^xsd:string ;
    neo:text "What is it thinking?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1481 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "60f2b32f7cc8d93d44e180d1556d677c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 5 on page 54"^^xsd:string ;
    neo:text "How does it think when there is anger?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1482 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "e7ccac8cfc24eff9ba676fd36cfc47a9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 6 on page 54"^^xsd:string ;
    neo:text "How does the mind think in the absence of anger?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1483 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_310 ;
    neo:id "0732941d452334cd786b74e9db5a45d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 7 on page 54"^^xsd:string ;
    neo:text "With such awareness, you will begin to see causes and effects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1484 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "13b66ecc6ac27f4148e5445da15161f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 1 on page 54"^^xsd:string ;
    neo:text "So you see, it’s not enough to just to know whenever something arises."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1485 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1133,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1281 ;
    neo:id "a6f63aebcc22c9a538dd8d35c6386ce7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 2 on page 54"^^xsd:string ;
    neo:text "You have to reach the point where you recognize cause and effect at work as well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1486 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_310 ;
    neo:id "00df4b95ff744037cd36068964296ae3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 3, sentence number 3 on page 54"^^xsd:string ;
    neo:text "Without catching the causes, the effects will continue to grow unhindered and anger will grow and grow."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1487 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1465,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1488,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1489,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "fde78a4f4f463f34481708016274c715"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 1 on page 54"^^xsd:string ;
    neo:text "Investigate these things and study the mind’s phenomena at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1490 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1491 ;
    neo:id "a8a94ceb4a0d297147676c5bef687a4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 2 on page 54"^^xsd:string ;
    neo:text "Recognize the internal chatter every time there is thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1492 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1493,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318 ;
    neo:id "f53681827b1407d55f69c4fb83120f1c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 3 on page 54"^^xsd:string ;
    neo:text "What kinds of thoughts are there when you are alone?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1494 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_81 ;
    neo:id "573bf135b177e78d07daa8c1ec969884"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 4 on page 54"^^xsd:string ;
    neo:text "What kinds of thoughts are there when you are with others?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1495 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_546 ;
    neo:id "31e8624f9e51dac64eaa2a11dd6b94a1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 5 on page 54"^^xsd:string ;
    neo:text "How does the mind think in these circumstances?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1496 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "5d0a681a04bb389be01d85e4fbb1d4d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: WHY IS THERE AVERSION?, paragraph number 4, sentence number 6 on page 54"^^xsd:string ;
    neo:text "You need to see all of these things."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1497 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1498,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1499,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_511 ;
    neo:id "fbbf29eea3bd9ea40901b9410eee4fdb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 1, sentence number 1 on page 54"^^xsd:string ;
    neo:text "There was a time in my lay life when I had been practicing continuously for a year or so and I hadn’t had a major bout of anger for quite some time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1500 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_68 ;
    neo:id "ee368dbfefa5a4a8a8df14f8c73af118"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 1, sentence number 2 on page 54"^^xsd:string ;
    neo:text "I woke up sick one day and I went to work anyway and managed the family business alone."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1501 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1502,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "d6855068023ae2f91c57bcf0c1950564"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 1, sentence number 3 on page 54"^^xsd:string ;
    neo:text "Little dissatisfactions accumulated throughout the day but I didn’t take the time to work through them or clear them out."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1503 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1504,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1505,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "aea38ec21b841165d887d3aaf796a1dc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 2, sentence number 1 on page 55"^^xsd:string ;
    neo:text "Later that night, I asked one of my younger brothers (a doctor) for some medicine and he responded dismissively."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1506 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1507 ;
    neo:id "1348b8442d85c7814f4de9a441249696"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 2, sentence number 2 on page 55"^^xsd:string ;
    neo:text "That was the final straw."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1508 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1509,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1510,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "2feb1e658a517f2f877275c042cc3c20"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 2, sentence number 3 on page 55"^^xsd:string ;
    neo:text "I just exploded, thinking, “How dare he talk to me like this?” I kicked a chair across the room as I was used to doing in my younger days."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1511 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1510,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527 ;
    neo:id "73a99540d6e34b303315d6ea7057af9d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 2, sentence number 4 on page 55"^^xsd:string ;
    neo:text "My family was all sitting around the room at that time and everyone looked stunned."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1512 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1513,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "3be97a6e36ddee6f89e94186b4f47ccb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 3, sentence number 1 on page 55"^^xsd:string ;
    neo:text "Awareness only kicked back in when my older sister asked, “What’s happening to you with so much meditation?” I then saw the whole process internally and externally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1514 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1515,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1516,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "2eb2966cfaaa20fe0dc423b7ea3fae2d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 3, sentence number 2 on page 55"^^xsd:string ;
    neo:text "I saw the frightened faces around me and realized how I had disrupted my surroundings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1517 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1518,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1519,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1520,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "2ec4b04f09dc6463d579a249cbbb4432"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 3, sentence number 3 on page 55"^^xsd:string ;
    neo:text "I also saw the whole mental process from a very tiny grain to this explosion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_152 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_108,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_153,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_154,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "e36ae57b3f6929f4ff0ccfcb2247b780"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 7, sentence number 5 on page xi"^^xsd:string ;
    neo:text "To get at some of these answers, we have tracked down and edited transcriptions from the more recent retreats abroad."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1521 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231 ;
    neo:id "01b171e92a75aab9fa14877a7fc0a90d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 3, sentence number 4 on page 55"^^xsd:string ;
    neo:text "It became very obvious how negative this anger was."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1522 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1523 ;
    neo:id "db38c2ab17a333496e51cf5ca33a9497"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 3, sentence number 5 on page 55"^^xsd:string ;
    neo:text "There was not one bit of wholesomeness anywhere."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1524 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "ca49878633c24895d3e6d7bd41ff0a86"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 1 on page 55"^^xsd:string ;
    neo:text "Seeing all of this in one big picture, I made a vow that I wouldn’t let something like this happen again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1526 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1527,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_515 ;
    neo:id "03899b1ff722f1c215be119445249f95"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 2 on page 55"^^xsd:string ;
    neo:text "I learned not to continue along a line of thinking when I saw dissatisfaction arising in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1528 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "088a2e05ab0d0fb9c6fb1f87148cc851"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 3 on page 55"^^xsd:string ;
    neo:text "Instead I would switch to watching the feeling associated with that thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1529 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "4acf8b26c549b8fb3a29601010cf4a12"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 4 on page 55"^^xsd:string ;
    neo:text "From then on, I would clear the anger out even when I noticed a little bit of anger."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1531 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1532,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_271 ;
    neo:id "ad86137824f66679dbab4062b9e88e50"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 5 on page 55"^^xsd:string ;
    neo:text "Nothing else mattered except to pay attention to even the smallest hints of anger and I would work with samatha (tranquility meditation) and / or vipassanā depending on the situation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1533 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1534,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1535,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1536 ;
    neo:id "f02ae4ad18921d79a1e20f22979936d5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 4, sentence number 6 on page 55"^^xsd:string ;
    neo:text "Anger could go from a scale of zero to one and back to zero."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1537 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1538,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1539,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "1cd691580aacc66567b26fd55edfec48"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 2 on page 56"^^xsd:string ;
    neo:text "I worked with zeros and ones, never letting it accumulate further."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1540 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "756f18b59d6f1e493e83fbd7c6238fdd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 1 on page 56"^^xsd:string ;
    neo:text "Ask yourself why when you find yourself getting angry at something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1541 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "da031be9e062d6aeac3e11573c37bdb3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 2 on page 56"^^xsd:string ;
    neo:text "Question why you continue to be angry and why you are getting even angrier."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1542 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1543,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1544 ;
    neo:id "cb35b24b77ccb9cb40acd9307e513ce8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 3 on page 56"^^xsd:string ;
    neo:text "There’s fuel somewhere."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1545 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "d2d88d5d00f0f1267a3e46356ca20a1e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 4 on page 56"^^xsd:string ;
    neo:text "With many people, anger would go straight from zero to one to one million!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1546 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1547,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585 ;
    neo:id "2b3d6d4f1ab13087e1051f5be26f4c65"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 5 on page 56"^^xsd:string ;
    neo:text "Instead of cooling it with water, we’re all dousing this anger with gasoline!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1548 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1549 ;
    neo:id "7f75448e042fa58365036caf4b328bc4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: ZERO TO ONE MILLION, paragraph number 5, sentence number 6 on page 56"^^xsd:string ;
    neo:text "So whoosh, whoosh, whoosh, of course it would grow!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_155 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_156,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_157,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_158,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_46,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "b94b3ec2e4e8292cb298009aa2323291"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 8, sentence number 2 on page xii"^^xsd:string ;
    neo:text "While Sayadaw teaches through guided meditations and Q&As led by yogi questions, we have compiled this book thematically so that a reader can use it in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1550 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "28866b1f8a165035398c559c56144aac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 1, sentence number 1 on page 56"^^xsd:string ;
    neo:text "There are always subtle defilements underneath and delusion is always there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1551 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "0403a2c32de3eea7f916d74162111d95"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 1, sentence number 2 on page 56"^^xsd:string ;
    neo:text "Delusion is there whenever wisdom is not there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1552 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1553,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "c8805f8b19cd72fa42cc72d51b2d3cce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 1, sentence number 3 on page 56"^^xsd:string ;
    neo:text "It is only in those brief moments when wisdom is present that delusion is not present."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1554 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "e1fe50cabef486bb68a109825e54423a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 1, sentence number 4 on page 56"^^xsd:string ;
    neo:text "How many times does the idea of “I” not happen?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1555 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "b7d9dc7a0ce5e1185c5868ee44a9ddc1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 1, sentence number 5 on page 56"^^xsd:string ;
    neo:text "You may notice it for a brief moment then delusion comes in to cover the wisdom up immediately."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1556 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1363,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1557,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1558 ;
    neo:id "8d1c357615f6c791487c1230b9b82224"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 2, sentence number 1 on page 56"^^xsd:string ;
    neo:text "Moha is darkness and you have a thief’s tiny flashlight."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1559 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_596,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "4eeef706f82be48f2611613b954dad31"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 2, sentence number 2 on page 56"^^xsd:string ;
    neo:text "When you turn it on, it will light up a small area in front of you and you’re probably satisfied with that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1560 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_794 ;
    neo:id "d30a7e7c70c82a22902ea3651888d488"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 2, sentence number 3 on page 56"^^xsd:string ;
    neo:text "You may think, “Oh, I know a lot now.” What about everything that you do not notice?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1561 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_794 ;
    neo:id "3d9669bf6750cb2cd544fcb5f20662a5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DELUSION, paragraph number 2, sentence number 4 on page 56"^^xsd:string ;
    neo:text "It’s vast and you only know what you know, but you do not know what you do not know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1562 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1563 ;
    neo:id "2b0545e99b6663c370c9439544a4a58d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 1 on page 57"^^xsd:string ;
    neo:text "You don’t need to try to restrict or rein in a restless mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1564 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "215784610d2aaa1518d62006302858db"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 2 on page 57"^^xsd:string ;
    neo:text "Just recognize that if the mind is scattered, that it is scattered."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1565 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1566,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1567 ;
    neo:id "5976738aafba29612109584567145ab4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 3 on page 57"^^xsd:string ;
    neo:text "The fact that you recognize it means that something is already at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1568 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1569,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1570 ;
    neo:id "a76250e604e292e321839a9c7e3f5e68"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 4 on page 57"^^xsd:string ;
    neo:text "Just know gently without getting lost in the thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1571 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1572,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_563 ;
    neo:id "6bca71dcd6d8d8be53177c9e803730ba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 5 on page 57"^^xsd:string ;
    neo:text "The mind is like a monkey, going from tree to tree."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1573 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1572,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1574 ;
    neo:id "8b2ba413f173fe8e77b77dbad3ed2fce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 6 on page 57"^^xsd:string ;
    neo:text "How easy is it to control a monkey?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1575 a neo:Document ;
    neo:id "60c90bbb49a90257d8400a72e38f47d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 7 on page 57"^^xsd:string ;
    neo:text "Not so easy!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1576 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1577,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1578,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "5ba930b1cd5fc00c1c36dc8f645751ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 8 on page 57"^^xsd:string ;
    neo:text "Trying to control restlessness requires more energy and concentration, and will fuel even more restlessness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1579 a neo:__Entity__ ;
    neo:FUELS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1577 ;
    neo:REQUIRES ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1577,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1578,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "Controlling Restlessness"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1580 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1581,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "6cff9b0fae361e7eeae906b7496f74a1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 9 on page 57"^^xsd:string ;
    neo:text "Remember that this thinking has nothing to do with you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1582 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1583,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "614bde72793c14a896507502e797128f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 10 on page 57"^^xsd:string ;
    neo:text "You just want to know every time the mind thinks and be happy that there is awareness of this mental state."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1584 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1585,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1586,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1587 ;
    neo:id "37bbd9bf9ecde6fe8a75f178292a5fa2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 1, sentence number 11 on page 57"^^xsd:string ;
    neo:text "When the right attitude comes in and you acknowledge that a scattered, restless mind is not a problem, then the mind will become more stable."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1588 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1074,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "4e831fe7eef57b347ab9d461ef8d0e38"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 1 on page 57"^^xsd:string ;
    neo:text "If you know every time there is thinking, you (the meditating mind) don’t get drawn into the thinking, right?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1589 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "72a3acf6a47fa5a304cc026358bb75b7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 2 on page 57"^^xsd:string ;
    neo:text "You will get caught up in the thinking when you don’t realize what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_159 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "fc0cdd90ec86ecc22fe4076d1393e35f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 8, sentence number 1 on page xii"^^xsd:string ;
    neo:text "What do we do when the retreat is over?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1590 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591 ;
    neo:id "9c16c50c108090e2fa4ab20223728532"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 3 on page 57"^^xsd:string ;
    neo:text "Instead of taking the storyline as your object, just know that the thinking mind has arisen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1592 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057 ;
    neo:id "1cbca3e6c181891d2e1393813c496ff0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 4 on page 57"^^xsd:string ;
    neo:text "When one new thought has happened, you know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1593 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057 ;
    neo:id "117458ccfadffb6f0551045bb32f07df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 5 on page 57"^^xsd:string ;
    neo:text "When another new thought has arisen, you know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1594 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318 ;
    neo:id "b6c85aa3fe607ece224ef9115ba4e0ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 6 on page 57"^^xsd:string ;
    neo:text "Many, many new thoughts will arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1595 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "3d284088381ec7b70b7930940026f277"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 7 on page 57"^^xsd:string ;
    neo:text "Then you begin to observe that the mind that you thought was yours is not yours."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1596 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "981d3cb4ae106d675d3b695c0ee9ac5c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RESTLESSNESS, paragraph number 2, sentence number 8 on page 57"^^xsd:string ;
    neo:text "The mind is mind, not “mine” or “me.”"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1597 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_150,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1598,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "057ff48c2f0ae4b3ef9fcbc25ed9ea80"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 1 on page 59"^^xsd:string ;
    neo:text "It’s natural to have challenges arise in daily life and you may respond to these obstacles in different ways."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1599 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1600,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "f505f09074c7f4405f4c65b24efdca77"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 2 on page 59"^^xsd:string ;
    neo:text "You may solve the problem in the moment to make yourself feel better temporarily, but that brief relief won’t uncover the Second Noble Truth or the cause of suffering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_16 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_17 ;
    neo:id "5e58afeb3f1bed4781498e3e5db795af"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 6, sentence number 1 on page vi"^^xsd:string ;
    neo:text "You have to play,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_160 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_162,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_163,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_164,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48 ;
    neo:id "982dc7dd44a0c50f5164db30111a62ea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 8, sentence number 2 on page xii"^^xsd:string ;
    neo:text "“Mindfulness is a Lifestyle Change” begins the book while an abbreviated “Mindfulness in Brief” caps the book in the Appendix."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1601 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1602,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1603 ;
    neo:id "429a1b6e21b7ecf6528fb18823215f4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 3 on page 59"^^xsd:string ;
    neo:text "Remember that there is no flyover or underpass on the Noble Path; you have to go through town with whatever experience that arises."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1604 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1605,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1606,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1607 ;
    neo:id "3be0653a50532f2d710f0e74ebd0fec0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 4 on page 59"^^xsd:string ;
    neo:text "The lessons are all laid out for you, and you have to recognize it as a lesson, a chance to work with the obstacle and come to a realization that can free you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1608 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "62d6b76e3b40a4582098d7bef3de04c3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 5 on page 59"^^xsd:string ;
    neo:text "The real benefit of the Dhamma is in having looked at defilements and having understood them, to approach the same tasks with wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1610 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1611,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1612 ;
    neo:id "bafe2805d1add23406ddf093d7332118"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 6 on page 59"^^xsd:string ;
    neo:text "We do not stop engaging with life issues."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1613 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1614,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "1eb22c7405f6eeb9def93882065d70e6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 7 on page 59"^^xsd:string ;
    neo:text "When the mind truly comes to understand something that is wrong as wrong, it will not repeat the same mistake again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1615 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1612,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "d36c2644745e953739612bd5931de25c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 1, sentence number 8 on page 59"^^xsd:string ;
    neo:text "Understanding will then mature and you can handle life issues wisely."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1616 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1617,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_520 ;
    neo:id "f4eac86e270c3e72bfd846cb3f5caf69"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 2, sentence number 1 on page 59"^^xsd:string ;
    neo:text "We want to realize that it is the mind and its machinations that make us unhappy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1618 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1619,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1620,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1621,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1622,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "65f204b840f3d5a398fe5d0b21167622"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 2, sentence number 2 on page 59"^^xsd:string ;
    neo:text "Some yogis tell me that they practice mettā to counteract judgments and comparisons but practicing this will not uproot the cause of suffering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1623 a neo:__Entity__ ;
    neo:NOT_UPROOT ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1622 ;
    neo:id "Practicing Mettā"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1624 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1619,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1625,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1626 ;
    neo:id "6407d0ff56c7fec2494bf7c62b634364"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 2, sentence number 3 on page 59"^^xsd:string ;
    neo:text "Mettā is like a balm but does not take away the wound."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1627 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1628 ;
    neo:id "1ba6d73b7a3fd7714de9e336098078cd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 2, sentence number 4 on page 59"^^xsd:string ;
    neo:text "It’s more useful when you recognize how painful it is to judge."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1629 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1630,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1631,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "743a9e3e77781555df498b3f0b7c135f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 2, sentence number 5 on page 59"^^xsd:string ;
    neo:text "The purpose of living with awareness is to really know how things really are and to understand."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1632 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "784553c6caf9ab7df49eb9868c1c2053"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 2 on page 60"^^xsd:string ;
    neo:text "Hopefully that understanding will free us from those defilements."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1633 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1619,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1634,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_713 ;
    neo:id "b4de0393b61a214b4f9f4678753e0868"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 3 on page 60"^^xsd:string ;
    neo:text "So next time, do not use mettā as an antidote for that because then you won’t see the truth of what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1636 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1637,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1638,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_679,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "5e99fc4479f6ec5937c968ec6f8ae49a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 1 on page 60"^^xsd:string ;
    neo:text "We should be interested in the relationships within us: the interplay of objects, the state of mind, wisdom, defilements, and awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1639 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1637 ;
    neo:id "887a4de445c7f4331709e49b73323a3a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 2 on page 60"^^xsd:string ;
    neo:text "These are the relationships that we want to take care of."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1640 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1641,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "4d8dbbb30e191b11b0456cfcf6cb1e75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 3 on page 60"^^xsd:string ;
    neo:text "People out there and what they are doing are concepts."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1642 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "db665fc7784e1a2a7fb0cdb9b368e3c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 4 on page 60"^^xsd:string ;
    neo:text "Moreover, objects out there are not doing anything but minding their own business."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1643 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_852,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_969 ;
    neo:id "8ef44d319a7f0e1eeafba3635fb00db2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 5 on page 60"^^xsd:string ;
    neo:text "But this mind is not minding its own business and getting into all sorts of trouble."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1644 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "f6c4f863f4097cd8d2aacf802a943797"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 3, sentence number 6 on page 60"^^xsd:string ;
    neo:text "This is the relationship we want to take care of and this is what the practice is all about."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1646 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1516 ;
    neo:id "6c6f2436197f28b2da0455abc2d4c838"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 1 on page 60"^^xsd:string ;
    neo:text "Even if we were sitting somewhere and not speaking to or wanting to speak to anyone, we are still relating to our surroundings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1647 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "5e23dbadc15ba7b87a89130f6dd4f019"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 2 on page 60"^^xsd:string ;
    neo:text "Awareness should be observing this relationship."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1648 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1649 ;
    neo:id "8fc0370a5540821b1e4045f8df05547e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 3 on page 60"^^xsd:string ;
    neo:text "There is no need to fix the relationship that is already happening but we do want to be aware of what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1651 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1652,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1653,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "1605b9d352acbaadccb27dcd04a16e4d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 4 on page 60"^^xsd:string ;
    neo:text "There is a temporary end to suffering and there is an ultimate end to suffering and we have to pay the price accordingly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1654 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1656,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "e2b758a488e3132fa2c15666c2626b44"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 5 on page 60"^^xsd:string ;
    neo:text "Some things come easily and are cheaper."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1657 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1658,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1659,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "626afb48063f8675c0fc33ffdbcc5ae7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 4, sentence number 6 on page 60"^^xsd:string ;
    neo:text "We will have to pay a higher price for something more valuable."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_166 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_167,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "25fa626a2988a63de8ac9be55b3679e6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 8, sentence number 3 on page xii"^^xsd:string ;
    neo:text "The beginning chapters address the triumvirate of greed, aversion, and delusion while latter chapters delve into more specific topics for daily life, which is anytime, anywhere off the cushion although we could also be practicing on the cushion in our daily lives as well!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1660 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_314 ;
    neo:id "187aa9a652566a3182ddda4cb84de093"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 5, sentence number 1 on page 62"^^xsd:string ;
    neo:text "Wisdom increases faith; anyone who understands the value of mindfulness and has benefitted from applying it in their lives sees their faith grow."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1661 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1662,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_314 ;
    neo:id "92ef495dee166e6cbd7bebeb84a1a8fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 5, sentence number 2 on page 62"^^xsd:string ;
    neo:text "The most important element of faith is faith in ourselves and in our ability to apply ourselves to the practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1663 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_799 ;
    neo:id "d6ecfdb285116491aea608708bcedecf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 5, sentence number 3 on page 62"^^xsd:string ;
    neo:text "Wholesome minds support each other just as unwholesome minds support each other."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1664 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1665,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585 ;
    neo:id "9d901d6693dd8567937a145881910788"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 5, sentence number 4 on page 62"^^xsd:string ;
    neo:text "When there is more water, the fire"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1666 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1665,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1667 ;
    neo:id "6fad3be791c7ba8a1c09ca5d4f9dacda"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GOING THROUGH ROADBLOCKS, paragraph number 6, sentence number 1 on page 62"^^xsd:string ;
    neo:text "goes out; when there is more fire, the burning continues."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1668 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "f5ab46e9fd3965b25e44793473c48690"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 1 on page 63"^^xsd:string ;
    neo:text "Daily life will be full of ups and downs when greed, anger, delusion, and all their relatives come on strong."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1669 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "97b6b24d680af12a97d0e4e5af2b963a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 2 on page 63"^^xsd:string ;
    neo:text "The wisdom you’ve got may not be sufficient enough to stop them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1670 a neo:Document ;
    neo:id "a00711eed5e423a2f3d22de5188569b5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 3 on page 63"^^xsd:string ;
    neo:text "How do you approach such a situation?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1671 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_622 ;
    neo:id "4f25b2ee64b43cf3170280224a5a5583"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 4 on page 63"^^xsd:string ;
    neo:text "The first step is to accept whatever is happening in the mind as it is."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1673 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "04173a9fcd6a9969d282a9301a72c70c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 5 on page 63"^^xsd:string ;
    neo:text "Accept that this is just the nature of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1674 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1675,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "f2b1c137f187e870385c8f385d0e27e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 6 on page 63"^^xsd:string ;
    neo:text "Unless you accept, you will be fighting defilements with defilements."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1676 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1678,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_970 ;
    neo:id "a7879cf2ccdc3db26a75a245c7a88372"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 7 on page 63"^^xsd:string ;
    neo:text "I draw the analogy of trying to accelerate a car with one foot on the brakes!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1679 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677 ;
    neo:id "08dbef529a7d1989cffd0488209958c2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 1, sentence number 8 on page 63"^^xsd:string ;
    neo:text "The car won’t move."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1680 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "3df6d5fc91751345df0e4dfc9df4bb79"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 1 on page 63"^^xsd:string ;
    neo:text "So, when you begin, the mind may not necessarily completely be open to this process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1681 a neo:Document ;
    neo:id "41485e6ceabae8ab2f466126fee9ff35"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 2 on page 63"^^xsd:string ;
    neo:text "That’s fine."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1682 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_98 ;
    neo:id "34a6145fff7adda18d06f54c66be2f94"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 3 on page 63"^^xsd:string ;
    neo:text "This is how you start when you’re developing your meditation skills."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1683 a neo:Document ;
    neo:id "b4467fe8fd3e888f5ca256a9c53a0835"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 4 on page 63"^^xsd:string ;
    neo:text "Learn from these different situations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1684 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_310 ;
    neo:id "7c4ad561acf203ff1910aec74e68b2be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 5 on page 63"^^xsd:string ;
    neo:text "Later on, you’ll begin to notice causes and effects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1685 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "df2b1ca375aa4a090dc0502cbecdadb6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 2, sentence number 6 on page 63"^^xsd:string ;
    neo:text "Understanding the causes that lead to greater momentum in the practice will allow your meditation to improve naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1686 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1687,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_705 ;
    neo:id "a2bab22fa0245eac2a521cb0035736fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 3, sentence number 1 on page 63"^^xsd:string ;
    neo:text "While something is happening, awareness will continue to collect data little by little in the background and wisdom will step in when there is enough data."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1688 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1689,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "1227195c1066f7d77398aa6179b5b3de"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 2 on page 64"^^xsd:string ;
    neo:text "When wisdom steps in, you will no longer continue with the unskillful action."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1690 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1691,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1692 ;
    neo:id "c107566ce5814a51a6cbee8f228a5583"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 3 on page 64"^^xsd:string ;
    neo:text "Acknowledge and work through these challenging situations instead of avoiding them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1693 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1177,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "4683f1538bd7299fde2cb48c0e6806d4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 4 on page 64"^^xsd:string ;
    neo:text "When the mind comes understand that something that is wrong is wrong, it will not repeat an action again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1694 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1605,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "5ef73f5e6e0063ffce435499b7a5582c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 5 on page 64"^^xsd:string ;
    neo:text "The lessons are all there for you to work through."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1695 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1635,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "1634cbfbe87b6e7753990c1c95ad1e26"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 1 on page 64"^^xsd:string ;
    neo:text "What kind of understanding can you glean from what is happening?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1696 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1697 ;
    neo:id "9b709d48484eafb3cf7c261a8a7861be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 2 on page 64"^^xsd:string ;
    neo:text "You can start by being interested."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1698 a neo:Document ;
    neo:id "07e849809c494c2d67152d13a9045935"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 3 on page 64"^^xsd:string ;
    neo:text "Then investigate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1699 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "d4373afe5ec951a14514bbe242249967"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 4 on page 64"^^xsd:string ;
    neo:text "You will become aware of many different things but be mindful that these are just objects or experiences."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1700 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1701 ;
    neo:id "93b62c9a3278ff86abeefcbea879b3e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 5 on page 64"^^xsd:string ;
    neo:text "Begin to ask more questions: What is a concept?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1702 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "b2208840af87769eb1df9f00fb929740"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 6 on page 64"^^xsd:string ;
    neo:text "What is reality?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1703 a neo:Document ;
    neo:id "df9cc84d720410d856fd03132a5f2499"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 4, sentence number 7 on page 64"^^xsd:string ;
    neo:text "Continue to watch and learn."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1704 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1705,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_373,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_727 ;
    neo:id "233d59ef735a925e1134c88dabcdc838"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 1 on page 64"^^xsd:string ;
    neo:text "Cultivate curiosity and interest—they are important ingredients."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1706 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1707,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514 ;
    neo:id "a0d95e6942f9726b3b79358a081b2ed3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 2 on page 64"^^xsd:string ;
    neo:text "Don’t be afraid of making mistakes, and never feel bad about having made a mistake."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1708 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1709,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1710,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1711,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1712 ;
    neo:id "3df3308ff1962f57da48525b65978059"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 3 on page 64"^^xsd:string ;
    neo:text "These false steps are the stepping-stones on our path and a part of our progress."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1713 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1714,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1715 ;
    neo:id "2f764b12f3c2d5417ee000ef8a313065"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 4 on page 64"^^xsd:string ;
    neo:text "We cannot avoid making them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1716 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1707,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "e641c4fdad77e8fc9fefaf3ecb05fb40"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 5 on page 64"^^xsd:string ;
    neo:text "Becoming aware of, carefully looking at, and learning from mistakes is wisdom at work!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1717 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1707,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "73a063f1deade10af299b902274ec1b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 6 on page 64"^^xsd:string ;
    neo:text "As we learn from our mistakes, wisdom will start coming in more naturally, more automatically."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1718 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_461,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "d54a65fed8d64a921f9bccfda6a42f4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 7 on page 64"^^xsd:string ;
    neo:text "Over the years, as our practice progresses, as we become more and more mindful, the knowledge and understanding we have accumulated will naturally come in more quickly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1719 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "2a6b741f85c1a047a2b511819293bcb2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Reflect. Learn. Keep Going., paragraph number 5, sentence number 8 on page 64"^^xsd:string ;
    neo:text "Wisdom and mindfulness will start working as a team."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1720 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_311,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "4845d64cc3cfb6c937d0142d14a329b2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 1 on page 65"^^xsd:string ;
    neo:text "The dhamma encompasses everything."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1721 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1722,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1723,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "92a1e337e076beef9795fa763dd94126"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 2 on page 65"^^xsd:string ;
    neo:text "All the good and all the bad are all nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1724 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1725,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1726 ;
    neo:id "00f2b66d7be98e71ef88d868f52a9bad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 3 on page 65"^^xsd:string ;
    neo:text "You may only want the good and not the bad but that’s impossible to have."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1727 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1728,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "03b25fd718a05c8dc0807c6904800a7a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 4 on page 65"^^xsd:string ;
    neo:text "You will have negative reactions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1729 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1730,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1731,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1732,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1733,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "870b4e767ab9b54f753f3956effc430a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 5 on page 65"^^xsd:string ;
    neo:text "When there is insufficient understanding into phenomena or the wrong attitude towards an experience, you will have a negative reaction and you can’t stop that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_173 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_174,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_175,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_176,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_37 ;
    neo:id "2ca1ff70533a13f6753ba3180867b648"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 8, sentence number 4 on page xii"^^xsd:string ;
    neo:text "While it may seem at odds to have sections on cultivating wholesome minds, inquiry, and non-doing all in the same book, each of these pieces answers different needs at different times in our meditation practice, whether within a span of minutes or months."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1734 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1735 ;
    neo:id "9c365585471eaa66dd581cf5f9204b8d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 6 on page 65"^^xsd:string ;
    neo:text "Just know that a reaction is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1736 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "bb89e01ea3dc69a614534fbf2a76a871"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 7 on page 65"^^xsd:string ;
    neo:text "Know it and understand it, but don’t try and stop it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1737 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_311,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "8a971ea9541a10c6c6e078347d04d6d1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 8 on page 65"^^xsd:string ;
    neo:text "Everything will fall into place once there is understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1738 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1739,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_702 ;
    neo:id "50c70530b5ac8398dcfbb9edcfb6cc5f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 9 on page 65"^^xsd:string ;
    neo:text "Wisdom will know how to balance, do what needs to be done and drop the unnecessary bits."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1741 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_851 ;
    neo:id "fd3358ede466050168fcafb7fee8203d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 10 on page 65"^^xsd:string ;
    neo:text "Don’t force something to happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1742 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "957a957c9e411a80a332c6cd82f21072"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 11 on page 65"^^xsd:string ;
    neo:text "This goes against nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1743 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1205,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1744,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1745,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "ee6801311cd06520dd9aec2765ef2231"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 12 on page 65"^^xsd:string ;
    neo:text "While you can’t get something just because you want it or you work for it, there are two things that will move us forward: how much you do and how skillful you are."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1746 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1747,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_901 ;
    neo:id "73df0e156131a7ddc4cf15b392a359c4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 13 on page 65"^^xsd:string ;
    neo:text "Pay attention to applying skill and right effort— these pieces deserve your attention."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1748 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1749,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "53a68411fd7a07fabecf1d824cb10e85"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 1, sentence number 14 on page 65"^^xsd:string ;
    neo:text "Meditation is not like the lottery; you don’t pay a little and win a huge windfall."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1750 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1751,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1752,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1753,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1754,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "8d9127f6503f1f8c601d554a1cba7103"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 2, sentence number 1 on page 65"^^xsd:string ;
    neo:text "Reducing defilements is a learning process, and you will find that your understanding slowly emerges and moves toward the middle path as you recognize the extremes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1755 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1754,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1756,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1757 ;
    neo:id "76a42adbd208b0b8075aca960b9f1e98"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 2, sentence number 2 on page 65"^^xsd:string ;
    neo:text "Suppressing and expressing are the two different extremes, but you will experience them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1758 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1553,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1759 ;
    neo:id "5e2ed07f659a07c1c933c1aa57b0842f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 2, sentence number 3 on page 65"^^xsd:string ;
    neo:text "Watch what the mind does in those moments, learn what is beneficial and adjust accordingly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1760 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1725,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1726,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1761,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "a35283e47823c250ac6017855da89721"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 2, sentence number 4 on page 65"^^xsd:string ;
    neo:text "If you think something is good, you’re at one extreme, if you think something is bad you’re at the other extreme."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1762 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "5075c1c0d63b0f4b8fa8823e1f5c5101"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 2 on page 67"^^xsd:string ;
    neo:text "You have to see things as they are and where they lie."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1763 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1764 ;
    neo:id "9db2e079d885475b889cf0ee02476ca6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 3 on page 67"^^xsd:string ;
    neo:text "Therein lies the Middle Way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1765 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "56c89c1c871831424d10b885bcd2ce4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 4 on page 67"^^xsd:string ;
    neo:text "For example, when a defilement arises in the mind, you neither try to stop nor encourage the defilement."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1766 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "dfa1c945bc613ae1208da84ac4ec522a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 5 on page 67"^^xsd:string ;
    neo:text "Exercise right view in remembering that this defilement is not you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1767 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1768 ;
    neo:id "e7b3a3365e379c8eb79c9cee4972f011"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 6 on page 67"^^xsd:string ;
    neo:text "The defilement will express the amount of power it has and you can’t prevent that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1769 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1770 ;
    neo:id "24eeda33919bfd27b6720fe69a4737c2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 7 on page 67"^^xsd:string ;
    neo:text "Just step back and keep an eye on the defilement, consistently and patiently, learning and figuring out how it functions and its job description."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_177 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "64b2930e769fe1ac0b42b9d80d9f9220"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 9, sentence number 1 on page xii"^^xsd:string ;
    neo:text "It feels like we have been editing for quite some time, and we have, over some years, having worked on this manuscript in the midst of daily life, and understand fully when life just takes over."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1772 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1356 ;
    neo:id "b83512f116118850f903d678515d6be1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PAY ATTENTION TO SKILL AND RIGHT EFFORT, paragraph number 3, sentence number 8 on page 67"^^xsd:string ;
    neo:text "This is a learning process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1773 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1360,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "196e9e12ab258a31976346a373c432ed"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 1, sentence number 1 on page 67"^^xsd:string ;
    neo:text "How can we view the world through the lens of Dhamma?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1774 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1360,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1775,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1776,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_550,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "0cf123ef36e0fedd8a1e2a46b365b337"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 1, sentence number 2 on page 67"^^xsd:string ;
    neo:text "When we are thinking about the world, we are already thinking about concepts; we are thinking about people, places, and situations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1777 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1775,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1778,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1779,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "67600746cca75aca94725c437078371f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 1, sentence number 3 on page 67"^^xsd:string ;
    neo:text "When the mind pays attention to concepts, either wholesome or unwholesome states of minds will come up depending on how much wisdom we have."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1780 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "468dc7fb57caca88d76ee97e87808a8a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 2, sentence number 1 on page 67"^^xsd:string ;
    neo:text "I’ve noticed that when yogis observe defilements, it is often from a point of view that they are enemies to be fought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1781 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1782 ;
    neo:id "9ed03358440ae7eefbd48266a07d7a51"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 2, sentence number 2 on page 67"^^xsd:string ;
    neo:text "That is already a battle lost."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1783 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "1d2afbcf382ae6fcf1e0f66e57f81197"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 2, sentence number 3 on page 67"^^xsd:string ;
    neo:text "Defilements like it when you fight because fighting in itself is a defilement and they like that they have a spy in your camp."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1786 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1787,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "5a4c408597cf13f77f017620ba389b32"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 2, sentence number 4 on page 67"^^xsd:string ;
    neo:text "Fighting anger with anger gets you more anger, or “anger-squared.” Defilements cannot stand it when you watch them calmly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1788 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1672,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1789,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_727,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "c4e8ba7e2a1bfca2a6ef93550ed98301"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 2 on page 68"^^xsd:string ;
    neo:text "When you accept a defilement’s presence, take interest in it, and try to understand it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1790 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055 ;
    neo:id "f1cfb5392245e61da28c5c3a78367033"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 3 on page 68"^^xsd:string ;
    neo:text "That’s when the defilement becomes really uncomfortable."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1791 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_44 ;
    neo:id "184cdd17c4b407d581b0e8505f53e465"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 1 on page 68"^^xsd:string ;
    neo:text "For me, I understood that difficulties would decrease if I practiced mindfulness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1794 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1792,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1795,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "2baf22641d68322245bdcae68c470042"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 2 on page 68"^^xsd:string ;
    neo:text "I noticed that the intensity of suffering and problems would decrease when I practiced."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1796 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "9dacfc40144f79671c463da9b358ced5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 3 on page 68"^^xsd:string ;
    neo:text "Truly understanding this motivated me to continue."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1798 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1799 ;
    neo:id "66babc563e3ec86b5214cb584c127036"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 4 on page 68"^^xsd:string ;
    neo:text "When real understanding is present and strong, the mind changes for the better."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_18 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_17,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "dd488745edba827d259c5f8fe17a1408"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 7, sentence number 1 on page vi"^^xsd:string ;
    neo:text "play with awareness"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1800 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "a2f8ab7eb26a7a7cce4c8f7e8c3c79a9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 5 on page 68"^^xsd:string ;
    neo:text "If wisdom isn’t strong enough, the mind can’t change because defilements still arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1801 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "5ccb5d843418ed80047b9d9d96127d2a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 3, sentence number 6 on page 68"^^xsd:string ;
    neo:text "There are people who know about meditation but they don’t practice; for these people, their minds do not really change."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1802 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "f26be1799d438b9be3da0ecb537502ee"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 1 on page 68"^^xsd:string ;
    neo:text "Depression drove me to practice wholeheartedly at home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1803 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "5a42a12bcb1be768c8eb17d7f0a2366f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 2 on page 68"^^xsd:string ;
    neo:text "I remember first trying many different ways to alleviate these feelings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1804 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_283,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "de20fd277bd9c79f979989e66a61db9a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 3 on page 68"^^xsd:string ;
    neo:text "I went everywhere that I had ever been and explored new places seeking happiness but the depression followed me everywhere."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1805 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1806,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1807,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_485 ;
    neo:id "72104b8364a850be40c3f906e051a5ba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 4 on page 68"^^xsd:string ;
    neo:text "I couldn’t find happiness when I went out with my friends, whether I went to the beach or to the mountains or when I went thrill-seeking somewhere."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1808 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1809 ;
    neo:id "4de90d751c03f860e9403b3b77ec9e3e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 5 on page 68"^^xsd:string ;
    neo:text "Nothing made me happy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_181 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_182 ;
    neo:id "3fc6a1da4ecfc17d0faf06b4bc48e0be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 9, sentence number 2 on page xii"^^xsd:string ;
    neo:text "We have tried to stick to our own page limits for this daily-life book, lest we continue to edit forever!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1810 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1811 ;
    neo:id "81eb862f948c790cb041805fcb280f77"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 6 on page 68"^^xsd:string ;
    neo:text "Even drugs couldn’t do the job."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1812 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1813,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "4351ff6f768060a4ad53229c4a7aaba3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 4, sentence number 7 on page 68"^^xsd:string ;
    neo:text "It finally occurred to me one day that even if I were to go to the moon, the depression would also follow me there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1814 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1815,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_849 ;
    neo:id "431e4dca75bdeff40d9c448571f20cb6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 5, sentence number 1 on page 69"^^xsd:string ;
    neo:text "During this period in my life, my suffering became a very obvious object of meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1816 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "573d0fa41143b01e5066357c5c4ad9c5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 5, sentence number 2 on page 69"^^xsd:string ;
    neo:text "I watched until it became unbearable and then I changed the object to something neutral to continue being aware."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1817 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1818,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1819,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_78 ;
    neo:id "40742fcfe7cd2b0629db0fa33ea322e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 5, sentence number 3 on page 69"^^xsd:string ;
    neo:text "In Myanmar, ānāpānasati (awareness of the breath) was used as a common, neutral object but it was too subtle for me at the time because the suffering was so strong."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1820 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "7d9ab35874b6ec5244b07a0bdc041b3b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 5, sentence number 4 on page 69"^^xsd:string ;
    neo:text "I needed something stronger to make my breath obvious."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1821 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1822,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_83 ;
    neo:id "6a2d7f9c6c0da5d399c5e8efb59ad635"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 5, sentence number 5 on page 69"^^xsd:string ;
    neo:text "I found the answer in a Vicks nasal inhaler because I found that when I used the inhaler my attention would be at my nostrils."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1824 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1825,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "c8f46bbc37a8a4bbd8c2a01be817ff65"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 1 on page 69"^^xsd:string ;
    neo:text "When it comes to using wisdom, I’m not asking you to think of a solution or to resolve the situation by thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1828 a neo:Document ;
    neo:id "6eb6122be3eeb7aefffbef5a99ce9715"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 2 on page 69"^^xsd:string ;
    neo:text "That’s not what I’m saying."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1829 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "b03fe927b5279e6c791a1421e40f98f3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 3 on page 69"^^xsd:string ;
    neo:text "Thinking a little allows us to practice effectively."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_183 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_184,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_185,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_186 ;
    neo:id "d1e40d0efbf7ead0a450f96e014d3e21"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 9, sentence number 3 on page xii"^^xsd:string ;
    neo:text "If this is the first book you are picking up with Sayadaw U Tejaniya’s teachings, may we suggest the illustrated Don’t Look Down on the Defilements for a funny and quick primer on the right attitude for meditation, Dhamma Everywhere: Welcoming Each Moment with Awareness + Wisdom for a more in-depth look, and Awareness Alone is Not Enough with Q&A’s from different retreats?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1830 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "261bec4b5ec71b60b7f7f6b954aaab76"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 4 on page 69"^^xsd:string ;
    neo:text "I see it as a considered practice where you are aware and you reflect a little bit on what you’re doing, how you’re doing it, and what you’re discovering: a little bit, not a lot."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1831 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "858379ac48e3bb88bca5d70eea9e9eb8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 5 on page 69"^^xsd:string ;
    neo:text "This is what we do when we are at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1832 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "035e347a41e3d5a0ac1832234cef97dd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 6 on page 69"^^xsd:string ;
    neo:text "When we do our work, we consider whatever work we have done before and how we accomplished this kind of work so we can figure out the best way to move forward."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1833 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "9f8be1216584aaaf3af7871129b34dea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 7 on page 69"^^xsd:string ;
    neo:text "None of us do work without considering how to do it the best way possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1834 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1835,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1836,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1837,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1838 ;
    neo:id "9f631569fd11c9af434410e5f1349452"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 8 on page 69"^^xsd:string ;
    neo:text "Even when we’re trying to fix something we are not yet familiar with, we may tinker with it, take time to reflect, check what is happening, see whether it is working and then tinker a bit more."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1839 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867 ;
    neo:id "63906da512576a08d6155067d25227cc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 6, sentence number 9 on page 69"^^xsd:string ;
    neo:text "That is what I mean by using wisdom in using our own intelligence to find our way in our own practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1840 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1841,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1842,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1843,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1844,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1845 ;
    neo:id "5197604d241245cf86351853145eca26"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 1 on page 70"^^xsd:string ;
    neo:text "If any of the Brahma Vihāras, or the “sublime states” of loving kindness, compassion, sympathetic joy, and equanimity arise, the mind will feel good and we will feel at peace and ease in understanding of the way things are."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1847 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1843,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1848,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1849,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "b82c2011e0c42c2bf0cea3fd4e651c2a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 2 on page 70"^^xsd:string ;
    neo:text "If there is compassion without wisdom, that compassion might actually be contaminated because it is mixed up with a non- acceptance of what actually is; a feeling of helplessness will be in there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1850 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "6dccf161e724610f44df40c0dbc04fdb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 3 on page 70"^^xsd:string ;
    neo:text "If that happens, you will need to clear the mind first."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1851 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1852 ;
    neo:id "3a2bf1494d92b344c9b97cecb77bdd6a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 4 on page 70"^^xsd:string ;
    neo:text "Come back to observing the unwholesome mind state with right view."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1853 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1845 ;
    neo:id "6b3eec2217764c5f5eccc0e72c0926b5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 5 on page 70"^^xsd:string ;
    neo:text "Do not try to force yourself to have equanimity."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1854 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1855,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_702 ;
    neo:id "aa8b671dc20d02b3f6aa50a0d7368d4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 6 on page 70"^^xsd:string ;
    neo:text "Work with the unwholesome states that arise until the mind comes to some balance."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1856 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1841 ;
    neo:id "81062075e12c7f4db4e6ffc3ab63ba46"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: HOW TO WORK WITH DIFFICULTIES, paragraph number 7, sentence number 7 on page 70"^^xsd:string ;
    neo:text "Then you will recognize whether it is any of the Brahma Vihāras arising in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1857 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_457 ;
    neo:id "3d032bc3f71ec94d6d3eb3ae1158aacd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 1, sentence number 1 on page 70"^^xsd:string ;
    neo:text "When I was deep in depression and I began to try practicing at home initially, I watched all my difficult emotions and it became a very strong motivation to keep awareness in order to get better."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1858 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_717 ;
    neo:id "4bb1116c1cfe8fd72067c4884e69da75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 1, sentence number 2 on page 70"^^xsd:string ;
    neo:text "As soon as it got better I would lose the motivation to be as mindful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1859 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1860,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1861,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1862,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_733 ;
    neo:id "eef99fe349f7849bfeb5408da4990840"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 1, sentence number 3 on page 70"^^xsd:string ;
    neo:text "I would revert back to my old ways, talking and joking with neighbors and neighboring shops or customers."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1863 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1864,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1865,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1866,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1867,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1868 ;
    neo:id "11befd50519a4801ff3c847fd3f9b011"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 2 on page 71"^^xsd:string ;
    neo:text "Then some trigger would hit me really hard, or hit a sore point that brought up all the old anxieties, fears, guilt or shame and I became overwhelmed again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1869 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1866,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "6024c3f778d693c686725b4b130959f2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 3 on page 71"^^xsd:string ;
    neo:text "Watching all the old fears and feelings would alleviate it a bit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_187 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_188,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_189,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_190,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_191 ;
    neo:id "2427bd8b1c606f01907977790be201d2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 2 on page xiii"^^xsd:string ;
    neo:text "These are all given out freely and can be accessed online at www.ashintejaniya.org or through Wisdom Streams, www.wisdomstreams.org in North America."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1870 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "3bed644de4d920bec5e3b8e27e9a5a75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 4 on page 71"^^xsd:string ;
    neo:text "But when it got better, I forgot again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1871 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_344,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "6b614a0c3e8094d689c57f44d21eb17e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 5 on page 71"^^xsd:string ;
    neo:text "It felt like people were coming by and slapping or hitting or punching me mentally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1872 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1873,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_645 ;
    neo:id "e900d9fb78f8bd638d1d8aada4eaad7b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 6 on page 71"^^xsd:string ;
    neo:text "It was not intentional on their part; it was just that my mind was not strong enough to be resilient."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1876 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1877,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "5b9a883d407b5ff6a162f020e80161ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 7 on page 71"^^xsd:string ;
    neo:text "Over many months, seeing the mind triggered daily and easily, I began to think about why I kept going back into this cycle."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1878 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "9e997a1d1769faa3dd61860e48552d11"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 8 on page 71"^^xsd:string ;
    neo:text "I suffered through this many, many times."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1879 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1880,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "922e9e49c3f7bdac7f7e93aa95e52364"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 9 on page 71"^^xsd:string ;
    neo:text "I then realized that I was becoming too relaxed and not being mindful enough."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1881 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "eedf9825d221fa13c8e5fe7818349609"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 10 on page 71"^^xsd:string ;
    neo:text "When I began to feel better, I thought, “I can’t stop being mindful.” Even when I was feeling better and there was nothing to do, I would not waste my time talking needlessly, and I would always be mindful of something or another."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1883 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "076237a1815e6cbc7ac33956096be931"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 1 on page 71"^^xsd:string ;
    neo:text "I became prepared when people came to talk to me."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1884 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "fd034f1d7d24fc2d8359930414e8e718"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 2 on page 71"^^xsd:string ;
    neo:text "Other people can be full of defilements too and they come and unload their defilements on us."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1885 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1886 ;
    neo:id "77eeccf0007e43babbc01b776f73a3a6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 3 on page 71"^^xsd:string ;
    neo:text "If we are not ready, we get affected and infected."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1887 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1888,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0902e307415ab8d7704477e1a4034706"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 4 on page 71"^^xsd:string ;
    neo:text "Even with family members, I began to realize that I could not just relax."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1889 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "f81d4f77dac62f33770492dedbd81605"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 5 on page 71"^^xsd:string ;
    neo:text "I could not drop mindfulness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1890 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "c313f15ae04c0cbb6aaada2d943539e8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 6 on page 71"^^xsd:string ;
    neo:text "My mindfulness got better and more continuous."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1891 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1892,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_44 ;
    neo:id "be3ab6e9f74e32ae786c3c77be95e8d2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DON’T LET GO OF MINDFULNESS, paragraph number 2, sentence number 7 on page 71"^^xsd:string ;
    neo:text "This is how we learn from life—our failures and difficulties teach us."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1893 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "e6145b85607bce2a5407ff34da17bc8c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 1, sentence number 1 on page 73"^^xsd:string ;
    neo:text "My teacher would always ask how I was practicing and that is what I’m asking you now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1894 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_43 ;
    neo:id "c53c732d31ec3f7b26bcedbcf3a5ff2f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 1, sentence number 2 on page 73"^^xsd:string ;
    neo:text "“What are you doing?” or “What is special or different today?” were questions my teacher would ask me."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1895 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_83 ;
    neo:id "6989781c74a19e2f1cd4226f130e2102"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 1, sentence number 3 on page 73"^^xsd:string ;
    neo:text "Yogis who are practicing will know the answer while those who are not practicing will not know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1896 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "65438b0458d328d313ff1dbf1369fd8f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 1 on page 73"^^xsd:string ;
    neo:text "Reviewing what goes on in the mind is the work of wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1897 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_257 ;
    neo:id "d1fc43f7c139a9b173f3911bc43bed5f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 2 on page 73"^^xsd:string ;
    neo:text "At first, when we watch anger, we are just watching."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1898 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1899,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1900,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1901,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1902,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1903 ;
    neo:id "ed8bc60dae9815b68c6d6bd99760884d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 3 on page 73"^^xsd:string ;
    neo:text "Reviewing what has happened sets a direction for the mind and creates a map of sorts for future awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1904 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1905,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "eb164a3a6b889c8e931863be044ff057"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 4 on page 73"^^xsd:string ;
    neo:text "You have a situation that you consider from different angles and decide to try meditating a certain way the next time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1906 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1907,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "77c71c405440e3945e3d56c057dfb5e6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 5 on page 73"^^xsd:string ;
    neo:text "When the next time comes, you are more likely to remember to try it that different way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1908 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1909,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1910,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1911 ;
    neo:id "2cf8fc8c046567dd7ca96232a8dda551"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 6 on page 73"^^xsd:string ;
    neo:text "If you forget, set an intention to try again the next time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1912 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1913,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1914,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1915,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1916 ;
    neo:id "df7745f8b878c91fdb8869e1be1f7fce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 2, sentence number 7 on page 73"^^xsd:string ;
    neo:text "When you play a game with the same scenarios occurring again and again, you become an expert at knowing ahead of time what moves are beneficial and what are not at certain junctions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1917 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1918,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "0fe0086481be07d24d025698bd8b4e0f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 3, sentence number 1 on page 74"^^xsd:string ;
    neo:text "If you want to improve, you first work continuously without a break."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1919 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1072,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1920,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "ebecab79640bb567c019a124afb1056f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 3, sentence number 2 on page 74"^^xsd:string ;
    neo:text "You also use the wisdom you’ve got, determining what is skillful and what is not skillful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_192 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_193,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "061f382334be6ea9ffb1c8b949ffb68a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 3 on page xiii"^^xsd:string ;
    neo:text "For more auditory learners, please check for Sayadaw’s retreat audio on www.dharmaseed.org."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1922 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "9ca1b1aba986372f3f24906c3369af64"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 3, sentence number 3 on page 74"^^xsd:string ;
    neo:text "You need to assess your practice for yourself."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1923 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1924,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "1c67f7448c2cfb8f874606bdabe0afff"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 3, sentence number 4 on page 74"^^xsd:string ;
    neo:text "Like running a business, you’ve"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1925 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1926,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "ea1237326ac8569df24eb247ff8bf99d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: REVIEWING WHAT HAS HAPPENED, paragraph number 4, sentence number 1 on page 74"^^xsd:string ;
    neo:text "got to be savvy and learn from your practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1927 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1928 ;
    neo:id "98fa548cccfc168d9843ed3092af0e21"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 1, sentence number 1 on page 75"^^xsd:string ;
    neo:text "When you are aware of what’s happening in the mind, you begin to notice the undesirable parts and will want to change."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1929 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1930,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "f599ac74800dac839023b9b65ca78fa4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 1, sentence number 2 on page 75"^^xsd:string ;
    neo:text "This is a beginning."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1931 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1605,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "884a33d5334f135b52e249f4a764858a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 1, sentence number 3 on page 75"^^xsd:string ;
    neo:text "The lessons are all there for you to go through and learn."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1932 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1933,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "11ba74157c9297904ce48664e26bed6b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 1, sentence number 4 on page 75"^^xsd:string ;
    neo:text "Later on, if you really come to understand that something that is wrong is wrong, you will not repeat it again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1934 a neo:Document ;
    neo:id "a659398dfc45f577cfd6eddda513fad7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 2, sentence number 1 on page 75"^^xsd:string ;
    neo:text "Don’t try to do anything,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1935 a neo:Document ;
    neo:id "38ce82f62a612afef396524225713d58"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 3, sentence number 1 on page 75"^^xsd:string ;
    neo:text "don’t try to prevent anything,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1936 a neo:Document ;
    neo:id "757bc8fa368641f7177fd466cd2e21d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 4, sentence number 1 on page 75"^^xsd:string ;
    neo:text "but don’t forget what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1937 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_274,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_330 ;
    neo:id "34469b8d1d8d83d2c47bade5c05292c9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 1 on page 75"^^xsd:string ;
    neo:text "This is what my teacher, Shwe Oo Min Sayadaw would say as his instructions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1938 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "be498cf6fbd48012048665d7cc51737b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 2 on page 75"^^xsd:string ;
    neo:text "In the first two lines, he is speaking to the experience of what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1939 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "acd355a090729d00de69f834db875a1f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 3 on page 75"^^xsd:string ;
    neo:text "Awareness can be at work, but you do not try to alter the experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_194 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_195,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_196 ;
    neo:id "ba19f78e9467b7894c0a2070a781de3b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 4 on page xiii"^^xsd:string ;
    neo:text "When Awareness Becomes Natural: A Guide to Cultivating Mindfulness in Everyday Life is a commercial publication that can be accessed through Shambhala and other sources."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1940 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "51b625f59b0731c9d9ee6a04dd8536a2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 4 on page 75"^^xsd:string ;
    neo:text "You let the process continue as it is without interfering."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1941 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1942,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "c601bdad7cd969d518f0753560100ad3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 5 on page 75"^^xsd:string ;
    neo:text "Let things unfold naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1943 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_136,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1569,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1944,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1945,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1946 ;
    neo:id "6d01fa422aeae616e912175d7e3e175b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 6 on page 75"^^xsd:string ;
    neo:text "Your job is to watch, know, learn, and gain experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1947 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1948,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_894 ;
    neo:id "ebf66e85ef593cbb44a0da70d8f6f841"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 5, sentence number 7 on page 75"^^xsd:string ;
    neo:text "As you watch an experience continuously, you’ll begin to recognize patterns within it and later see the whole picture."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1949 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "09b04a89e7b34928308a6b96bd582e86"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 2 on page 76"^^xsd:string ;
    neo:text "The value of this meditation becomes more apparent with dedicated practice over long stretches of time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1950 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1951,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "ff6312d1f8e72efaf4be793e8d415c62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 3 on page 76"^^xsd:string ;
    neo:text "The more experienced you become, the deeper you will see."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1952 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "dab5eaf8949d9d2c4ae1e332a932481a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 4 on page 76"^^xsd:string ;
    neo:text "The dhamma is very subtle and you’ll see this when you practice long term."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1953 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "6e105e05761c039d77e8b21d0c61d882"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 1 on page 76"^^xsd:string ;
    neo:text "What is happening in the mind and what is happening in the body right now?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1956 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1957,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1958 ;
    neo:id "cccfd3175f6bd95c83bbaf1ae958b74b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 2 on page 76"^^xsd:string ;
    neo:text "How is one mind or mental state related to another mental state?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1959 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "529482665e64a0d82aa14c62321d6ab9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 3 on page 76"^^xsd:string ;
    neo:text "You want to be interested in the nature of this mind and body."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1960 a neo:Document ;
    neo:id "ac04c784fb8db0c1ad47fc8388343b09"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 4 on page 76"^^xsd:string ;
    neo:text "Hold concepts or story lines on the side for now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1961 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1962,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "88aa1c9f653956120f513b860335e244"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 5 on page 76"^^xsd:string ;
    neo:text "As wisdom gains traction and defilements eventually thin out, you’ll see that there aren’t that many problems per se."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1964 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170 ;
    neo:id "0b56e57d838024f5a217fcd6b5061907"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 6 on page 76"^^xsd:string ;
    neo:text "“Problems” arise when there is a lot of greed, aversion or delusion present."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1965 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1672,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_382,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "21362dada788157c4cecf786e1725dbf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 6, sentence number 7 on page 76"^^xsd:string ;
    neo:text "When we can’t accept things as they are, we exhaust ourselves with desire for things that are not present or with desire to push away things that are already there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1968 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1969,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1970,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1971,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1972,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1973 ;
    neo:id "86e232709b8681506f2aa19c3b06a2f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 7, sentence number 1 on page 76"^^xsd:string ;
    neo:text "The mind seeks variety, novelty and freshness and becomes lazy or bored when it’s not satiated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_197 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_189,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_198 ;
    neo:id "e38c38faf2915157a6325c68dce8332f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 5 on page xiii"^^xsd:string ;
    neo:text "We appreciate greatly your very vital contributions towards future free publications globally; please reach out to any of us at info@wisdomstreams.org."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1974 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "4066c62af11e5164a7ba9ba29141a12a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 7, sentence number 2 on page 76"^^xsd:string ;
    neo:text "If we think that a certain experience is lingering longer than we’d like, we’re not observing properly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1975 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1553 ;
    neo:id "9dd88391662b792495ebb733ebec2e9c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 7, sentence number 3 on page 76"^^xsd:string ;
    neo:text "No two moments are the same."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1976 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1971,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_814 ;
    neo:id "3ca0fe82b48e16e6f670eb4ad7d115b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 7, sentence number 4 on page 76"^^xsd:string ;
    neo:text "Every moment is fresh and every moment is changing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1977 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1978,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "e589047f3a6c9d7a9f6cbff644d7d790"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Day-to-Day, paragraph number 7, sentence number 5 on page 76"^^xsd:string ;
    neo:text "Even if an experience may seem neutral, we can still see subtle changes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1979 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1980,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_754 ;
    neo:id "203ad5f7e296c515bac175279bab63e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 1 on page 77"^^xsd:string ;
    neo:text "Yogis usually know about the Five Precepts and Eight Precepts so I do not need to tell them to you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1981 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1980 ;
    neo:id "66bbadff5d2447e9213ead3e30323895"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 2 on page 77"^^xsd:string ;
    neo:text "If there is always mindfulness, you will automatically follow the Five Precepts."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1982 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1980 ;
    neo:id "9e45c41edf1995844021d01ac97b5668"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 3 on page 77"^^xsd:string ;
    neo:text "We must have some idea about what the Five Precepts entail in order to maintain them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1983 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_794,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "5471233ee1e2f4232ddcf34d6850d113"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 4 on page 77"^^xsd:string ;
    neo:text "It’s important to have that kind of knowledge already, but I’m not the sort of person who wants to impose requirements on people."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1984 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1125,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1985,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "baf2db8ad44956e222a52312b2a7c264"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 5 on page 77"^^xsd:string ;
    neo:text "If you merely follow my instructions without conducting your own investigation, wisdom won’t arise in you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1986 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1101,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1177,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "d8846bc8426086a227299e9cf5e6a747"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 1, sentence number 6 on page 77"^^xsd:string ;
    neo:text "You need to learn to the point where you personally understand why you need to act in certain ways."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1987 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_874,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_875 ;
    neo:id "2b80f5cb5331c3162ab6a827e483a2b4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 2, sentence number 1 on page 77"^^xsd:string ;
    neo:text "There are two aspects of sīla or moral conduct: the doing of what should be done, and the not doing of what should not be done."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_199 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_200,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71 ;
    neo:id "8cdcf948e061170106efa41ecb61a7af"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 1 on page xiii"^^xsd:string ;
    neo:text "When we welcome the Dhamma into our daily lives we reap the benefits of the Buddha’s teachings."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1990 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1725,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1991,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1992,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71 ;
    neo:id "2dbdfb27ea31b0cd5027da2a3de4de62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 2, sentence number 2 on page 77"^^xsd:string ;
    neo:text "If you know the Pātimokkha (the Buddhist monastic code), the Buddha says to do good, avoid evil, and purify the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1993 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1994,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_303 ;
    neo:id "d0b1a91557778085e21b9fb196c1ab03"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 2, sentence number 3 on page 77"^^xsd:string ;
    neo:text "The Buddha says to do what should be done."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1995 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1996,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1997 ;
    neo:id "cf71b2383feb2c4a8d7d5380ae9d79a4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 2, sentence number 4 on page 77"^^xsd:string ;
    neo:text "The Five and Eight Precepts that we always talk about is abstaining from that which should not be done."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1999 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2000,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2001 ;
    neo:id "fb6f77b0a75d243a9738520ee4fa5527"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 2, sentence number 5 on page 77"^^xsd:string ;
    neo:text "Remember that there is also the other side: do as much as possible of what should be done."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3 ;
    neo:id "29bc35f81c06c720928baa1b1c851d7a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 2, sentence number 1 on page iii"^^xsd:string ;
    neo:text "Transcribed by Tony Reardon"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_20 a neo:Document ;
    neo:id "027b042bf025ee20485d3620b4615448"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 8, sentence number 1 on page vi"^^xsd:string ;
    neo:text "and the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2002 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2003,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_310 ;
    neo:id "a7bafc54424b1faa7bee426017918cba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 3, sentence number 1 on page 77"^^xsd:string ;
    neo:text "If we are being mindful all the time and wisdom is growing, we begin to understand what should and shouldn’t be done, because we will observe the effects of our actions and learn from that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2004 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2005,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2006,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2007,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "9a8498bb32db1d6037343277ebd2c8b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 3, sentence number 2 on page 77"^^xsd:string ;
    neo:text "In my experience, my behavior changed through continuous practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2008 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "1daa2a95bcb0553ef8d39ae50f6adea7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 4, sentence number 2 on page 79"^^xsd:string ;
    neo:text "I became very calm and spoke very little or not at all if it was not important."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2009 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "7fc1bb266a28ad804758ddc26d849d76"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 4, sentence number 3 on page 79"^^xsd:string ;
    neo:text "I was serious when I did talk."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2010 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "5eadb107bb2a907cff3b1b3af8f76e12"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 4, sentence number 4 on page 79"^^xsd:string ;
    neo:text "Being very careful in speech became important in my practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2011 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2012,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2013,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2015,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2016,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_759,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_761 ;
    neo:id "9f6404470d1dc466479c2117cb9e6917"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 4, sentence number 5 on page 79"^^xsd:string ;
    neo:text "I practiced refraining from lying, slander, gossip, talking nonsense, speaking harshly, and idle chatter."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2017 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2018,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "b5523faff68b700865be2b961a7ab79a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DOING WHAT SHOULD BE DONE, paragraph number 4, sentence number 6 on page 79"^^xsd:string ;
    neo:text "And as a result, my meditation deepened."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2019 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "2248d33d0e24219a28133f33ef09cacb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 1, sentence number 1 on page 79"^^xsd:string ;
    neo:text "Every person acts largely out of their own past causes and conditions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_202 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_203,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "8b9fbcda71cb41743c4da2d63749a4c7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 2 on page xiii"^^xsd:string ;
    neo:text "Our deepest gratitude goes to Sayadaw for patiently lighting this path of awareness + wisdom, and teaching us the right attitude for meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2020 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2021,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2022,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2023 ;
    neo:id "a4e8c5af77eff8f82099c33be62c3afa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 1, sentence number 2 on page 79"^^xsd:string ;
    neo:text "People brought up in Asia have a certain cultural conditioning and people brought up in the Americas or Europe have their own kind of conditioning."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2026 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2027,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2028,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "168bcc89ce674120437b7275c8ccf052"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 1, sentence number 3 on page 79"^^xsd:string ;
    neo:text "Then there’s individual conditioning, parental influences, and each person’s experiences throughout life; there are so many combinations and permutations that everybody has a unique footprint."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2029 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2030,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2031 ;
    neo:id "28ad397690d8609d80eb0676b7ee235c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 2, sentence number 1 on page 79"^^xsd:string ;
    neo:text "‘Non-self’ is just that principle of cause and effect."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2032 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2033,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2034,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2035 ;
    neo:id "e2bc39b4d63fe291edf3bbeb3aac31e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 2, sentence number 2 on page 79"^^xsd:string ;
    neo:text "For example, somebody may have a very hot temper, and that person’s conditioning includes certain triggers that sets off their temper."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2036 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2037,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2038,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2039,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "6b2f9547cd1b08fb3f8b700e58d14cc7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 2, sentence number 3 on page 79"^^xsd:string ;
    neo:text "If you understand that a person’s past conditioning is what is causing them to lose their temper as opposed to believing that they personally have negative intentions towards you, then it becomes easier to see the process and forgive that person."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_204 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_205,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_206,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "e96ef7ff1545cee6b37952aac9eb27d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 3 on page xiii"^^xsd:string ;
    neo:text "May all living beings benefit from the dedication of those who have contributed to this process: Ma Thet (Moushumi Ghosh) for her tireless and dedicated retreat translations which are in this book, and for her careful telling of Sayadaw’s story in “A Note from the Teacher,” to all the folks who sent in transcriptions and those who did not shy away from our drafts in their roughest states."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2040 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1353,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "db4e769e32b61672ebab7565d1b2bcf8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 3, sentence number 2 on page 80"^^xsd:string ;
    neo:text "You recognize that because of conditions, the results arise, and it’s not the person who’s angry, but a set of conditions that has brought about this effect."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2041 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "15f8e02176f2d3a0262b2d33bc7de342"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 3, sentence number 1 on page 80"^^xsd:string ;
    neo:text "If you stay in the present moment, moment to moment to moment, you see the principles unfold."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2043 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "a8f25d3f8283407aa93390feb6c51d62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 3, sentence number 2 on page 80"^^xsd:string ;
    neo:text "If you are angry and you watch that anger many times, you will begin to notice how the anger cannot run away with you as long as you are aware."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2044 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2045,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "16451fda68d437263105be7c4a324ce4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 3, sentence number 3 on page 80"^^xsd:string ;
    neo:text "You begin to see how, with awareness + wisdom, the unwholesome mental states cannot take over the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2046 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2045,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "f6c1e25c9d7ea98e8323855d9f39adfd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 4, sentence number 1 on page 80"^^xsd:string ;
    neo:text "Without awareness + wisdom, the unwholesome mental states can gain momentum unbeknownst to you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2047 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2048,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2049,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2050,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "afd18d8ca9b48d1810623b172204f675"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 4, sentence number 2 on page 80"^^xsd:string ;
    neo:text "When there is knowing, you begin to notice how the habit of anger could arise in the absence of awareness or wisdom and how the process unfolds naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2051 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2052,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2053,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_783 ;
    neo:id "40885d64967a8468b56b33ee52721f9c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 4, sentence number 3 on page 80"^^xsd:string ;
    neo:text "It’s all about mental processes; it’s never about the story or external things."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2054 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2056,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "52c4098572fcfba2b1a427c11273da90"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 4, sentence number 4 on page 80"^^xsd:string ;
    neo:text "When you understand the benefit of something, the harm of the opposite becomes obvious."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2058 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2059,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "bea67584a42bece0c1133543ae906dad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 5, sentence number 1 on page 80"^^xsd:string ;
    neo:text "I say this a lot: when yogis successfully observe something unwholesome and it passes, and they are happy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2060 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2061 ;
    neo:id "ed1dc24e63f5992ad1a86858721c44f3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 5, sentence number 2 on page 80"^^xsd:string ;
    neo:text "But that’s not the end."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2062 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_352 ;
    neo:id "4a9f1524e69d430cac700aee4cc89834"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 5, sentence number 3 on page 80"^^xsd:string ;
    neo:text "It is important to reflect at that point what would have happened if we had not been mindful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2063 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2064 ;
    neo:id "46d55f7b91cffe02fa4864b80d46ffac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 5, sentence number 4 on page 80"^^xsd:string ;
    neo:text "If we are just happy in la la land we don’t get to learn what it is like to be unmindful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2065 a neo:__Entity__ ;
    neo:RELATED_TO ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "Unmindfulness"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2066 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2067,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "c0a4c35d826571f3390bdc40ce8cd9b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 6, sentence number 1 on page 81"^^xsd:string ;
    neo:text "I usually tell yogis to stay away from the storyline, but it can help to see the idea that the story carries."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2068 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2069,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_783 ;
    neo:id "3d3bce9a6c93489c13418955f31071ed"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 6, sentence number 2 on page 81"^^xsd:string ;
    neo:text "The story might be, “Anne was making a noise and I felt really angry with her” while the idea behind that might be “people shouldn’t make noise.” This idea influences the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_207 a neo:__Entity__ ;
    neo:CONTRIBUTOR ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_153 ;
    neo:id "Folks"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2070 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "185d24d5a33fa11e05c62ee42dbfa7a2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CAUSES AND CONDITIONS, paragraph number 6, sentence number 3 on page 81"^^xsd:string ;
    neo:text "But when it is seen clearly for what it is, that this idea is not helpful, then it can be let go."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2071 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_852 ;
    neo:id "ce6e81bee229ac8d4bc520c4c4923df9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 1 on page 81"^^xsd:string ;
    neo:text "We get into a lot of trouble when there is attachment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2072 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2073,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "9d4c8ce8a7121e47557e061a3df20fde"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 2 on page 81"^^xsd:string ;
    neo:text "When you or the other person is clinging to each other or to the relationship, double trouble!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2074 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2076,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2077 ;
    neo:id "fe8af1cac113f5c1492203331fe8db55"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 3 on page 81"^^xsd:string ;
    neo:text "For example, thinking that you will be okay only if your children are okay implies that the mind is reliant on somebody else for its mood and that takes away the mind’s freedom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2078 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170 ;
    neo:id "f784e39107113c6d21c48570cb992f01"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 4 on page 81"^^xsd:string ;
    neo:text "This is a strong delusion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2079 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1843,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1844,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1845,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2080,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2081,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_640 ;
    neo:id "fc53ae24fd60dacac731bc2980f38ca8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 5 on page 81"^^xsd:string ;
    neo:text "With attachment come anger, anxiety, fear, and doubt but if there’s wisdom there can be loving-kindness, compassion, sympathetic joy, and equanimity."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2082 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_550,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "01bba974f9f10c84524ca77af2915ef9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 1, sentence number 6 on page 81"^^xsd:string ;
    neo:text "When the mind doesn’t believe that its suffering comes from other people, situation or places, then it is free."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2083 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1645,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2084,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2085 ;
    neo:id "3224cc5ddb82296909d25918cf5b2b9f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 2, sentence number 1 on page 81"^^xsd:string ;
    neo:text "An old couple was once asked how their relationship had lasted 50 years."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2086 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1715,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2087 ;
    neo:id "0fc11297209e9801dc6bd6fd03c189c2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 2, sentence number 2 on page 81"^^xsd:string ;
    neo:text "One of them replied that they made adjustments every time their communication broke down."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2089 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2090,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2091,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "773e0748910a366f54c6240fd7ed84c6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 2, sentence number 3 on page 81"^^xsd:string ;
    neo:text "It worked because that adjustment was not made with passion or defilement but with wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2092 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2093,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527 ;
    neo:id "3698f84e537760764f5192673d1623ad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 2 on page 82"^^xsd:string ;
    neo:text "We become strangers to each other in a family if we don’t talk to each other for long periods of time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2094 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "3e8087ef655362bc67764c1bccb12185"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 3 on page 82"^^xsd:string ;
    neo:text "It takes a lot of wisdom to know whether and when to speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2096 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2097,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2098,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "833797aa652a789282fc0779eeee060f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 4 on page 82"^^xsd:string ;
    neo:text "Consideration of time, place, and other factors are all a part of that moment and situation before we can decide whether it is appropriate to say something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2099 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2100,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2101,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "cb17b1f0bbe413b9996d1a5e4f6c99fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 5 on page 82"^^xsd:string ;
    neo:text "Sometimes it may be necessary to use humor to ease a situation; jokes and humor are very attractive to people."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_21 a neo:Document ;
    neo:id "00fc4f59da38b151545939b73bdd8bd9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 8, sentence number 2 on page vi"^^xsd:string ;
    neo:text "Then it becomes very interesting."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_210 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_211,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_212,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_213,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_214,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_215,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_216,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_217,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_218,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_219,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_220,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_221,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_222,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_223,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_224,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_225 ;
    neo:id "b6c6b9468f6448c40343dc9450a822ac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 10, sentence number 4 on page xiii"^^xsd:string ;
    neo:text "A big thank you to Sheng Bin Chiu, Sajama Sajama, TJ, Jim Noyes, Tom Aust, Ashin Sunanda, Steve Armstrong, Douglas McGill, Martin Kaminer, Nancy Zan, Margaret Smith, Heidi Che, Chan Lai Fun, Tiffany Taalman, and Jie Zeng for joining us at different stages with your patient and close reading of the material."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2102 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_517 ;
    neo:id "8ea2bc7ac08c7ce0e8f0c63ea19f5010"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 1 on page 82"^^xsd:string ;
    neo:text "So, love as much as you can but do not get attached."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2103 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2104,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_517,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769 ;
    neo:id "fc697ebc0c17f4aa672efd006f7d431a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 2 on page 82"^^xsd:string ;
    neo:text "What emotions come up when you think about someone you love?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2105 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_517 ;
    neo:id "85570d0aa582bfbec71cdeb828043079"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 3 on page 82"^^xsd:string ;
    neo:text "If there is only love, there is only happiness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2106 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_517 ;
    neo:id "da4915328e8025177fee0eeba434b5b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 4 on page 82"^^xsd:string ;
    neo:text "But love can get mixed up with a bit of attachment and that’s followed by fear."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2107 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2108 ;
    neo:id "e3bb9a350bf605f69f8be8c817fe0d45"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 5 on page 82"^^xsd:string ;
    neo:text "Loss is a natural part of life so there will be loss eventually."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2109 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "7c5537676200ceeec7ced4379ea20d84"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 6 on page 82"^^xsd:string ;
    neo:text "We need to understand it instead of fearing it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2110 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "1f83c3c0b59d769e40f4f5a63aaa8994"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: RELATING TO OTHERS WISELY, paragraph number 3, sentence number 7 on page 82"^^xsd:string ;
    neo:text "Every day we are losing time, losing the object, losing awareness, in every moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2111 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095 ;
    neo:id "c0bea8969630112ae0efeb8ae18c3195"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 1, sentence number 1 on page 82"^^xsd:string ;
    neo:text "We must be aware of ourselves every time we speak; come to know the many steps the mind goes through to speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2112 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1259,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "1a276db49509471c30e36ee9df1785a0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 1, sentence number 2 on page 82"^^xsd:string ;
    neo:text "If yogis make a habit of knowing themselves, then awareness when speaking will naturally become part of that habit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2113 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2114,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "328ac92b80196fee860194a76d5bc7d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 2, sentence number 1 on page 83"^^xsd:string ;
    neo:text "For some time I have had yogis not speak for two-thirds of a retreat and then, in the remaining one-third I explain how to be mindful while speaking and get the yogis to try mindful speech for a few days."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2115 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "0d412658a326cff793efa427d8520c41"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 2, sentence number 2 on page 83"^^xsd:string ;
    neo:text "Ideally yogis will have built up enough momentum and continue being mindful while speaking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2116 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "1c9a70d7d41d3ccb6fff3d9c9ccb7f18"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 2, sentence number 3 on page 83"^^xsd:string ;
    neo:text "But there is generally some inability or misunderstanding of how to remain aware when talking, and after a while I notice yogis speaking without being mindful and their momentum is gone."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2117 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2118,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "edfeda4d24cc28b022a719145cad889d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 2, sentence number 4 on page 83"^^xsd:string ;
    neo:text "I now limit the practice to just one session to give just a taste of what it might be like to speak mindfully."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2119 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2120,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0ac63a2a1ec904d8ea9f8f3883b6249b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 1 on page 83"^^xsd:string ;
    neo:text "I did not invent this idea of cultivating awareness while talking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2121 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1809,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2122,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "603490cea0927025b1f60e16986870d2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 2 on page 83"^^xsd:string ;
    neo:text "It is nothing extraordinary."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2123 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2124,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "ef9c937266357b25b2772d3208039035"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 3 on page 83"^^xsd:string ;
    neo:text "The Satipaṭṭhāna Sutta prescribes, “When silent, be silent with awareness and wisdom, when speaking, speak with awareness and wisdom,” but few people practice that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2125 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126 ;
    neo:id "731221dd55dc00ff5b504db6ba022ee7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 4 on page 83"^^xsd:string ;
    neo:text "It’s difficult to practice being mindful when speaking and seeing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2127 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1004,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2128 ;
    neo:id "1aedf9e4a9be30376b98fa11315a9e36"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 5 on page 83"^^xsd:string ;
    neo:text "The reasons are that we don’t practice being mindful when speaking, seeing, and looking and we also don’t have enough momentum in our awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2129 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "21ae300b45b0c19972528823ea865a6d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 6 on page 83"^^xsd:string ;
    neo:text "The whole point of my retreats is that I’m teaching you a skill that you’re supposed to bring into your life, and use in your life, so that mindfulness becomes a way of life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2130 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "885b6cf71b3710fdef85d9bb41dc5d87"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 3, sentence number 7 on page 83"^^xsd:string ;
    neo:text "That’s why I think it is useful to know and practice being mindful when you speak, especially when you are back home and at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2131 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2132 ;
    neo:id "6d7412cefe23b0cdfc40b0ab0b7e3282"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 4, sentence number 1 on page 85"^^xsd:string ;
    neo:text "Awareness of speech is not a strange or wonderful thing but something very simple: be mindful when you speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2133 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2134,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "ad529c83ba1756473b89fc0de92b0168"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 4, sentence number 2 on page 85"^^xsd:string ;
    neo:text "Some people ask, “What should I be aware of?” and I say, “Know that you are speaking, notice whatever part of the speaking experience is most obvious to you.” On retreat we practice observing body sensations and feelings, and observing the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2136 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "da767ced061d56e87c8968042c6b10a6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 4, sentence number 3 on page 85"^^xsd:string ;
    neo:text "All these things are still present when we speak and we want to know which of these catches our attention as we speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2137 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "f993657b6049f8ccb63f46504fe266f8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 4, sentence number 4 on page 85"^^xsd:string ;
    neo:text "The biggest trap when speaking is the strong desire to speak, wanting a lot to speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2138 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2139,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "bdf2bf5fbe8fbc26b035efafad9233f2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 4, sentence number 5 on page 85"^^xsd:string ;
    neo:text "A strong desire to speak is greed and mindfulness then goes out the window."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2141 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2033,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2132 ;
    neo:id "1437d6f2e4e8ff74ef047fb2ea97e360"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 5, sentence number 1 on page 85"^^xsd:string ;
    neo:text "We can’t practice awareness of speech alone; we have to speak to somebody."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2142 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2143,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471 ;
    neo:id "43dc5a96231e55148088fb81f5636e42"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 5, sentence number 2 on page 85"^^xsd:string ;
    neo:text "We have to pay attention to an outside object, not just our own mind and body, so we lose mindfulness because our attention goes fully outside and then we are no longer attentive internally or to our speech."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2144 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "6101d5593546c3d0d3a614b408a01433"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 5, sentence number 3 on page 85"^^xsd:string ;
    neo:text "We start to think about the other person and look at the other person and then all our attention and our awareness goes outwards and our attention is no longer also directed toward ourselves."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2145 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2146,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2147 ;
    neo:id "165273cf771af5ed567dd29185407b8a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 5, sentence number 4 on page 85"^^xsd:string ;
    neo:text "On the other hand, practicing talking meditation too formally and only in paying attention to one self will make the conversation stiff and unnatural."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2149 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2150,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "f2afc00b8d2f1aa65e3eb12629f9705a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 6, sentence number 1 on page 85"^^xsd:string ;
    neo:text "A yogi said in a Finnish retreat that while the retreat is quite good for mindfulness, there’s a lot of stuff happening and especially in speaking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2151 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2152,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "dd44ff367c83b09bda8ece278592fa2d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 6, sentence number 2 on page 85"^^xsd:string ;
    neo:text "When speaking with others, a yogi has to be responsive and quick and it feels like they’re doing two jobs at once."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2153 a neo:Document ;
    neo:id "84636f0a9460407624a4aa32e9393497"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 2 on page 86"^^xsd:string ;
    neo:text "Yes—it will be this way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2154 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "6b2e87775c0361a69651b34c7a22d6bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 3 on page 86"^^xsd:string ;
    neo:text "It’s all about skill, and skill is gained from continued practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2155 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2156 ;
    neo:id "0ffa12d850394adaebeadbd93ab50118"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 4 on page 86"^^xsd:string ;
    neo:text "We will be slow in any subject when we are not skillful as yet."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2157 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "d14a7917accd31db662254821b8c4e1a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 5 on page 86"^^xsd:string ;
    neo:text "As we do it over and over again, we gain momentum and the process becomes easier."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2158 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1167,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2160 ;
    neo:id "134c55e1cbb21d3bfabec13e31ff3368"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 6 on page 86"^^xsd:string ;
    neo:text "While there may be a lot of personal effort in the beginning, it eventually begins to roll on its own momentum, like riding a bike."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2161 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2162,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2163 ;
    neo:id "15869028aa10e7c7d927218b02f275f2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 7 on page 86"^^xsd:string ;
    neo:text "I liken it to martial arts, where at first you are practicing some simple moves and after a while (you don’t know when), you can just use them automatically."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2164 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "e1996bd278de2f35fe34cf48876218ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 8 on page 86"^^xsd:string ;
    neo:text "In this same way, the mind may now be a little slow and deliberate when it begins this practice, but as you keep doing it, you will find it slowly becoming automatic."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2165 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144 ;
    neo:id "5b3c5962f86b039c14097dd60feeac8f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 1 on page 86"^^xsd:string ;
    neo:text "You could try practicing in this way: Know what you want to say."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2166 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_851 ;
    neo:id "b582b6084d8f854af6446dc029a50fb9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 2 on page 86"^^xsd:string ;
    neo:text "Think about what you want to say before you say it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2167 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "2e0692edaf46faf60676f5343bc0474e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 3 on page 86"^^xsd:string ;
    neo:text "When you acknowledge to yourself first, to what you feel and think before you speak, you are giving yourself time to know yourself before you speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2170 a neo:Document ;
    neo:id "6cf52b55ad29fadb1cf08aac00223207"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 4 on page 86"^^xsd:string ;
    neo:text "Try this over and over again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2171 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2172,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "3b1b22e1b6ea068cda33f253be9740c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 5 on page 86"^^xsd:string ;
    neo:text "You can be aware of your experience as you are listening to the other person and recognize that you are listening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2173 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2174,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "2d70f701202fdcd4c39bd3cfb8f9a307"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 7, sentence number 6 on page 86"^^xsd:string ;
    neo:text "You are listening and knowing and are aware that you are listening and they are listening and then you are aware that the act of listening is happening, that speech is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2175 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2176,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "5d6db91f9a959400e7bacf183a49b803"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 1 on page 87"^^xsd:string ;
    neo:text "You might have to practice this quite actively; it will be difficult at first but only because you haven’t had enough practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2177 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_410,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "c42bde5509134b295c5d703402edf462"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 2 on page 87"^^xsd:string ;
    neo:text "Every new thing you learn is difficult when it is new because you don’t have enough practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2179 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "8121566ebf3ac3cc5092b73b2255e761"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 3 on page 87"^^xsd:string ;
    neo:text "When your overall mindfulness becomes more natural and continuous and has some momentum through practice and you know the mind and recognize it at work, it becomes easier to notice when you are talking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2180 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1004,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2181,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_841 ;
    neo:id "b8f62c3015e002e4caf713ec09f68670"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 4 on page 87"^^xsd:string ;
    neo:text "You will notice when the mind is thinking, when it is listening, when it is hearing, looking, and so on."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2182 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "3c88cca3ab6c228079373f7901282f17"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 5 on page 87"^^xsd:string ;
    neo:text "You will need to accept that at first you will lose mindfulness quite a lot."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2183 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2184 ;
    neo:id "6745137204bafe0ad03550e52ac46bc8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 8, sentence number 6 on page 87"^^xsd:string ;
    neo:text "Just don’t give up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2185 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2186,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2187,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "88504f3e28c6b96dcc5edd279338019f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 9, sentence number 1 on page 87"^^xsd:string ;
    neo:text "Before I learned how to practice in social situations, I would spend as much time as I could by myself and did concentration practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2188 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2186,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2189,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_662 ;
    neo:id "61c12fda6d79423dc7ea569b719c4f5b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 9, sentence number 2 on page 87"^^xsd:string ;
    neo:text "The mental stability was there but I couldn’t find peace because I was resistant to social situations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2191 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "3219e971565c665cc06a61efa632dc59"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 9, sentence number 3 on page 87"^^xsd:string ;
    neo:text "I wasn’t skillful but tried over and over again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2192 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0cbb3cc73e99bce95b45d7aef104107e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 9, sentence number 4 on page 87"^^xsd:string ;
    neo:text "As I learned to practice with people around, slowly over a long time, the mind’s habit changed; my awareness increased and slowly became automatic."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2193 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2186,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2190,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2194,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "fc5f36f776feacc95394f98932de2fb9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 9, sentence number 5 on page 87"^^xsd:string ;
    neo:text "When I saw that my resistance was because of conditioning, I actively set out to practice in social situations to overcome the resistance."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2195 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2013,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2196,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_759,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_760 ;
    neo:id "8f47655b46ff9eda9c037716cb41348f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 10, sentence number 1 on page 87"^^xsd:string ;
    neo:text "At one point, I decided to practice right speech, meaning no lying, no harsh speech, no slander, and no idle talk."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2197 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2198,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_464 ;
    neo:id "552e116c898dee6f054134598529aa2c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 10, sentence number 2 on page 87"^^xsd:string ;
    neo:text "Taking on this task really helped me in talking meditation because I had to check if I was doing any of the four wrong speeches."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2199 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2200,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "e45c7120ffce80c8cda853db954edc4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 2 on page 88"^^xsd:string ;
    neo:text "It reduced the amount of talking tremendously and my practice just shot up because we speak so often and I had to be so mindful all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_22 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_23,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_24 ;
    neo:id "20fb1764f42c645a1f5457a7d810f82c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 9, sentence number 1 on page vi"^^xsd:string ;
    neo:text "Use your know-how and wit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2201 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_962 ;
    neo:id "7a3f36acd075a634338b0a15bb09773b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 1 on page 88"^^xsd:string ;
    neo:text "I don’t remember how long I practiced actively like this but after some time of practicing I could maintain my peacefulness while I was with others."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2202 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "da136cb9505cd1954241902da3356505"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 2 on page 88"^^xsd:string ;
    neo:text "After I was more settled, I actively increased the practice and sought out places that disturbed me because I knew that’s where my weakness was."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2203 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_550 ;
    neo:id "8fc7c47166780cf99ada003f01954c58"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 3 on page 88"^^xsd:string ;
    neo:text "I would go to those places and keep trying there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2204 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2205,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "3183f00b3b3901d416a0740cc5c4edbb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 4 on page 88"^^xsd:string ;
    neo:text "Sometimes I would walk into a bar and meditate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2206 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "83301cce30a63039b6131c52c01af710"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 5 on page 88"^^xsd:string ;
    neo:text "I wanted to know how much this affected my mind and I became really interested."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2207 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2208,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582 ;
    neo:id "737b2b7a53fc3297352bb97e5c29cfae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 6 on page 88"^^xsd:string ;
    neo:text "Everyone around me was drunk and talking loudly but I was very peaceful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2209 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2210,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "374d720141e529bb8d755c7614ccd9b0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 11, sentence number 7 on page 88"^^xsd:string ;
    neo:text "This is how I developed confidence in my practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2211 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095 ;
    neo:id "6e28116721a5c8164766d420964efd7d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 12, sentence number 1 on page 88"^^xsd:string ;
    neo:text "It’s good to know, as information, that, it is possible to be mindful when you speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2212 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2213,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "514fce316d0c17e50c35da9b3ea763dc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 12, sentence number 2 on page 88"^^xsd:string ;
    neo:text "Then you are willing to try and put this aspect of mindfulness practice into your daily life, to challenge yourself to use this as part of your practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2214 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1662,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "4d4509ef3320f9633533997dde195f4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 13, sentence number 1 on page 88"^^xsd:string ;
    neo:text "It is very easy for defilements to come into our speech when we speak about ourselves, when the “I” becomes involved."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2215 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1259,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "0ba2ed3857ccd51e2ff45f99c5fab562"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 13, sentence number 2 on page 88"^^xsd:string ;
    neo:text "At home we usually speak without mindfulness and it is this habit, rather than mindfulness, that tends to come in when we speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2216 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "bfb2761757cbebf9b5c0f701758077a9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 14, sentence number 2 on page 89"^^xsd:string ;
    neo:text "When we are speaking, there are three things we can be mindful of: our mind, our speech and our body."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2217 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "727255b6c1ef05acbc336da7b1fc92b5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SPEAKING MINDFULLY, paragraph number 14, sentence number 3 on page 89"^^xsd:string ;
    neo:text "If we know our mind then we should definitely be able to filter that into knowing our speech and our body as well."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2218 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "10a7aa271c0b030bb5da9922db1ca661"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 1, sentence number 1 on page 89"^^xsd:string ;
    neo:text "You need to have your eyes open while meditating in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2219 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2220,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "812b0f2eae25f37b169559cf974e2ec1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 1, sentence number 2 on page 89"^^xsd:string ;
    neo:text "I learned how to be aware with my eyes open because fellow shopkeepers used to tease me when I meditated at work with my eyes closed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2222 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1944,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "f981e52c179a43a4f5d23f44caa5f7ea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 1, sentence number 3 on page 89"^^xsd:string ;
    neo:text "They thought I was sleeping on the job!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2223 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2224,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "04b0164aaaaccfcf5de52f3742dbc498"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 1, sentence number 4 on page 89"^^xsd:string ;
    neo:text "So I learned to pay attention to the internal landscape while keeping my eyes open."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2225 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "8096de980a49f4c8df755a05cd58f56e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 1, sentence number 5 on page 89"^^xsd:string ;
    neo:text "I eventually became more skillful at knowing the difference between seeing and looking, and the people I worked with didn’t even know that I was meditating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2226 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "cbbfa3c858add8a322ad03633b19cc7d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 2, sentence number 1 on page 89"^^xsd:string ;
    neo:text "If you actively know that you are aware and you are tuned into this awareness, then it’s hard to miss the seeing that’s happening in this moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2227 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2228,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2229 ;
    neo:id "5a692d9d1db11d82179dce8e310f7e5e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 2, sentence number 2 on page 89"^^xsd:string ;
    neo:text "One exercise you can do to help recognize this is to sit with your eyes open when you do sitting meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2230 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2224,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471 ;
    neo:id "467f1b303d4f1ad563636416aeb95904"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 2, sentence number 3 on page 89"^^xsd:string ;
    neo:text "Be naturally attuned to your internal landscape without bringing your attention to your eyes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2231 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471 ;
    neo:id "7ce706f6c9357edc415e6c62ec81d6b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 2, sentence number 4 on page 89"^^xsd:string ;
    neo:text "While this is happening, attention will naturally stray to the process of seeing and you will know that seeing is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2232 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1553,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2233 ;
    neo:id "83a10d8100f4f68d91e94af39a7c8ad7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 2, sentence number 5 on page 89"^^xsd:string ;
    neo:text "It can be those moments when the awareness naturally settles on seeing and it can hit us with clarity that seeing is happening right now and being known."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2234 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "fbfce8368909820767de1bee3c8892b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 3, sentence number 1 on page 91"^^xsd:string ;
    neo:text "When we do not understand the reality of seeing, then sometimes putting attention on our eyes gets us lost in the things we see instead of recognizing that seeing is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2235 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2236,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2237,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "98fb60c2e6c8f6d154f01b36f5556775"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 3, sentence number 2 on page 91"^^xsd:string ;
    neo:text "Sight or seeing is such an obvious object that we do not recognize it as such, simply because we don’t yet understand its mechanisms."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2238 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2239,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_783 ;
    neo:id "61d954240c8030cc16719c33896c96e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 1 on page 91"^^xsd:string ;
    neo:text "It’s a similar story with the act of looking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2240 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2241,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2242,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_866 ;
    neo:id "9b31fd68837f78186328a09898bd8d84"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 2 on page 91"^^xsd:string ;
    neo:text "We want to pay attention to the mind that is doing the work of focusing on seeing in order to pick up something visually or to use certain information in order to function."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2243 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1004,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2239,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "fcb80147d0f2e3381b8a466927a48ceb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 3 on page 91"^^xsd:string ;
    neo:text "You can’t physically know looking but you can know that the act of looking is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2244 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "1b030090bc5db4f00f9e286d442cb114"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 4 on page 91"^^xsd:string ;
    neo:text "It’s not something tangible but you can know that it is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2245 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "41b3385d809eac0a2e0aaded9ef0a5be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 5 on page 91"^^xsd:string ;
    neo:text "This is because reality is not solid."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2246 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1569,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2247,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "049bf886967e169765ec2d15288e80f4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 6 on page 91"^^xsd:string ;
    neo:text "We can understand reality or we can know reality but that’s all we can do."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2248 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "9508d5e24b3ac47e4558ce88f2189e75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 7 on page 91"^^xsd:string ;
    neo:text "If we are able to be aware of awareness, able to know the mind that is doing the work of being aware, then that awareness will pick up seeing or looking on its own."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2249 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2250,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "e1fbf77b45c02695a85a04e4709733e6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: SEEING IS DIFFERENT FROM LOOKING, paragraph number 4, sentence number 8 on page 91"^^xsd:string ;
    neo:text "These little skills are necessary, particularly in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2251 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1377 ;
    neo:id "4321013a250b2e06724235bfc669ae62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 1, sentence number 1 on page 91"^^xsd:string ;
    neo:text "All six sense doors are working while you’re eating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2252 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_818 ;
    neo:id "314ebe5f2777afb18052e42eee979499"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 1, sentence number 2 on page 91"^^xsd:string ;
    neo:text "Do you know everything that is happening?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2253 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1377,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1909,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2254 ;
    neo:id "1d1e2ea92f4805605a94f5cc3b9485c2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 1, sentence number 3 on page 91"^^xsd:string ;
    neo:text "If you forget yourself while you are eating, there will be a lot of eagerness there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2255 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_120,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1377,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2254 ;
    neo:id "76c67b6d3494bc1bb8f86f69bef4c1ac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 2 on page 92"^^xsd:string ;
    neo:text "Eating often has a kind of excitement and eagerness that accompanies it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2256 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1377,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2254 ;
    neo:id "468380cb88cadbeb4ed8aba6ef3f0dea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 3 on page 92"^^xsd:string ;
    neo:text "So before you start eating, check and see if there is eagerness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2257 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_120,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "92183681ccedb6e98785bc51a752a5ff"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 4 on page 92"^^xsd:string ;
    neo:text "When this excitement calms down, awareness will become steadier."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2258 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2259 ;
    neo:id "6b1707b7b8b1a900e4df0ee70cd626c5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 1 on page 92"^^xsd:string ;
    neo:text "Taste arises on the tongue."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2260 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1162,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "a1d74c792b28d0d18590728d7cd89888"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 2 on page 92"^^xsd:string ;
    neo:text "Where does the feeling that this food is good arise?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2261 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "e4a31693a4d49c01c6fdccd0f162a993"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 3 on page 92"^^xsd:string ;
    neo:text "In the mind!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2262 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "215ae64cf625fb8e69340ac5f975411b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 4 on page 92"^^xsd:string ;
    neo:text "They’re wholly separate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2263 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2264 ;
    neo:id "1d9d359c243f046ed0ee817c3b8eea62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 5 on page 92"^^xsd:string ;
    neo:text "Of course when we speak, we say, “This tastes good.” You’ll have one and the same durian but some people will like it while others can’t stand it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2265 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2266 ;
    neo:id "7943eea7ff353857695fb7921c078348"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 6 on page 92"^^xsd:string ;
    neo:text "Durians have this one taste but the idea that this durian is either “heavenly” or “disgusting” happens in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2267 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2268 ;
    neo:id "5955f102a85a177f561ea5ff9360889b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 7 on page 92"^^xsd:string ;
    neo:text "There was a Singaporean yogi who did not like durians and he watched the disliking mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_227 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_223,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_228 ;
    neo:id "658c7d3e7876cc1af89115622aa5dcb7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 11, sentence number 2 on page xiv"^^xsd:string ;
    neo:text "We have immense gratitude to folks globally who will be bringing this book to life with dana, layout, printing, and distribution including Chan Lai Fun and Hor Tuck Loon."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2270 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2264,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2271,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "fd789d20d97098715b2920a24e088ca5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 8 on page 92"^^xsd:string ;
    neo:text "When the disliking passed away, he then tried the durian."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2272 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "2ad276d2db1e04594a7e7ef75c9ab617"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 2, sentence number 9 on page 92"^^xsd:string ;
    neo:text "Now he likes durians!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2273 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "7879fd70bcebbb4bd5670aeff2019083"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 3, sentence number 1 on page 92"^^xsd:string ;
    neo:text "Taste has nothing to do with it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2274 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "a21ace076f7e5ba906c2c8158d8c15b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 3, sentence number 2 on page 92"^^xsd:string ;
    neo:text "Some of you probably were turned off by the smell of durians from the very beginning."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2275 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2264,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2276,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2277,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2278 ;
    neo:id "e525c0e5545a67b5dafad2eadcbb5192"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 3, sentence number 3 on page 92"^^xsd:string ;
    neo:text "The first whiff made such a negative impression on the mind that it labeled everything about the durian as negative, beginning with that initial association with the sense of smell."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2279 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "c2aec88aa5d49192c5aec8316f487e7f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 4, sentence number 1 on page 92"^^xsd:string ;
    neo:text "So, let’s relate this to your daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2280 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2281,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "ea02cf587b3eabb7fc7714b27a29206b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 4, sentence number 2 on page 92"^^xsd:string ;
    neo:text "When you are outside and you judge a certain kind of sound as distracting or bad, then perhaps you will go looking for a place where there are no sounds."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2284 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "1d62caddc21bbaf325721b57b563ea2b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 4, sentence number 3 on page 92"^^xsd:string ;
    neo:text "Can you find any place without sound?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2285 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282 ;
    neo:id "9f59e900cfd4cab4e05a598369470abd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 5, sentence number 2 on page 93"^^xsd:string ;
    neo:text "You have to understand the nature of sound."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2286 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1726,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2287,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2288 ;
    neo:id "16155f36ed478a4e2435d4b4bb326e16"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 5, sentence number 3 on page 93"^^xsd:string ;
    neo:text "You may consider a certain kind of sound noisy, distracting, or bad."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2289 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "f1803b00c2a416d338d2f655148224b8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 5, sentence number 4 on page 93"^^xsd:string ;
    neo:text "You may then go in search of a place without sounds."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_229 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_230,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_231 ;
    neo:id "ef731af0f824484c986eb1af2a1150f8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 11, sentence number 1 on page xiv"^^xsd:string ;
    neo:text "May the reader benefit from this project as much as we have collaborating on it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2291 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_577 ;
    neo:id "d9cd66054f316f132e0220e0d5e4c0ee"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THE PROCESS OF EATING, paragraph number 5, sentence number 5 on page 93"^^xsd:string ;
    neo:text "But can you find any place that is completely silent?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2292 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_655 ;
    neo:id "9c8f010c937fbf12285be448a2199a63"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 1, sentence number 1 on page 93"^^xsd:string ;
    neo:text "We need insight into the nature of the thinking mind because much of our suffering comes from thoughts."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2293 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2294 ;
    neo:id "4822087bcc84e4617d1def48d5e8d51b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 1, sentence number 2 on page 93"^^xsd:string ;
    neo:text "Have you ever thought, “What if this car gets into an accident?” How did that feel?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2295 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "c73eb3321631df0009038ca171b160ec"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 1, sentence number 3 on page 93"^^xsd:string ;
    neo:text "There is fear when “I” is involved but the mind is free when it knows a thought as just a thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2296 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "9bb4cbf011aadee2c7444f90e91abbe8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 2, sentence number 1 on page 93"^^xsd:string ;
    neo:text "Thinking in the right way is part of the practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2297 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "7ed5217999c6708659cf179d397e7423"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 2, sentence number 2 on page 93"^^xsd:string ;
    neo:text "Yogis are often afraid of thinking about meditation but in fact, to do any kind of work, we need to consider the situation, reflect, and think."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2300 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1707,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2301,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "1f1dcb3298cda1840c0269bcf5d00ed2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 2, sentence number 3 on page 93"^^xsd:string ;
    neo:text "We use wisdom to make fewer mistakes and we actively reflect on meditation work that’s productive and useful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2304 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "a2964cace052dc32550fed2ccff3155c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 2, sentence number 4 on page 93"^^xsd:string ;
    neo:text "This helps us recognize what’s helpful in our practice and strengthen that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2305 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_364,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "a67ee30ce233d157a9c56b7255fdba0b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 2, sentence number 5 on page 93"^^xsd:string ;
    neo:text "What we are observing, experiencing and thinking about how to practice, it all comes together."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2306 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2307,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2308 ;
    neo:id "6b4242e0b221f58690c0eaf4ed1db7d3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 3, sentence number 1 on page 93"^^xsd:string ;
    neo:text "The thinking mind in itself is neither wholesome nor unwholesome."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2309 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2310,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_717 ;
    neo:id "ead041fa1e0253f598b54f4da8acfc88"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 3, sentence number 2 on page 93"^^xsd:string ;
    neo:text "It is the motivation of defilement or wisdom behind the thinking mind that determines the quality of the thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2311 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2312 ;
    neo:id "0fad44bb98b9322374d03e10f0df9e7d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 3, sentence number 3 on page 93"^^xsd:string ;
    neo:text "We are concerned with this quality of mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2313 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2314,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "8fcc3e898b47f06d17492bc60cb35805"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 2 on page 94"^^xsd:string ;
    neo:text "Naturally arising thoughts are not a problem because they are just objects to be known."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2315 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1055,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "1995a9058902d81e414523b1684f7f1b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 3 on page 94"^^xsd:string ;
    neo:text "Of course, if there is a defilement, we ought to deal with it and not let it carry on unchecked."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2316 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "796bb4d69f148de15e002e34439417b0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 4 on page 94"^^xsd:string ;
    neo:text "If, on the other hand, it is wholesome, we can encourage it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2317 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591 ;
    neo:id "08e579684825f13b472186d013465d36"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 1 on page 94"^^xsd:string ;
    neo:text "It is best not to observe the thinking mind alone."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2318 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "831408e02cf5e6c235765e22e7e6f6bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 2 on page 94"^^xsd:string ;
    neo:text "Also watch the feelings that accompany this thinking so that you can know when it is becoming too much."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2319 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2320 ;
    neo:id "6e4fe17c924fb343ecf565aff147a306"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 3 on page 94"^^xsd:string ;
    neo:text "You can also gently allow the overthinking to continue and learn from it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_232 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_233,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_234,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_235,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_236 ;
    neo:id "5109be4dfa8cdc3a95945ef6c3fc5a0d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 11, sentence number 2 on page xiv"^^xsd:string ;
    neo:text "We assume responsibility for any errors in the transcription or editing and will do our best to rectify any issues for future editions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2321 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2320,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "f7da660bb9f472c4224829f19ffadd00"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 4, sentence number 4 on page 94"^^xsd:string ;
    neo:text "You will experience when it has become too much and having this experience will allow you to learn from overthinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2322 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1367,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2323 ;
    neo:id "bda96daf0095d10b4ab9d0f40435678a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 5, sentence number 1 on page 94"^^xsd:string ;
    neo:text "When there are strong wholesome qualities in the mind, it is difficult for the mind to suddenly change and become unwholesome; when there is a strong unwholesome train of thought going on, it’s difficult for it to suddenly switch and become wholesome."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2324 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "ac3524b16f6bf2a18e7d907622ac5af1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 5, sentence number 2 on page 94"^^xsd:string ;
    neo:text "I experimented for myself when my mind was wholesome."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2325 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2326,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "bf4094af699d33143bc7bf214a717635"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 5, sentence number 3 on page 94"^^xsd:string ;
    neo:text "I tried to intentionally think negative thoughts and realized that I could not."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2327 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2307,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "5fcdcd5ecb9b98d60e200ee648da88bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 6, sentence number 1 on page 94"^^xsd:string ;
    neo:text "Know that not all Dhamma-related thinking will necessarily be wholesome."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2328 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2329 ;
    neo:id "2bb613bece3bd311f1aae37237b2ff87"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 6, sentence number 2 on page 94"^^xsd:string ;
    neo:text "Sometimes a self-righteousness or attachment will be fueling it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2330 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "4b554630ead1bfaaa0df4718f981f85c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 6, sentence number 3 on page 94"^^xsd:string ;
    neo:text "When Dhamma-related thinking has to do with your actual practice, it’s probably helpful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2331 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "254e2584f1b7ea4e360fc06d70a6bc5f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 6, sentence number 4 on page 94"^^xsd:string ;
    neo:text "It’s helpful to think about the Dhamma and it’s okay if you don’t understand things straight away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2332 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2097,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_303 ;
    neo:id "4d64f377cb4b637e496456b1b1018762"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 2 on page 95"^^xsd:string ;
    neo:text "The Buddha recommended this kind of consideration because you never know when the mind might be in the right state and suddenly understand!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2334 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1759,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2335,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2336,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2337,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2338,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_866 ;
    neo:id "f85919bd8a6125a76da6fabb56f3e18f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 3 on page 95"^^xsd:string ;
    neo:text "Take in enough information to help you understand whether this information is beneficial, suitable, too much, too little, or balanced."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2339 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2299 ;
    neo:id "4795321ea8885ca16c4375b200be42f2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 1 on page 95"^^xsd:string ;
    neo:text "If you can see the wanting to think, know that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2340 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1467 ;
    neo:id "b906b12556912b62ece534d732f8d08c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 2 on page 95"^^xsd:string ;
    neo:text "Observe the intensity of the wanting."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2341 a neo:__Entity__ ;
    neo:ON ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1467 ;
    neo:id "Observe"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2342 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_364 ;
    neo:id "ab28f8574fc20a434f6a6daf5e8c65ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 3 on page 95"^^xsd:string ;
    neo:text "When, through skillful observation, the wanting diminishes, the thoughts will also diminish."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2344 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1197,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318 ;
    neo:id "263c7d3f9842ed0332185efcbc2637f3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: THINKING PROCESSES, paragraph number 7, sentence number 4 on page 95"^^xsd:string ;
    neo:text "If you can’t see the intentions to think just switch back and forth between thoughts and body as objects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2345 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_966,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "00020172bf528527f37eeb6597dd8a60"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 1 on page 95"^^xsd:string ;
    neo:text "Do you know that you are walking when you are walking around in daily life?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2346 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "57aefaf7e88475428acccecaee36a970"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 2 on page 95"^^xsd:string ;
    neo:text "You will often be lost in thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2347 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "2551d0f5e3ad80964d36cb0438d517f7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 3 on page 95"^^xsd:string ;
    neo:text "If you realize that this is happening, just know, “The mind is thinking.” What is important is what is happening in this moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2349 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2350,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "2e609fd5b523dca9babddaa1698bc1c3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 4 on page 95"^^xsd:string ;
    neo:text "You can do what you need to do when you arrive at your destination; there’s no need to think about it now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2351 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2352 ;
    neo:id "3c7b61f33016f7becedd5def9782c678"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 5 on page 95"^^xsd:string ;
    neo:text "This way the mind will also think less about the future."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2353 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2354 ;
    neo:id "cf7bd059031a4fbe03334190a20650d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 6 on page 95"^^xsd:string ;
    neo:text "You can expend a lot of mental energy speculating about the future without actually knowing what is going to happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2355 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2356,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2357,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "2b0ed1f557c4066eb9c827fcf44c69a4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 1, sentence number 7 on page 95"^^xsd:string ;
    neo:text "If you discover a very different outcome than what you had expected, you have spent a lot of energy on imagination!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2358 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2360 ;
    neo:id "249b8665ee8504783d9abecd58608dc7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 2, sentence number 1 on page 97"^^xsd:string ;
    neo:text "There was a businessman who went to the market to buy goods wholesale to resell later."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2362 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2360,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2363,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2364,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2365,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2366 ;
    neo:id "40e08bae2b9e1728c7b682073af6ba99"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 2, sentence number 2 on page 97"^^xsd:string ;
    neo:text "His journey to the market was filled with thoughts of various prices, how he would try to get there before everybody to get the first pick of goods."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2367 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "55b8a0e4c7f6cae6fb6b84ef8b3d5135"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 2, sentence number 3 on page 97"^^xsd:string ;
    neo:text "When he arrived he found there was nothing there for him!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2368 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "08da486d5683e97fa24902b050946b6e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 2, sentence number 4 on page 97"^^xsd:string ;
    neo:text "This businessman was a yogi and so he was aware of what his mind was doing this whole time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2369 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2370,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "655bef6e6cd4a243d3b416925890fa0a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: LOST IN THOUGHT, paragraph number 2, sentence number 5 on page 97"^^xsd:string ;
    neo:text "He realized how much time he had wasted speculating and determined that on future market trips he would relax and make decisions when he arrived."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_237 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_198,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_5 ;
    neo:id "a84a914da99ab32757eece10d6f8b1a3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 11, sentence number 3 on page xiv"^^xsd:string ;
    neo:text "Do email comments to info@wisdomstreams.org attention Laura."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2371 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1701,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2372,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_783,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "1e87137891b996cab778ab11a27631fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 1 on page 97"^^xsd:string ;
    neo:text "The concept or story is about the past or future but the knowing of that is in the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2373 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2374,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2375,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2376 ;
    neo:id "d0221ba15ac08afbcaa4b38cd61090d8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 2 on page 97"^^xsd:string ;
    neo:text "You need to consider how you might respond to a certain situation so that you arrive prepared, but this is not the same as worrying about a situation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2377 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2378,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2379,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "bf1b62511572147d8edda4cce9cdcbc9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 3 on page 97"^^xsd:string ;
    neo:text "If you are planning and knowing with wisdom that this is happening, that’s the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_238 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_46,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "dc314ed56aa39ca9a6fb177f4ee435cc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 12, sentence number 1 on page xiv"^^xsd:string ;
    neo:text "Finally, this book is by no means comprehensive, and not meant to replace Sayadaw’s personal guidance or your own further exploration of the Dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2380 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2379,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "de4bf77033d87c420f078a308bc126cb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 4 on page 97"^^xsd:string ;
    neo:text "Planning is necessary but could be done with either defilements or wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2381 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2379,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2382 ;
    neo:id "cce725803ff534f3e69bb7425b5b896c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 5 on page 97"^^xsd:string ;
    neo:text "Do you worry when you’re planning?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2383 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2384,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_640,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "8611129293d5a36f6aa9261bb7e0bfa8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 1, sentence number 6 on page 97"^^xsd:string ;
    neo:text "Some people plan with greed and others with anxiety but there is a way to plan and think in a relaxed way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2385 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2386,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "f9492b981fe3636078fdee8deb97966c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 2, sentence number 1 on page 97"^^xsd:string ;
    neo:text "Thinking about past events will also happen naturally from time to time and there’s nothing you can do about it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2387 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826 ;
    neo:id "4d47bbff0452781366fb0008b4faa5a6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 2, sentence number 2 on page 97"^^xsd:string ;
    neo:text "You can’t go back and change the situation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2388 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2372 ;
    neo:id "bdd8e9c01c520fbd52031343f964c4af"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 3, sentence number 2 on page 98"^^xsd:string ;
    neo:text "You can only revisit the past in thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2389 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1707,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_408 ;
    neo:id "629616b05d8b704b4fe9f08ec092d886"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 3, sentence number 3 on page 98"^^xsd:string ;
    neo:text "However, you can learn a lesson and not repeat the same mistakes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_239 a neo:Document ;
    neo:id "b790f6a82b862e8fe7fad2eec79b6f18"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 12, sentence number 2 on page xiv"^^xsd:string ;
    neo:text "Good luck in your endeavors!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2390 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2372,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2391,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "a066bcae8bef65403423a66a022f51c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: MEMORIES AND PLANNING, paragraph number 3, sentence number 4 on page 98"^^xsd:string ;
    neo:text "One yogi realized that the idea of “one second” of time was a concept and the past dropped away for him with this understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2392 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_960 ;
    neo:id "d54366cb464965b6744b371e0f4be07c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 1, sentence number 1 on page 98"^^xsd:string ;
    neo:text "Meditating at work is a skill and by skill, I mean lots of practice!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2393 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2394,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2395 ;
    neo:id "a9d4f06267850d45327724a3a5cad92a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 1, sentence number 2 on page 98"^^xsd:string ;
    neo:text "Initially, of course, when you pay attention to outside phenomena, you can’t concentrate on phenomena inside; when you put your mind inside you can’t really be aware of what is happening outside."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2396 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2281,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2395,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "a244395fdeb8679fe8bcc6520e48d1fe"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 1, sentence number 3 on page 98"^^xsd:string ;
    neo:text "Initially you might not be able to be aware of inside and outside when you are working but try to practice whenever you can to allow momentum to build."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2397 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_352 ;
    neo:id "5361e954697d772f0f6b5a806967da7b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 1, sentence number 4 on page 98"^^xsd:string ;
    neo:text "At some point awareness will kick in naturally while you’re doing something you’re really absorbed in."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2398 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "94198ed9baa63ccc3a94296b9621129e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 1, sentence number 5 on page 98"^^xsd:string ;
    neo:text "Getting to this level of awareness requires consistent practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2399 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1131 ;
    neo:id "d135cf6a2768695dc6cca44ca82ace38"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 2, sentence number 1 on page 98"^^xsd:string ;
    neo:text "When you need to be working, just do it fully."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_240 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_241,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48 ;
    neo:id "9f3b9e2a154a490d3742f2f1e13a0768"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 13, sentence number 1 on page xiv"^^xsd:string ;
    neo:text "This book is dedicated to all the beings in the universe."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2400 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1259,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "6b746cdbd638c767402d57bcfc0134a8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 2, sentence number 2 on page 98"^^xsd:string ;
    neo:text "Sometimes you will have more time to devote to your practice and do it freely and you will know something like, “Oh the mind is thinking about this so it can do that.” When you build the habit of noticing the mind at work then you will notice that awareness just starts popping up because it becomes a habit for the mind to recognize itself doing work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2401 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2402,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2404,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "68e02e2d7df87f39867a069696bd8a20"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 2, sentence number 3 on page 98"^^xsd:string ;
    neo:text "This will just come in naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2405 a neo:Document ;
    neo:id "0364bb0baea10fc10812c0b29396771c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 2, sentence number 4 on page 98"^^xsd:string ;
    neo:text "Allow this to happen."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2406 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_117,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "a8215cde511e862d7a5347f3e35f4d78"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 3, sentence number 1 on page 99"^^xsd:string ;
    neo:text "A yogi once asked a question about building up continuous practice, “How much should we do?” I said, “Do it 50-50.” The yogi was a psychiatrist so he thought a moment about my suggestion and asked, “How do you measure?” (Laughter.)"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2408 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2409,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "205281220b3dd8e99ba99a84bf0da933"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 3, sentence number 2 on page 99"^^xsd:string ;
    neo:text "I considered it and realized that it wasn’t as much about a division of 50-50 as much as allowing the mind to do its work naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2410 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1792,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "9fda444fb77741be186bdbd45ff52d4f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 3, sentence number 3 on page 99"^^xsd:string ;
    neo:text "If it is very practiced then the knowing happens naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2411 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "bc767e14caf2111ac99d4351b7e4e82f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 1 on page 99"^^xsd:string ;
    neo:text "When you have a continuous practice that reminds and remembers and knows the mind at work, then it gets to the point where it becomes effortless because the mind becomes so familiar and so intimate with itself."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2413 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "a84d1446583b959579e30e41b5608ba6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 2 on page 99"^^xsd:string ;
    neo:text "It is always with itself and it likes being with itself."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2414 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2412 ;
    neo:id "22da27ce8355fa52e621e63c1c23571c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 3 on page 99"^^xsd:string ;
    neo:text "That’s when it allows the mind to do anything because it doesn’t mind; it’s always with itself."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2415 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2416,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2417 ;
    neo:id "55c26836979b3a9c1072ee4fb55e826e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 4 on page 99"^^xsd:string ;
    neo:text "The operative word is continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2418 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296 ;
    neo:id "5801d3b8f1daffbbbd874138b0191d2f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 5 on page 99"^^xsd:string ;
    neo:text "Although it is difficult in the beginning, any amount of effort you put in brings momentum and that in turn makes it more effortless and continuous in the future."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2419 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71 ;
    neo:id "e2f22c3f1fe098b31e79b827f6b7202f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 6 on page 99"^^xsd:string ;
    neo:text "That’s why the Buddha said to practice continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_242 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_243,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3 ;
    neo:id "3e9515acb795c3948510cbd2fe326614"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Dear Reader, paragraph number 13, sentence number 2 on page xiv"^^xsd:string ;
    neo:text " With much mettā, Tony Reardon Laura Zan"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2420 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1187,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1620,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2421,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2422 ;
    neo:id "859a9a69393fa01938c0b00839b7e4bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 4, sentence number 7 on page 99"^^xsd:string ;
    neo:text "WHEN THE MIND SAYS, “IT’S NOT FAIR.” When something happens, the mind starts making judgments, sets up parameters, and develops ideas of what’s appropriate and boundaries of “you” and “me.” Once hooked on these ideas, the mind won’t like it when one of these ideas is violated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2423 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "23bf19f97ac0b0a21546798fa1f658ee"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 1 on page 100"^^xsd:string ;
    neo:text "We encounter this all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2424 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1235,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2425,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2426,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2427,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "d369ddc666362d5c9007a7239bd1d33c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 2 on page 100"^^xsd:string ;
    neo:text "In Western society, people wait in a queue or line because there is a belief that people should wait their turn for something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2428 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2429,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2430,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769 ;
    neo:id "05b934a0412af60213e42456249748b5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 3 on page 100"^^xsd:string ;
    neo:text "There is a dissonance when someone cuts that queue/line and thoughts that they should be in line start coming up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2431 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2432 ;
    neo:id "16072141980e07d91c44cf4181c94c8f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 4 on page 100"^^xsd:string ;
    neo:text "Or different thoughts of fairness might come up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2433 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1162,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1235 ;
    neo:id "812bbb7697ec04a8f490edcf47ec069a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 5 on page 100"^^xsd:string ;
    neo:text "There could be another kind of belief, “I wanted to get to my food and she has slowed that down by jumping the queue.” The mind has convinced itself of all these strands of thought!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2434 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2003,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2435,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769 ;
    neo:id "07c2e1722f3f200861cd2fdab5f9d20d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: AWARENESS AT WORK, paragraph number 5, sentence number 6 on page 100"^^xsd:string ;
    neo:text "At times like these, we should ask ourselves, “What internal belief is being thwarted here?” Right now, someone’s actions are frustrating these beliefs and the mind justifies this anger against the other person!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2436 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "f5447cf92831eb512b24bf35db17de2f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: STRINGING EACH OTHER ALONG, paragraph number 1, sentence number 1 on page 100"^^xsd:string ;
    neo:text "In daily life, we give each other compliments and thank each other for their compliments."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2438 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1649 ;
    neo:id "6b739ceb73c3099bde61b8af7ec8b707"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: STRINGING EACH OTHER ALONG, paragraph number 1, sentence number 2 on page 100"^^xsd:string ;
    neo:text "We string each other along by reinforcing the need to look good and feel good."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_244 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_245,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_247 ;
    neo:id "9a84b287ddacaad4ef75d7aa64cbdf08"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 1 on page xv"^^xsd:string ;
    neo:text "We work within the limits of language to describe the process of clear seeing that is at times difficult to pin down with words."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2441 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2442,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "2063d274ac66d48e5dde79f1dbf884ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: STRINGING EACH OTHER ALONG, paragraph number 1, sentence number 3 on page 100"^^xsd:string ;
    neo:text "If instead we had said, “You look really terrible,” the listener might get irritated because people want to feel good."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2443 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_139,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2444,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "7a91890236eb037c3497b84448f4e494"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: STRINGING EACH OTHER ALONG, paragraph number 1, sentence number 4 on page 100"^^xsd:string ;
    neo:text "We are often at the mercy of other people’s words, compliments or insults and are generally automatically affected."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2445 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1201,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "7eb494685afa08dece378230ead2d953"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: STRINGING EACH OTHER ALONG, paragraph number 2, sentence number 2 on page 101"^^xsd:string ;
    neo:text "When there is an understanding of how these thoughts work in the background, the wanting will disappear."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2446 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1219,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1360 ;
    neo:id "cf58d3ee27b726bba5127a7eab6fdda2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 1 on page 101"^^xsd:string ;
    neo:text "It is very important that there is a right attitude when we are working in the world."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2447 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2448,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2449,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "df9517ccdc1415efb4902c65cd174a0c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 2 on page 101"^^xsd:string ;
    neo:text "Sometimes we may feel like we are being taken advantage of or being taken for granted."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2450 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "da18d25ed2a5ea698652f919cba4ff07"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 3 on page 101"^^xsd:string ;
    neo:text "How different would it be if we thought these people were acting in a certain way because they didn’t know any better?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2451 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2452,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769 ;
    neo:id "ab3f75b34f0c334c811ce995e76e2f76"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 4 on page 101"^^xsd:string ;
    neo:text "If someone were bullying you, it would be really tough to handle!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2453 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2454,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "2a23bb815077107d4f3fcb6a5df882b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 5 on page 101"^^xsd:string ;
    neo:text "You may get tense, agitated or angry with the bully."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2455 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "fb755183681f2c8f349ddebc24912bc3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 6 on page 101"^^xsd:string ;
    neo:text "What if you thought that this person was only inadvertently doing these things because she didn’t know better?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2456 a neo:Document ;
    neo:id "0e65e4a4ef52fc340080e467b7a0bc82"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 7 on page 101"^^xsd:string ;
    neo:text "How would you feel then?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2457 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2247,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2458 ;
    neo:id "4e5f27b672ce0be308179c0793e6f8da"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 8 on page 101"^^xsd:string ;
    neo:text "You can better understand and forgive."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2459 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1726,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2460 ;
    neo:id "cb376fe5e706a025befb318092a281e4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 9 on page 101"^^xsd:string ;
    neo:text "SELF-JUDGMENTS “Bad” is just a label."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2461 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2462 ;
    neo:id "612d353813475c9c2c5ebcf1f67bce0f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 10 on page 101"^^xsd:string ;
    neo:text "Don’t label yourself that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2463 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "da13691a2004f7f9e24f1d1977054cbc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 11 on page 101"^^xsd:string ;
    neo:text "When the mind is wholesome, the person is good and when the mind is unwholesome, the person is bad."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2464 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "dbe8febf6e24bd056dcf12b98c46e0f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 12 on page 101"^^xsd:string ;
    neo:text "It’s only for that moment and that’s always changing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2465 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "4f93a6c2843b1f753420317c39992535"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 1, sentence number 13 on page 101"^^xsd:string ;
    neo:text "Continue to practice and take your time; the fact that you are practicing shows that your mind wants to become better and that means that the mind will become better."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2466 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2080 ;
    neo:id "c8508256c95397322c328201862f9a50"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 1 on page 103"^^xsd:string ;
    neo:text "When doubt is strong in the mind, do not pay attention to these thoughts."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2467 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471 ;
    neo:id "e5cfc095a665710f17a95499fbcd2f66"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 2 on page 103"^^xsd:string ;
    neo:text "Once we give attention to these kinds of thoughts, they suck us in and grow."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2468 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1065,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2469,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "b23abe0f172ddedaffbe92839bdf5ab7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 3 on page 103"^^xsd:string ;
    neo:text "We can anchor ourselves to feelings instead and not give any power to the conceptual thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2470 a neo:Document ;
    neo:id "9c11de1289dc5c73edd75570dc7c219f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 4 on page 103"^^xsd:string ;
    neo:text "Follow the same principle for other strong, unwholesome states."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2471 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "a6a0e96dccf93b58cd94e182ff434fd4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 5 on page 103"^^xsd:string ;
    neo:text "When we look at the feeling and discontinue looking at the thoughts, it will help the mind calm down."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2472 a neo:__Entity__ ;
    neo:DISCONTINUE ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1004 ;
    neo:id "Discontinue"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2473 a neo:__Entity__ ;
    neo:HELP ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "Calm_Down"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2474 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "e8620c13b00eab724abed6cf7857a805"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 2, sentence number 6 on page 103"^^xsd:string ;
    neo:text "Then we can look at these thoughts and feelings together when we feel we’re ready."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2475 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1711,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2476,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_52,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "383aebc5041c55d3cdcf78b398b64478"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 3, sentence number 1 on page 103"^^xsd:string ;
    neo:text "Everyone has his or her own path and there’s a natural course that needs to unfold for each person."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2477 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "1a438b3d4d191b5a3d1d563a8489c840"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 3, sentence number 2 on page 103"^^xsd:string ;
    neo:text "You can watch what’s happening in the mind and understand it, but you can’t force it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2478 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_335,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "41dbf35be6d21f33cfe33b7dbf5a18bb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 3, sentence number 3 on page 103"^^xsd:string ;
    neo:text "You may learn a technique at a retreat, but it is when you go home that you can apply that technique all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2479 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180 ;
    neo:id "9ed399e1a9b4b83aa0a6b9650c4c6661"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: FEELING LIKE BEING TAKEN ADVANTAGE OF, paragraph number 3, sentence number 4 on page 103"^^xsd:string ;
    neo:text "That’s when your life changes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_248 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_249,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_250 ;
    neo:id "980f72a646aca4aad1208013d55b0733"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 2 on page xv"^^xsd:string ;
    neo:text "As such, some rules of grammar may be bent a teeny bit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2480 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_567 ;
    neo:id "6eac5268e6e5ec1725fa8b9da3e16112"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 1 on page 103"^^xsd:string ;
    neo:text "How do you experience silence?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2481 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2482,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2483,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_566 ;
    neo:id "cc308ee2e41c2a6af99619a59c2956fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 2 on page 103"^^xsd:string ;
    neo:text "How do you experience the stillness of a garden or the woods?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2484 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "1e5cf4328d8f49951c4460a6f20b36b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 3 on page 103"^^xsd:string ;
    neo:text "I’ve asked different people this question."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2485 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_514,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "7e1286e8ded8b88551be3d7061a7b4fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 4 on page 103"^^xsd:string ;
    neo:text "Fear comes up for some people."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2486 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1973,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2487 ;
    neo:id "f0e29a89fed9a98556f9faff7a822882"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 5 on page 103"^^xsd:string ;
    neo:text "Youngsters tell me that they get bored when there’s nothing to occupy them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2488 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2489,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "c20119e12b48a9ac5ef343a0bb07a86e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 1, sentence number 6 on page 103"^^xsd:string ;
    neo:text "As you can see, good or bad depends on the person experiencing it, depending on their preconceived feelings of it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2490 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2491,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2492 ;
    neo:id "ff3a256883666fdd91130e4e0c4f3375"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 2, sentence number 1 on page 104"^^xsd:string ;
    neo:text "There are tons of these accumulations that you have from childhood and you really want to see these ideas that have built up over the years."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2493 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2494 ;
    neo:id "32d27777b4a37fc675f98cf57bb183c7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 2, sentence number 2 on page 104"^^xsd:string ;
    neo:text "If these little preconceptions are seen properly, then the mind will no longer be disturbed by what is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2495 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1398,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "6e43fb73ba2e88eb54ba468c0579be5a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: PRECONCEPTIONS, paragraph number 2, sentence number 3 on page 104"^^xsd:string ;
    neo:text "If you continue to meditate regularly, there ought to be fewer and fewer attachments."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2496 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2360,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507 ;
    neo:id "68eac8e39655f1fe9e7b2d3a248fd943"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 1 on page 104"^^xsd:string ;
    neo:text "The market where I had my shop was a very busy place."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2497 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2498,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2499 ;
    neo:id "d2bacf4fa8a725e71992e6b1a9204097"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 2 on page 104"^^xsd:string ;
    neo:text "Lots of shops were lined up side by side with narrow alleys between them."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_25 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_27 ;
    neo:id "2128d446ad9bd7298b82f81960f59bb5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 9, sentence number 2 on page vi"^^xsd:string ;
    neo:text "If meditation feels like a responsibility,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2500 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2361,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2501,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2502,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_507 ;
    neo:id "8df720a81c2dfc933329787eb96e03e1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 3 on page 104"^^xsd:string ;
    neo:text "Shopkeepers sent goods in and out with carriers who ran back and forth for the shopkeepers."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2503 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "8defff3e09c373a35e1f4d5904f03b72"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 4 on page 104"^^xsd:string ;
    neo:text "People would run quite blindly, not caring who was in the way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2504 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "790cd7c456e5556e03915210ddd02081"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 5 on page 104"^^xsd:string ;
    neo:text "I would get irritated whenever I had to get out of the way, which was quite often!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2505 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "a1f372abc91e721c45bf275458e7eee1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 6 on page 104"^^xsd:string ;
    neo:text "I knew that people would run into me if I didn’t move aside, but also became annoyed that I was the one who always had to be careful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2506 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2507,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2508 ;
    neo:id "7cff4f09f12503d4ff7d1b54a0c7cd8c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 1, sentence number 7 on page 104"^^xsd:string ;
    neo:text "This was a daily occurrence."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2509 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2510,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "42b9a3543912c8e7fffe0ebc30c46f2d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 2, sentence number 1 on page 104"^^xsd:string ;
    neo:text "When I began to practice continuously, I became mindful of my irritation with this market situation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_251 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_252,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_253,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_254,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_255 ;
    neo:id "50a63d87d051d7dfe1e64b5cbae028d3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 3 on page xv"^^xsd:string ;
    neo:text "A construct like “the mind is knowing” instead of “the mind knows” is used in instances where it seems more appropriate to describe something in process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2511 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2512,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2513,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "e27c3248c1ddeddebeaca4bd8753d0c3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 2, sentence number 2 on page 104"^^xsd:string ;
    neo:text "After being mindful of it regularly for a long time, I actually began to see it as a good practice to give space to these people to prevent accidents and I saw moving aside as a practice of generosity."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2515 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2516,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "45794e11a6f35f9180adbb4d363b543d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 2, sentence number 3 on page 104"^^xsd:string ;
    neo:text "As I practiced day after day and mindfulness arose, good actions also followed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2517 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2518 ;
    neo:id "6f9b51f0f74fca1e8d0f74cc59c8d394"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 3, sentence number 2 on page 105"^^xsd:string ;
    neo:text "The aversion that accompanied the critical mind decreased."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2519 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1619,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2520,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "8e2417e6e88095a6f5bf2bf487ea2c6d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GIVING COMES IN DIFFERENT WAYS, paragraph number 3, sentence number 3 on page 105"^^xsd:string ;
    neo:text "With aversion gone, I began to feel mettā for these people."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2521 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "c69e88e84232f154767b1be5bd931202"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 1, sentence number 1 on page 105"^^xsd:string ;
    neo:text "In daily life, where wisdom may be weak, you want initially to pay attention to awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2522 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "a5730887b0e0af3b5a82de8b4dab1b47"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 1, sentence number 2 on page 105"^^xsd:string ;
    neo:text "The mind can recognize the situation happening while awareness naturally collects data in the background."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2523 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1687,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_894 ;
    neo:id "0f66a1639db0bfe15d297ed0bf379e75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 1, sentence number 3 on page 105"^^xsd:string ;
    neo:text "As awareness picks up more data from the experience, and the picture becomes complete and wholesome minds grow stronger, you will eventually stop acting out of defilements."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2524 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2525,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2526,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "d729614a66e61d4479a2effa7e8b7755"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 2, sentence number 1 on page 105"^^xsd:string ;
    neo:text "Let’s say you are in a social situation and you have accidentally said something harsh because there was too much momentum to speak."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2527 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_705 ;
    neo:id "83d9e300848bc0d30b6885085ccedda0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 2, sentence number 2 on page 105"^^xsd:string ;
    neo:text "Let awareness continue to know in the background while you’re talking to others."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2528 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_894 ;
    neo:id "9a45605c86fdee503e1ce8b162e4f824"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 2 on page 106"^^xsd:string ;
    neo:text "At some point of seeing this whole process, awareness will have enough of a picture that wisdom can arise and resolve the situation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2529 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2530,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "cbe8b1f02339e48c15b756479bb932b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 3 on page 106"^^xsd:string ;
    neo:text "It is inevitable to make some wrong turns in daily life but you have to learn how to profit from these experiences."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2531 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "b9454589ed9b4c0f6594af88c3f62191"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 4 on page 106"^^xsd:string ;
    neo:text "Don’t allow defilements to run freely or your situation will deteriorate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2532 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170 ;
    neo:id "557be9ab6bb1ddac606d7d32ab9cbc87"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 1 on page 106"^^xsd:string ;
    neo:text "Imagine the alternate result if only delusion were operating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2533 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1826 ;
    neo:id "4b00d0ebe647ebf4e71d038c8bdc4e84"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 2 on page 106"^^xsd:string ;
    neo:text "Perhaps that situation would become exaggerated."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2534 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1567,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "ee509a04ac61148db3d85ec9f1ed6540"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 3 on page 106"^^xsd:string ;
    neo:text "We have to recognize things for what they are."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2535 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2536 ;
    neo:id "96417555e09b3b5b6f464f91329b80be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 4 on page 106"^^xsd:string ;
    neo:text "If the mind has a bad habit, we have to recognize that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2537 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "1fd4abf8455759e09eab4164e11bc763"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 5 on page 106"^^xsd:string ;
    neo:text "There is awareness so you’re keenly aware of what goes through your mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2538 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2366,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "954ace6d1750352f002e16bbb8c8f3e5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 6 on page 106"^^xsd:string ;
    neo:text "It takes time and everybody has different characteristics."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2539 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2540 ;
    neo:id "b9c3a6b4c0a24711bacaf5742d14bf9c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 7 on page 106"^^xsd:string ;
    neo:text "We all have faults and we need to look at what is in our mind and know it until the mind realizes that it doesn’t want to be that way anymore."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2541 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1607,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "9f81309228b20e94949be76e40c8db73"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 3, sentence number 8 on page 106"^^xsd:string ;
    neo:text "That realization will help you learn how to let go."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2542 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_200,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "d580c44c75ba6ddb080db7419efa1c45"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 4, sentence number 1 on page 106"^^xsd:string ;
    neo:text "We think that there are many people that we interact with in our daily lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2543 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890 ;
    neo:id "e13a156124891d1ef4b27c8e904d6e85"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 4, sentence number 2 on page 106"^^xsd:string ;
    neo:text "In fact, most of us will usually interact with a certain limited set of people over and over again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2544 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "884c260a3fd4373d8f6c991b9079344f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 4, sentence number 3 on page 106"^^xsd:string ;
    neo:text "How do we work with this?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2545 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2546,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_906 ;
    neo:id "fe7744585ca6e4a45d49a9c2f02827c7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 4, sentence number 4 on page 106"^^xsd:string ;
    neo:text "How can we strategize so that we become skillful?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2547 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "460c3bf8bf59ef7083e0c7e4f21134aa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 4, sentence number 5 on page 106"^^xsd:string ;
    neo:text "So long as there is the intention to have the Dhamma in our lives, then it will become easier."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2548 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2549 ;
    neo:id "b65a66a8d58fef33928662bd7ae381fb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 5, sentence number 1 on page 106"^^xsd:string ;
    neo:text "Having these experiences is very important and each experience gives you a life lesson."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2550 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2551 ;
    neo:id "c7f33ab57dda8d4c7218f33df0c71d06"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 5, sentence number 2 on page 106"^^xsd:string ;
    neo:text "It’s like playing videogames, which I like to talk about with children."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2552 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2553,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "40aca4d76dafb8c340c994aaf4a3f3bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 5, sentence number 3 on page 106"^^xsd:string ;
    neo:text "You work at it and reach the first level."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2554 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2555,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2556,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2557 ;
    neo:id "d3eaaf449d93d751a3c1d33a89245503"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 5, sentence number 4 on page 106"^^xsd:string ;
    neo:text "You graduate to higher and higher levels and eventually win the prize."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2558 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "a21431ce5abc3ba61ea97129b0738d27"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 6, sentence number 2 on page 107"^^xsd:string ;
    neo:text "You know how to do this because you’ve got that experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2559 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2560 ;
    neo:id "b2469f0298cfbe70cab2818f57b0d0a3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 6, sentence number 3 on page 107"^^xsd:string ;
    neo:text "You know how you can win this game at this level."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_256 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_115,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_257,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_258,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_259,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_260,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_261,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_262 ;
    neo:id "cb1fd82a44833e0f07f806fdb5ae577e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 4 on page xv"^^xsd:string ;
    neo:text "The following words are used interchangeably: watching, being aware, observing, being mindful, recognizing, noticing, and paying attention."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2561 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2549 ;
    neo:id "94703dbacd208b49a6671445fb290c34"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 6, sentence number 4 on page 107"^^xsd:string ;
    neo:text "Of course if you don’t know how to learn from your experiences, you won’t get anything no matter how many life lessons come your way!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2562 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2540 ;
    neo:id "0dd7c58526ecefbbe38ca0fccd891b6a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 6, sentence number 1 on page 107"^^xsd:string ;
    neo:text "We all have faults"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2563 a neo:Document ;
    neo:id "fa4bac913860b913ff122843e912cf08"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 7, sentence number 1 on page 107"^^xsd:string ;
    neo:text "and we need to look at what is in"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2564 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1569 ;
    neo:id "21cdd72ec8d18053a61841827a8c16bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 8, sentence number 1 on page 107"^^xsd:string ;
    neo:text "our mind and know it"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2565 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "525143564915323a11ecda2232f9e5d9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 9, sentence number 1 on page 107"^^xsd:string ;
    neo:text "until the mind realizes that it"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2566 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1205,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1432 ;
    neo:id "2c250b760c4f90555f63760bd90a0489"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 10, sentence number 1 on page 107"^^xsd:string ;
    neo:text "doesn’t want to be that way"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2567 a neo:Document ;
    neo:id "f6bacc8c02dde4af75a7fff3ca4ad555"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 11, sentence number 1 on page 107"^^xsd:string ;
    neo:text "anymore."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2568 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1607,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "1a5a3fa7c02d7d7f9c951c176c9e0821"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 12, sentence number 1 on page 107"^^xsd:string ;
    neo:text "That realization will help you"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2569 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1945,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2570 ;
    neo:id "8e530a485d6b2d04bd1609f2a9a5155f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 13, sentence number 1 on page 107"^^xsd:string ;
    neo:text "learn how to let go."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2571 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2572 ;
    neo:id "68f45c5c812b8c04871e11509b4e058d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 14, sentence number 1 on page 108"^^xsd:string ;
    neo:text "We are not patient with gentle awareness; we do not believe it will work or trust that"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2573 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "ba1e8770bae95d542c4fe9df5d413fb1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: DIFFERENT EXPERIENCES, DIFFERENT REACTIONS, paragraph number 15, sentence number 1 on page 108"^^xsd:string ;
    neo:text "it will grow into something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2574 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "92a9f13bd776693db6716e543faec298"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 1 on page 109"^^xsd:string ;
    neo:text "When I began to meditate in earnest at home, my awareness was inconsistent."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2575 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2576,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "98f23ab13ead4de5f03622207f0c8c7a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 2 on page 109"^^xsd:string ;
    neo:text "I over-compensated for this spotty awareness by putting in a lot more personal effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2577 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "9b30eaa25dfe09f8da2caef06e8100ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 3 on page 109"^^xsd:string ;
    neo:text "I wanted to be as mindful as possible but I was just too tired to do any more than that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2578 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "b1d80658af8aef5a3fc04b1ee7a77dfa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 4 on page 109"^^xsd:string ;
    neo:text "Even then, there was only so much I could do."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2579 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2580,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2581,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "7a051a7ae83e4a9cb5a8b6f367185aea"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 5 on page 109"^^xsd:string ;
    neo:text "After some time, I began to notice a lighter, general, but discontinuous awareness that, done day after day, formed a pattern of long-term practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2582 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2583,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2584,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2585 ;
    neo:id "683c65a1e8832870584b26afdf41cab0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 1, sentence number 6 on page 109"^^xsd:string ;
    neo:text "The momentum that came out of general awareness created these dots that came together to form a tsunami of awareness that could be seen clearly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2586 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2572 ;
    neo:id "c111559919bbfbf936a5685cbd5b1da7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 2, sentence number 1 on page 109"^^xsd:string ;
    neo:text "We do not believe gentle awareness will work or trust that it will grow into something so we are not patient with gentle awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2587 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2588,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2589,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2590 ;
    neo:id "7c376c8f0e3dc65a76e867692ea73358"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 2, sentence number 2 on page 109"^^xsd:string ;
    neo:text "Personal effort uses our own effort while waiting patiently for momentum to grow uses a natural process, a natural law, and natural energy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2591 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2592 ;
    neo:id "eb7b3ca5da7b7c593f20425cc6d24a43"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 2, sentence number 3 on page 109"^^xsd:string ;
    neo:text "Unfortunately, personal effort is short-lived and does not allow us to function in the day-to-day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2593 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_660,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_793 ;
    neo:id "8eba51ebcd4015452dd2edb53f9fbde5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 2, sentence number 4 on page 109"^^xsd:string ;
    neo:text "We then begin to doubt our ability to live our lives with awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2595 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "0300f96151ead25a743727375b51d032"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 1 on page 110"^^xsd:string ;
    neo:text "The idea of figuratively looking lightly out of the corner of your eye describes a kind of awareness that watches the workings of the mind in its receiving state."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2596 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2597,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "8dd69ec8fe865c10c2fd90614a0e7e18"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 2 on page 110"^^xsd:string ;
    neo:text "The mind becomes aware of all the objects that match this mental frequency."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2598 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2599,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2600,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "66085712c5c4925fea9d834a983581da"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 3 on page 110"^^xsd:string ;
    neo:text "Alternatively, when we turn and pay attention solely on the objects, and make too much effort to see these objects, it will feel like the objects have disappeared because the observer and observed are no longer at the same frequency."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2601 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2602,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_970 ;
    neo:id "23565f97e243a75a70c12ea270d6dbbd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 4 on page 110"^^xsd:string ;
    neo:text "We can use an analogy with the optometrist here."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2603 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2602,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2604 ;
    neo:id "6e9ce1b48cef8cf10235a263c301fad8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 5 on page 110"^^xsd:string ;
    neo:text "When you go to the optometrist, they might have you try out different power lenses to determine what would work for you."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2605 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1768,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2606 ;
    neo:id "3be32ca5c399df42bbb56d922065b58d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 6 on page 110"^^xsd:string ;
    neo:text "When the power is right for you, then you see the letters clearly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2607 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1768,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2602,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2608 ;
    neo:id "1fc896b75d60db1ab6fe07bcdc6f861c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 7 on page 110"^^xsd:string ;
    neo:text "When the optometrist tries out a power that is too low or high, the letters on the chart become blurry."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2609 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2600,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "6b4e3ddbd7920d393320a390082c1f03"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 8 on page 110"^^xsd:string ;
    neo:text "It’s the same deal with the mind that is at the right frequency with objects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2610 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1353,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2159 ;
    neo:id "ab19c7669ae806e1e65212bf9d5d9519"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 3, sentence number 9 on page 110"^^xsd:string ;
    neo:text "While you may assume that putting in more personal effort will yield better results, you may still not be able to see clearly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2611 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1567,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2612 ;
    neo:id "88979d8696bbf473cc4b9fed2054da98"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 4, sentence number 1 on page 110"^^xsd:string ;
    neo:text "A light, general awareness allows us to continue functioning, to do the activities we need to do while a light recognition of what is happening works steadily in the background."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2613 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "e1a7f10be685226e539d4bf298dce362"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 4, sentence number 2 on page 110"^^xsd:string ;
    neo:text "This very gentle awareness, while not continuous in the beginning, will eventually gain momentum."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2614 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2615 ;
    neo:id "95e29ee51f564fea9151fd690b667238"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 4, sentence number 3 on page 110"^^xsd:string ;
    neo:text "When it becomes a natural, continuous awareness, it will really feel like you’re aware and you’ll feel like you’re living this awareness in everything that you’re doing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2617 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2618,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2619,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "5660a905bcfe4f891362c15667198b31"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Lighter Approach, paragraph number 5, sentence number 2 on page 111"^^xsd:string ;
    neo:text "For me, it was at this point that I really understood the true nature of vipassanā meditation and began to believe that it is possible to become enlightened while living life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2620 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2621,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "47c2fb053b7f62b1b421fa3190a81dc6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Meditators often forget to use their natural wisdom when they meditate at home because they haven’t practiced using it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2622 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296 ;
    neo:id "bd8445c380012a5a84af4a5ac7e22e62"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 2 on page 111"^^xsd:string ;
    neo:text "Investigate and use your wisdom to check in on whether awareness is present and how much effort is being used instead of blindly putting in more effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2624 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2625,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2626 ;
    neo:id "a4816def7058256afce1759f55284f67"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 3 on page 111"^^xsd:string ;
    neo:text "Here are some considerations: Can you see your level of effort?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2627 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1046,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121 ;
    neo:id "faa4ff2327c46043ed79552875cd942e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 4 on page 111"^^xsd:string ;
    neo:text "Is there stability of mind?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2628 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "20b21f700654731691749a5535d5fbba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 5 on page 111"^^xsd:string ;
    neo:text "Do you know what that experience is like?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2629 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2210,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_314 ;
    neo:id "a7d1b0c8085d0b9fa5accdeeacb3b403"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 6 on page 111"^^xsd:string ;
    neo:text "Do you know your level of confidence or faith?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_263 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "5cf3a2669c34e2ce83fbec4d5cb9d0ca"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 5 on page xv"^^xsd:string ;
    neo:text "You may also see the word “yogi” used often, which is Sayadaw’s reference to a meditator."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2630 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "4a4515ab4436c3c0015aa74f839a59ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 7 on page 111"^^xsd:string ;
    neo:text "Is wisdom at work?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2631 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63 ;
    neo:id "0505cc04a3f3dec7d7192998192782be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 8 on page 111"^^xsd:string ;
    neo:text "Meditators can normally recognize when there is awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2632 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63 ;
    neo:id "07caee503ec25021b10b96cfb0814949"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 1, sentence number 9 on page 111"^^xsd:string ;
    neo:text "However, fewer meditators can recognize wisdom at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2633 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "fe10f243c88f9e046b7b573936893e53"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 2, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Wisdom is one word but it operates in so many ways."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2634 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1566,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2635,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "fa20a9d64689565832f98d3ac8068048"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 1 on page 111"^^xsd:string ;
    neo:text "Sometimes we miss the fact that wisdom is there and doing its work because we aren’t familiar with the ways of wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2636 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2637,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "06ae2dd1f95e3877c4297c64e9745bb9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 2 on page 111"^^xsd:string ;
    neo:text "We are not close to wisdom like we are close with close friends."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2638 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296 ;
    neo:id "eeb819f9d107d4b0bd62c96d1d8a968a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 3 on page 111"^^xsd:string ;
    neo:text "We’re more familiar with effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2639 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2640,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63 ;
    neo:id "c8e4fe7acf495636c99fef6c29de1338"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 4 on page 111"^^xsd:string ;
    neo:text "I see meditators trying hard to stay awake."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_264 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_71 ;
    neo:id "5d8b346425d2db0fc2580c5d9d3c7696"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 1, sentence number 6 on page xv"^^xsd:string ;
    neo:text "“Dhamma” with a big “D” refers to the teachings of the Buddha and the practice of meditation while “dhamma” with a little “d” refers to natural phenomena, natural law, or object."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2642 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1985,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401 ;
    neo:id "ff305b941960bdb761e11da5be20ca65"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 5 on page 111"^^xsd:string ;
    neo:text "When we are sleepy we should instead do a bit of investigation of this sleepiness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2643 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401 ;
    neo:id "6630a8a78caa37a55891b0d765dc1c7e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 3, sentence number 6 on page 111"^^xsd:string ;
    neo:text "Why is there sleepiness now?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2644 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_63 ;
    neo:id "5484cd06f53fd4048e3712264d47a7c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 4 on page 113"^^xsd:string ;
    neo:text "Instead meditators react negatively to sleepiness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2645 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2646,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_401,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "08bf2a9fc0cc6060ee0aa5bf795ddfa4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 5 on page 113"^^xsd:string ;
    neo:text "They will try different tactics to fix the sleepiness instead of seeing it as it is and learning more about it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2647 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2648,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_371 ;
    neo:id "0b85deff0239f5bb7693108f4f7c95f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 6 on page 113"^^xsd:string ;
    neo:text "I see this playing out in the dhamma hall during sitting sessions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2649 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2650,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2651,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_55 ;
    neo:id "3064e7daf65c59e5842d1e0c976bdac9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 7 on page 113"^^xsd:string ;
    neo:text "Some meditator starts falling asleep and the expression on his face shows that he is unhappy with himself as he picks himself up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2652 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2003,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2653 ;
    neo:id "3eb1ae197e8d7d22b3d1d2103abb8f34"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 8 on page 113"^^xsd:string ;
    neo:text "Blindly continuing these actions could just form bad habits."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2654 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2655 ;
    neo:id "4cd6f3934d4405e27d693419ff12fe7f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 1 on page 113"^^xsd:string ;
    neo:text "If sitting meditation makes you sleepy, sometimes being active can be good."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2656 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2657,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2658,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "6b616689c2ca6616f8c490c4e5510c3a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 2 on page 113"^^xsd:string ;
    neo:text "If you give the mind work to do, if it is being actively aware, then it will be alert and awake because it is doing something."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2659 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1407,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_481 ;
    neo:id "edcd84400282ff01dc50ee132afab262"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 5, sentence number 3 on page 113"^^xsd:string ;
    neo:text "You can also try sitting with your eyes open."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2660 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2661,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_867 ;
    neo:id "ca77e84620e12bd5d12fd79668d8c9c4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 6, sentence number 1 on page 113"^^xsd:string ;
    neo:text "We need to use wisdom the way we use our intelligence to solve problems, grow our businesses or think through what needs to be done at home and at work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2662 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_890,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "74e0d9d2d6d31f4a1cd3c5d52e038141"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 6, sentence number 2 on page 113"^^xsd:string ;
    neo:text "In daily life, we figure out how to do things, consult with the right people and strategize to make a profit."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2667 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "3a5ce4d17713a9c2a703d978e67ad947"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 6, sentence number 3 on page 113"^^xsd:string ;
    neo:text "We need to recognize the presence of wisdom and apply similar skills to meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2668 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_128,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_371 ;
    neo:id "293d739cbe10489ce12ded8f82cdb272"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 6, sentence number 4 on page 113"^^xsd:string ;
    neo:text "PROBLEM-SOLVING FOR YOURSELF I often circulate around the Dhamma Hall of the Shwe Oo Min Meditation Center in the afternoons."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2669 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2650,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2670 ;
    neo:id "5b997d49707d34d1522e0654bca232cf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 6, sentence number 5 on page 113"^^xsd:string ;
    neo:text "There was a nun who sat right up front and I would see that her face would turn pink, over and over again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_267 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "e319431f9f2ba4d616e1525c30fb4764"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 2, sentence number 1 on page xv"^^xsd:string ;
    neo:text "We have tried to maintain Sayadaw’s voice as much as possible throughout."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2671 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2672 ;
    neo:id "82ab3a647f08477e804aa6ae5be90053"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 2 on page 114"^^xsd:string ;
    neo:text "Later in the interview I asked her why she was blushing repeatedly while she sat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2674 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2675,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2676 ;
    neo:id "a7f9dfe63a75bf281ac6700e80a8c3f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 3 on page 114"^^xsd:string ;
    neo:text "She said that it was because of her body ’s tendency to pass a lot of wind and she felt bad for the person sitting behind her, every time!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2677 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159 ;
    neo:id "1f69a40fe606ba334844d41621c32de5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 4 on page 114"^^xsd:string ;
    neo:text "So she went red in the face when her body did it again."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2678 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2679,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "331fbfafb450283a1cd95e2925d6a9b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 5 on page 114"^^xsd:string ;
    neo:text "I asked, “So what are you doing sitting in the front of the hall?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_268 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_270,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_271,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "07cc30f4776ed76d6419646f1f052114"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 2, sentence number 2 on page xv"^^xsd:string ;
    neo:text "The combination word “awareness + wisdom,” first coined by Sayadaw, but used freely before the book Dhamma Everywhere came out, underscores the need for more than mere awareness in vipassanā (insight) meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2680 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2679,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2681 ;
    neo:id "f860be97169721782496e99d1cd76400"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 6 on page 114"^^xsd:string ;
    neo:text "If you are concerned and if this is what your body does, sit at the back of the hall!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2682 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1159,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2683,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2684,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2685,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "cd7342230a1508e7968e2929fa9bec26"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 7 on page 114"^^xsd:string ;
    neo:text "The door is wide open and you don ’t have to sit in front.” This meditator felt that she should have been sitting up front because she was a nun."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2686 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1662,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2687,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_852 ;
    neo:id "6b6fd03c965aacc2665cdb2d5e925965"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 8 on page 114"^^xsd:string ;
    neo:text "We cause ourselves trouble with our beliefs."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2688 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1451,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2689,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2690 ;
    neo:id "abe34412d55c826ecb3a0a139c334b5c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 9 on page 114"^^xsd:string ;
    neo:text "Suppressing such bodily needs can be uncomfortable and eventually make us sick."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2691 a neo:__Entity__ ;
    neo:AFFECTS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2689 ;
    neo:CAUSES ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2690 ;
    neo:LEADS_TO ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1451 ;
    neo:id "Suppressing Bodily Needs"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2692 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2693 ;
    neo:id "9f52d072be446ede6a93a58f19217c6a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 10 on page 114"^^xsd:string ;
    neo:text "Instead, we can find alternative solutions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2694 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2695 ;
    neo:id "e73923be8eb5ad4241c015a98ef08d50"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 1 on page 114"^^xsd:string ;
    neo:text "Set yourself free!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2696 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1187,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1825,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "92585e4b43b92926b16a0a5a0f7aacc2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: USING WISDOM, paragraph number 7, sentence number 2 on page 114"^^xsd:string ;
    neo:text "Do what you need to do to meditate instead of holding certain ideas in your heads without considering an appropriate solution."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2697 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527 ;
    neo:id "7cb79c5b9e5313624599c0aa455bbeb9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 1, sentence number 1 on page 114"^^xsd:string ;
    neo:text "Before I began meditating, I was the black sheep of the family."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2698 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_139,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "ca353a608edc961767d78e18dfe3a7db"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 1, sentence number 2 on page 114"^^xsd:string ;
    neo:text "My words carried little to no weight because I was known to lie about things."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2700 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_818 ;
    neo:id "0441cee55eb7d4baaa2300f898127aba"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 1, sentence number 3 on page 114"^^xsd:string ;
    neo:text "But about three years into my practice, I spoke less and less, as I watched my speech very carefully."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2701 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "7d1c41b666c974a8b135388445824ffd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 2 on page 115"^^xsd:string ;
    neo:text "By then, everyone would listen whenever I spoke because what I said was something of value."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2702 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "b08ffa367efe846280e84c5b5c4a9c79"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 3 on page 115"^^xsd:string ;
    neo:text "They listened because they knew that what I said had a lot of thought behind it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2703 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_527 ;
    neo:id "9d41628c571b810560a43ef03d12161d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 4 on page 115"^^xsd:string ;
    neo:text "Sometimes my family would be unnerved because they knew what I was saying to be the truth."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2704 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2705,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2706,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2707 ;
    neo:id "10248ab55c02b7fa55809c1f9bf589c0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 1 on page 115"^^xsd:string ;
    neo:text "My family had regular Sunday social get-togethers where we would eat and then talk."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2708 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2709,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2710,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2711 ;
    neo:id "b94d57e602034d018a31b2dc17777f9a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 2 on page 115"^^xsd:string ;
    neo:text "The conversations usually revolved around the latest cars, movie stars, and such."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2712 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "b18cc4ac17c5aadcc75ad2227e838533"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 3 on page 115"^^xsd:string ;
    neo:text "I had been meditating for some time by then and found this to be a waste of time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2713 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "d67422e6c08caa8fddae34579110cce6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 4 on page 115"^^xsd:string ;
    neo:text "I considered what could be done and slowly an idea formed in my mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2714 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "b3ffceb2fa2f7702c1fbb5f08314be39"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 5 on page 115"^^xsd:string ;
    neo:text "One day I suggested that we all meditate together."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2715 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_494,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_598 ;
    neo:id "f3d0c584403c214e7403dac19f5ee9ce"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 6 on page 115"^^xsd:string ;
    neo:text "All of us had meditation experience because my father used to bring us all to the monastery."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2716 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "a636bbd85eda93ab423507b36e8950cf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 7 on page 115"^^xsd:string ;
    neo:text "So they agreed to meditate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2717 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2718 ;
    neo:id "540d5219468568abf27726a9172331fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 2, sentence number 8 on page 115"^^xsd:string ;
    neo:text "We all sat for 15 minutes initially and then we would eat."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2719 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "419f546c5de028f9a760fb46363c78bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 3, sentence number 1 on page 115"^^xsd:string ;
    neo:text "After a while the idea crystallized, and we sat together in meditation every time we met."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2720 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2721,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "4c81706269853618ca6cc3de2e6e0691"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 3, sentence number 2 on page 115"^^xsd:string ;
    neo:text "After eating or during the meal I then suggested a discussion and we would talk about life, whether we were happy or unhappy."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2723 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1715,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "99b33b2c365afcc8f4adb3ef6ff81468"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 3, sentence number 3 on page 115"^^xsd:string ;
    neo:text "I would ask them one by one, “How do you feel about your life?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2724 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2725,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2726,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2727 ;
    neo:id "6e4bafd8c3c1d4bba45210ceb2bff885"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 3, sentence number 4 on page 115"^^xsd:string ;
    neo:text "Do you feel satisfied with your life?” The party would turn serious; one brother replied that he was not satisfied with his life and another replied that it was 50:50."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2729 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2730,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_582 ;
    neo:id "dce6425395a82919e1cea6aea63da588"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 3, sentence number 5 on page 115"^^xsd:string ;
    neo:text "Slowly my siblings began to share the details of their lives and feelings, and someone would cry after sharing and get some relief."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_273 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_274,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_275,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_58 ;
    neo:id "63662f12f8380912b2881594585472f7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 3, sentence number 2 on page xvi"^^xsd:string ;
    neo:text "Sayadaw always maintained that his teacher, the late Shwe Oo Min Sayadaw, referred to awareness with the assumption of inherent wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2732 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "82d74a5aa0698e3b4f80e07647844e00"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 4, sentence number 2 on page 116"^^xsd:string ;
    neo:text "It was not something they had considered."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2733 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_52,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "a997b137b68274dbb152e7b312d7aad5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 4, sentence number 3 on page 116"^^xsd:string ;
    neo:text "Everyone was just sort of going through life, time was passing by, and they’d never given any thought to how they were living their own lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2734 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180 ;
    neo:id "e2a2ab144d9967bb3d70706776d5855e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 4, sentence number 1 on page 116"^^xsd:string ;
    neo:text "From one week to the next, the questions would continue: If you’re not happy with your life, how do you make yourself happy?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2735 a neo:Document ;
    neo:id "1ca23ec67d8c7bae1f2dbb905b304e64"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 4, sentence number 2 on page 116"^^xsd:string ;
    neo:text "How do you deal with it?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2736 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2147,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "3a571ad0b093fe1e687576d6cd408a64"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 4, sentence number 3 on page 116"^^xsd:string ;
    neo:text "We brought the Dhamma into the conversation and it turned into Dhamma discussions."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2738 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_81 ;
    neo:id "5086dc1c79ba01de956f6c5882351c1a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: CREATING A DHAMMA COMMUNITY, paragraph number 5, sentence number 1 on page 116"^^xsd:string ;
    neo:text "With wisdom, you will also know how to help others."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2740 a neo:Document ;
    neo:id "08f5c5c1540304b5f6c0e553617764a6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 2, sentence number 1 on page 117"^^xsd:string ;
    neo:text "Everyone was just sort of"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2741 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180 ;
    neo:id "956a85f50b4904a58332e62675bee4fc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 3, sentence number 1 on page 117"^^xsd:string ;
    neo:text "going through life,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2742 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750 ;
    neo:id "ad015b4a96ca3a9a7321eb9efdeab32d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 4, sentence number 1 on page 117"^^xsd:string ;
    neo:text "time was passing by,"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2743 a neo:Document ;
    neo:id "04fc2b0956973538bc7dacec5d588151"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 5, sentence number 1 on page 117"^^xsd:string ;
    neo:text "and they’d never given"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2744 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2745 ;
    neo:id "567c4db4633cfc2b4c97f7e5c3d5597e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 6, sentence number 1 on page 117"^^xsd:string ;
    neo:text "any thought to how"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2746 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "0f3ac69e1ef8b020f2375d2e7e9760a4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 7, sentence number 1 on page 117"^^xsd:string ;
    neo:text "they were living their own lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2747 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "9a5f74101bd9d224a66e5c61744944f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 8, sentence number 1 on page 118"^^xsd:string ;
    neo:text "I want yogis to know that mindfulness is a"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2748 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2749,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2750 ;
    neo:id "a68248c51c0298e3f998ec4801993417"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 9, sentence number 1 on page 118"^^xsd:string ;
    neo:text "lifetime commitment, not part-time work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2751 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "546dd0099359e71e6be7f0281b4f26b6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 9, sentence number 2 on page 118"^^xsd:string ;
    neo:text "It is something that we really need to do all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2752 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2753 ;
    neo:id "ee67f984023dd9a808328bfaf356b1ef"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 10, sentence number 1 on page 118"^^xsd:string ;
    neo:text "Only when we see the nature of the mind"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2754 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "f5b5077efb45b97421e1674756c4d446"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: | | , paragraph number 11, sentence number 1 on page 118"^^xsd:string ;
    neo:text "will we understand the nature of dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2755 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2756,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_87 ;
    neo:id "2ffc4682d527b37c9499d0dce89e3373"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 1 on page 119"^^xsd:string ;
    neo:text "yogi in one of my retreats had some questions surrounding free will."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2757 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2194,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2758 ;
    neo:id "a2872defafd8b9476a0e2dcd441a3058"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 2 on page 119"^^xsd:string ;
    neo:text "When we talk about the process of conditioning, remember there’s a stream of minds in the conditioned process."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2759 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1133,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2760 ;
    neo:id "dda003dcbc8a83f136d9ebc56cf11a7c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 3 on page 119"^^xsd:string ;
    neo:text "The conditions in one mind bring the effect into the next mind and then, whatever the mind chooses to do in the next moment adds a little to that quality, or takes away from that quality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_276 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_277,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_278 ;
    neo:id "33f3c5eed9f739c43804b188855d4d79"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 3, sentence number 1 on page xvi"^^xsd:string ;
    neo:text "We have also used the singular “they” as a gender-neutral pronoun where possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2761 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2762 ;
    neo:id "aecd7949013e106cb3211b8fed8d605c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 4 on page 119"^^xsd:string ;
    neo:text "It then passes away and then this condition gives rise to the next mind and then it passes away and the effect is given to the next mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2764 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1177,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2762,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2765,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2766,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "9de9c76a133d389d711523d2f044e4bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 5 on page 119"^^xsd:string ;
    neo:text "Every mind begins with something, a condition, but that mind has a moment in the present to choose its contribution to the moment in terms of action or non-action, before that mind passes away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2767 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2372,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2758,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "d212490843abcb92c0d508797584bebc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 6 on page 119"^^xsd:string ;
    neo:text "“Everything is conditioned” just means that there is a stream that’s going on and the present moment has been conditioned by the past."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2768 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2756,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2765,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2769 ;
    neo:id "80c82b8c8ba42cd0814d0a85911a9fd3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 7 on page 119"^^xsd:string ;
    neo:text "At the same time, there is an element of choice in the present through wisdom because wisdom has free will."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2770 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "a3a9e055bfb7e6f7661a06821bc6dbe4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 1, sentence number 8 on page 119"^^xsd:string ;
    neo:text "As a result, that wisdom has the ability to choose to take whatever action or non-action it would like."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2771 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2772,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "ca416f874660c9b8707892c9b84adab2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 2, sentence number 2 on page 120"^^xsd:string ;
    neo:text "All things are conditioned but also you cannot imagine the vastness of kamma that you have accumulated that has the potential to flower in every moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2773 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1864,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2033,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2774 ;
    neo:id "708543bb6c5982c7cb9458fab66565ac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 2, sentence number 1 on page 120"^^xsd:string ;
    neo:text "If somebody has developed a lifetime habit of anger, the person will become angry with a little trigger."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2775 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "55f5b7ec96a694eb9351f3caeed50532"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 2, sentence number 2 on page 120"^^xsd:string ;
    neo:text "If the person has studied meditation, starts practicing and understands the benefits of meditation in the present moment, this person may gradually develop to the point where, with awareness + wisdom, the person may possibly be able to consciously decide what to do."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2776 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "115be324da3f08743acc5ad6360149a5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 2, sentence number 3 on page 120"^^xsd:string ;
    neo:text "This person could decide whether to continue to be angry, on the one hand, or try to be aware of the anger and grow in wisdom as a result, on the other."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2777 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2756,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2769 ;
    neo:id "56dc7ab8ae46dd29428e9eb573362a8d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 2, sentence number 4 on page 120"^^xsd:string ;
    neo:text "This choice constitutes free will."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2778 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2194,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "a18374ad839c8c6e28fdbff11730a2b7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 3, sentence number 1 on page 120"^^xsd:string ;
    neo:text "If only delusion were present, then the conditioning is set and this person would act entirely according to that conditioning."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2779 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "48314eae3954c0d8707a102e176c4585"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 3, sentence number 2 on page 120"^^xsd:string ;
    neo:text "When this kind of mind is not interested in wisdom, the mind is just a push-button system that is triggered by external forces."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2782 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2194,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2783 ;
    neo:id "4daff690d807318eb19c5b3d276d8343"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 3, sentence number 3 on page 120"^^xsd:string ;
    neo:text "Conditioning will dictate all outcomes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2784 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "c901ab832d01778d00f3e35a7d96d7f0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 4, sentence number 1 on page 120"^^xsd:string ;
    neo:text "Awareness allows the mind to choose."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2785 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769 ;
    neo:id "16a643ebe37e638e3c5cdab297e2d0d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 4, sentence number 2 on page 120"^^xsd:string ;
    neo:text "You might hear someone talk about something or you might come across a book that opens up a bit of wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2786 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "854287db73461fe01db958d3c5a20a75"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 4, sentence number 3 on page 120"^^xsd:string ;
    neo:text "You may borrow some wisdom from a book or person, consider it, and apply it to your life to bring about more wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2787 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2788 ;
    neo:id "a2bc34900babcb874aa863eeaefaf008"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 4, sentence number 4 on page 120"^^xsd:string ;
    neo:text "In this way, we can see how awareness + wisdom yields freedom of choice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2789 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "6d3a92e380edd7c7efbf2a360d5801bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 5, sentence number 1 on page 121"^^xsd:string ;
    neo:text "While I’ve said all this, I also don’t advise yogis to reflect too much on these matters."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_279 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_280,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_281,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_48 ;
    neo:id "812103b7af6e3e945ebbee3e695a41fe"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: On Language, paragraph number 4, sentence number 1 on page xvi"^^xsd:string ;
    neo:text "Pāḷi and English words have been used throughout the book although we have limited Pāḷi usage to make this daily life book as accessible as possible."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2791 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2792,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2793,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "1ac18d22dc99adc1d248c2bb3b5ffeb2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 5, sentence number 2 on page 121"^^xsd:string ;
    neo:text "It’s easy to get lost in conceptualization and abstraction on these topics, and thus to drift far from the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2794 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_289,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "1f7d07246aecc58031b23e55ca50fdd7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A       CAUSE AND EFFECT CHAIN , paragraph number 5, sentence number 3 on page 121"^^xsd:string ;
    neo:text "One of the conditions for wisdom to arise is to think deeply about the Dhamma, but it absolutely needs to be grounded in Right View and Right Thought."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2795 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_522,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_668 ;
    neo:id "836012b72e1efb0c6731c5d267d1fc18"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 1, sentence number 1 on page 121"^^xsd:string ;
    neo:text "When we are experiencing an emotion, we can both be with the emotion and understand the nature of the mind that is feeling aversion or craving for this emotion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2796 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1607,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_522 ;
    neo:id "385dc77901761455116fcbe704762652"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 1, sentence number 2 on page 121"^^xsd:string ;
    neo:text "This is a more powerful realization than just being relieved of the emotion for a moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2797 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387 ;
    neo:id "9f908418404cc02b9f271c87c4445e80"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 1, sentence number 3 on page 121"^^xsd:string ;
    neo:text "Understanding that this is just mind, and there’s no one here, but only conditions is an insight."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2798 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387 ;
    neo:id "8387efdc3500bee83d694fde11f4de70"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 2, sentence number 1 on page 121"^^xsd:string ;
    neo:text "Often, insight minds are momentary and this is normal."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2799 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2800,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "f8b921991db049ea12995f829c27bccc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 2, sentence number 2 on page 121"^^xsd:string ;
    neo:text "We allow these insights to arise repeatedly and gather all these little insights many, many times."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_28 a neo:Document ;
    neo:id "190169eab2c709986e75f7acfb10759c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 10, sentence number 1 on page vi"^^xsd:string ;
    neo:text "it’ll just be a burden."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2801 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387 ;
    neo:id "67441b1025a95f83fd3a680dfd6da070"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 2, sentence number 3 on page 121"^^xsd:string ;
    neo:text "The repeated arising of insight impresses that understanding into the mind and each mind that arises then passes along its qualities to the next mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2803 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "c7ba4b94bd7339dd841482124d6045b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 2, sentence number 4 on page 121"^^xsd:string ;
    neo:text "When insights arise repeatedly, the inheritance of that insight for each successive mind becomes stronger."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2804 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2805 ;
    neo:id "e17ca5bbc4daccf669c12c356947f913"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: BUILDING UP INSIGHTS, paragraph number 2, sentence number 5 on page 121"^^xsd:string ;
    neo:text "That’s how we get lasting insights."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2806 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_802 ;
    neo:id "e99bd28fdbf66c7a083e1e3fd3043152"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 1, sentence number 2 on page 123"^^xsd:string ;
    neo:text "If you are personally very involved in trying to do the practice, you will not be able to see what is going on naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2807 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2808,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2809 ;
    neo:id "029353f840d71f7f0a39e76d3551e16e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 1, sentence number 1 on page 123"^^xsd:string ;
    neo:text "We always need to remember the difference between personal exertion and the energy of the dhamma taking over."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2810 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246 ;
    neo:id "49083d9f5e9761ab882a2334cb9cacfc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 1, sentence number 3 on page 123"^^xsd:string ;
    neo:text "When you step back you are able to see that the process of awareness is already happening quite naturally."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2811 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_841 ;
    neo:id "eadca949184afaa86d5b973f694c2936"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 1, sentence number 4 on page 123"^^xsd:string ;
    neo:text "That’s why I sometimes ask yogis: Can you notice that you can hear even though you are not listening, that seeing is happening even though you are not trying to look at anything?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2812 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_471 ;
    neo:id "069eac77d1d2f4f60975f717010d6885"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 1, sentence number 5 on page 123"^^xsd:string ;
    neo:text "Can you notice that even though you are not paying attention, your mind already knows things?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2813 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2241,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_262,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2814,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_461,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "02557899341c74be43844b2fe9c4dd03"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 2, sentence number 1 on page 123"^^xsd:string ;
    neo:text "I would like yogis, especially for those who have been practicing for years, to get to the point where they realize that without focusing or paying attention, that knowing is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2815 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "a20248d2590c907a9eeeee0a33044230"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 2, sentence number 2 on page 123"^^xsd:string ;
    neo:text "After many years of meditating, their practice must have gained momentum and they need to step back in order to see that this is happening."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2816 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "17077d6f65b1f2428b57c74cde813144"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 2, sentence number 3 on page 123"^^xsd:string ;
    neo:text "At that point, you need to switch from doing to recognizing."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2817 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_114,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "2d536c471088f17bb9464c8b263b19b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 2, sentence number 4 on page 123"^^xsd:string ;
    neo:text "When the dhamma takes over, there is just a doing of what is necessary."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2818 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_942 ;
    neo:id "0924dfcbd0a5c07cc2fd251a73fc8cbb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 3, sentence number 1 on page 123"^^xsd:string ;
    neo:text "Of course it is not possible to just switch, to immediately change the paradigm."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2819 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2820,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_866 ;
    neo:id "54fffccac1771ae0d6fee9a35c7cd866"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 3, sentence number 2 on page 123"^^xsd:string ;
    neo:text "But it is good to have this information because this will enable you to sometimes switch into this new mode."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_282 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_85 ;
    neo:id "2da490dc6e8a475577a035bf015d156e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 1 on page 5"^^xsd:string ;
    neo:text "You may be finished with a formal retreat for now but remember that the dhamma is everything, so it is everywhere, all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2821 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2822,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2824,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "1194c4c4a9ab414f20f7cfd849122ef6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 3, sentence number 3 on page 123"^^xsd:string ;
    neo:text "This way you will slowly understand what is actually happening and this will enable you to let go of the old paradigm."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2825 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_112,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "f77148ef682cee2ed7becc151e3832a1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 4, sentence number 2 on page 124"^^xsd:string ;
    neo:text "That’s why momentum is so important, when things continue under their own steam and you can really see that you are not involved."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2826 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "966047bf6dee7f8aec5d92da8cdfc07b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 4, sentence number 3 on page 124"^^xsd:string ;
    neo:text "If you just practice continuously and correctly, understanding will arise."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2827 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2828 ;
    neo:id "7ff6d9319f83a3de749c18b0a1fbea61"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: EFFORTLESS AWARENESS, paragraph number 4, sentence number 4 on page 124"^^xsd:string ;
    neo:text "Once you gain some understanding that this process is just happening, the mind will start seeing things more and more from this perspective."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2829 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_180,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "43b5b66e4355d04e01d57a9af47bbfe5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 1 on page 124"^^xsd:string ;
    neo:text "If you reflect on this life alone and add up the amount of time that you have spent trying to be aware, to grow the practice, and wisdom, you will find that it is a small amount of time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2830 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2831,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2832,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_750,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "3c1f1c425ddeee8087ee4440a9aa450e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 2 on page 124"^^xsd:string ;
    neo:text "Ignorance and defilements have been our companions from the time we were born."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2834 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2835,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "2b21738a805fdb0961a6ae39ae9261eb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 3 on page 124"^^xsd:string ;
    neo:text "Things may seem impermanent but defilements always seem to be permanently there!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2837 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "ca29c004db58157bc2c68676cb097a5e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 4 on page 124"^^xsd:string ;
    neo:text "If you understand cause and effect, however, you’ll see that defilements have always had their way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2838 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "e7cfc73f975c59173a64b30cb29f7752"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 5 on page 124"^^xsd:string ;
    neo:text "They are the ones whose impressions have run very deep."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2839 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2840,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "1c61a6954056367e01f87d5fb2ffc5df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 6 on page 124"^^xsd:string ;
    neo:text "They are very strongly impressed in the mind and they leave a very long shadow to carry on their work through cause and effect."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2841 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2842,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "3e38502674a3d009d0867220f2bc38f7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 7 on page 124"^^xsd:string ;
    neo:text "If our practice is intermittent, then we will not become any more skillful and any understanding will come to a standstill."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2843 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "ba54fc61c3498a3456e02d94bb7105d6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 1, sentence number 8 on page 124"^^xsd:string ;
    neo:text "If we neglect our practice altogether, delusion will begin to grow again and cloud over all the things that we once understood."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2844 a neo:__Entity__ ;
    neo:AFFECTS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "Neglect"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2845 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "3b3cad3131ca00c9919b60a4c38f2653"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 2, sentence number 1 on page 125"^^xsd:string ;
    neo:text "So long as we continue meditating, we can maintain a certain level of understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2846 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "458885979d294cca182e6e61e04f4b35"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 2, sentence number 2 on page 125"^^xsd:string ;
    neo:text "Awareness is the ground that allows wisdom to arise over and over again and that’s why you have to be aware moment to moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2847 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_981 ;
    neo:id "f1775a4246decf118919a10f8844a300"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 2, sentence number 3 on page 125"^^xsd:string ;
    neo:text "Any new understandings or wisdom passes away, just like everything else."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2848 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2835,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2849,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2850,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2851,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2852 ;
    neo:id "179ca654197b09a2c279087177fe2b5e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 2, sentence number 4 on page 125"^^xsd:string ;
    neo:text "The understanding of anicca (impermanence) and anatta (not-self, non- ego) are also impermanent."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_285 a neo:Document ;
    neo:id "e02347f666c794d52cdd0ca02aa1bd87"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 2 on page 5"^^xsd:string ;
    neo:text "Don’t lose track of that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2853 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "21525328f77db18b5e443535269423d4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 2, sentence number 5 on page 125"^^xsd:string ;
    neo:text "However, while that understanding may arise and also pass away, it will leave an impression for the next mind, which picks it up and in turn leaves an impression as it passes away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2854 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2855,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2856,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "8c38ea337d3254d4718806fc3d9acf77"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 1 on page 125"^^xsd:string ;
    neo:text "It is a zero sum game: You are either doing this or you are doing that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2857 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2856,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_719 ;
    neo:id "a892ab3f2d8973dd7577de477ec55250"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 2 on page 125"^^xsd:string ;
    neo:text "If this is not present, then that is present."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2858 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2859,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2860,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2861 ;
    neo:id "057a6bcda533500cb136cbdce3ee9f46"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 3 on page 125"^^xsd:string ;
    neo:text "You are either moving forward or you are moving backward; there is no standing still."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_286 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_287,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73 ;
    neo:id "969c2d98e5ca2f5569cb3605b8417e6e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 3 on page 5"^^xsd:string ;
    neo:text "You can persevere and continue practicing at home."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2862 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_797,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_799 ;
    neo:id "f29176364ebb79d60360a07171ac1ce7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 4 on page 125"^^xsd:string ;
    neo:text "Wholesome minds will support each other just as unwholesome minds support each other."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2863 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1665,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_585 ;
    neo:id "4fb31fff7c5283d83708dded5e01f7d0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 5 on page 125"^^xsd:string ;
    neo:text "When something is burning and you throw in more water, the fire will go out."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2864 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1665,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2865 ;
    neo:id "476a56df42651bb4bbff36f32e00e6e2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 3, sentence number 6 on page 125"^^xsd:string ;
    neo:text "If flames are more intense, the fire will continue to burn."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2866 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "bf5ab29f0e2db4c5b044c6b9b23a1b70"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 4, sentence number 1 on page 125"^^xsd:string ;
    neo:text "I want you to use your wisdom to continue the work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2867 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2868,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "da40a8d6c45fcc5a3b5e4ef088456264"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 4, sentence number 2 on page 125"^^xsd:string ;
    neo:text "You collect this gold dust a bit more each day, day by day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2869 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "2382adfacee044e91c49b4951e8fe6d8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 4, sentence number 3 on page 125"^^xsd:string ;
    neo:text "You learn from it all while this and that goes on in your lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2870 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "1bb1b14da9d4cae1b4066305f7da7ca2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 4, sentence number 4 on page 125"^^xsd:string ;
    neo:text "Mindfulness is a lifetime commitment, not a part-time job."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2871 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "bd5a52a7e96fa4b536a22304b6502988"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 4, sentence number 5 on page 125"^^xsd:string ;
    neo:text "It is something that you really, really need to do all the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2872 a neo:Document ;
    neo:id "8fe3e5be97151d8b48accd7fd942b782"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 2 on page 126"^^xsd:string ;
    neo:text "All the time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2873 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "72b300ca7d983c3fc49f6de7dd534dfc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 3 on page 126"^^xsd:string ;
    neo:text "Only when you see the nature of the mind will you understand the nature of dhamma."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2874 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "9400d3a03817c5a35361e844a7203ba5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 4 on page 126"^^xsd:string ;
    neo:text "The mind is just arising and passing away, is so ephemeral, and the only input you can have to this process is the quality of awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2875 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2876,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296 ;
    neo:id "8b88a234963550d04819b265fda8b673"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 5 on page 126"^^xsd:string ;
    neo:text "When awareness becomes natural, it means that you have been putting in the effort to keep it going: persistence is right effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2877 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2878 ;
    neo:id "79a1c44baa367f504309d215774bcdae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 6 on page 126"^^xsd:string ;
    neo:text "Awareness starts staying."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2879 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2303,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2880,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296 ;
    neo:id "048b92689c21ed25271001ca2da229fa"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 7 on page 126"^^xsd:string ;
    neo:text "Effort remains and it becomes much more natural and much more useful."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_288 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_289,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_291,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "f702ee9c33133236a5c7c6c253d6821e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 4 on page 5"^^xsd:string ;
    neo:text "Practicing the Dhamma includes all the practices of right thought (which is a fundamental part of right view), right speech, and right action."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2881 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_271,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2882 ;
    neo:id "14754a0872387e57253a7fadddbd4e8a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 1 on page 126"^^xsd:string ;
    neo:text "Vipassanā wisdom cannot come about through intellectual thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2883 a neo:Document ;
    neo:id "0700a0aeba6032a98027177ca985b66d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 2 on page 126"^^xsd:string ;
    neo:text "It simply cannot be comprehended."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2884 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2042,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_271,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2885,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387 ;
    neo:id "b1a6805d4454f4a8e36fc97cc6059e22"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 5, sentence number 3 on page 126"^^xsd:string ;
    neo:text "Vipassanā insight is not something that can be conceptualized through images; it is a wholly new understanding and insight into principles, into nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2886 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_981 ;
    neo:id "b6040632c40738d0b9e4ff3ab68908c0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 6, sentence number 1 on page 126"^^xsd:string ;
    neo:text "As we practice diligently and continuously, we will keep having these small understandings and insights over and over."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2887 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "ed5cd00c64a54b71a648d512309180b4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 6, sentence number 2 on page 126"^^xsd:string ;
    neo:text "Over the long haul, insights will become so persistent that they will work in tandem with awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2888 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "f2e7a123f98e933f9c4f24f1167d2915"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 6, sentence number 3 on page 126"^^xsd:string ;
    neo:text "Once wisdom starts working together with awareness, our meditation moves to a higher level of understanding."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2889 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "42c46b07d21ac5ccce83c70d9b37c4a7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 6, sentence number 4 on page 126"^^xsd:string ;
    neo:text "We begin to have bigger insights."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2890 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1768,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2891 ;
    neo:id "707fe8278aa3e4463486eb66d3bfb4be"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 7, sentence number 1 on page 126"^^xsd:string ;
    neo:text "These bigger understandings have a life of their own; they have more power."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2892 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642 ;
    neo:id "75de19043b6ae6526545e7af95b92c3a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 7, sentence number 2 on page 126"^^xsd:string ;
    neo:text "They are not so dependent anymore on awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2893 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_376 ;
    neo:id "9ece0050c815e32837080ebcb6a4e9e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 7, sentence number 3 on page 126"^^xsd:string ;
    neo:text "Once we have had such insights, they will always be available and wisdom will always be there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2894 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2895 ;
    neo:id "fbde825a6ce6a1441872945d9db18aa8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 2 on page 127"^^xsd:string ;
    neo:text "At this stage, awareness will step back to play a secondary role."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2896 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "df83fef76337f31f2fad42bcee320a8f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 3 on page 127"^^xsd:string ;
    neo:text "It will always be present because wisdom cannot exist without awareness, but at this level of understanding, wisdom begins to have a life of its own."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2897 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_981 ;
    neo:id "5a8c41bd03b2e28e0b7b25dd3fcb1e1c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 4 on page 127"^^xsd:string ;
    neo:text "Awareness will keep feeding wisdom and our understandings will grow in strength."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2898 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "e118df123a1d65fca8d8f5e614c83f68"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 5 on page 127"^^xsd:string ;
    neo:text "At this stage, the mind always knows what to do, and it can happen that the practice becomes so easy that it will keep going even if we are not making any effort to practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2899 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50 ;
    neo:id "48afaf98e16a1e193669213fc0711891"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 6 on page 127"^^xsd:string ;
    neo:text "The more we practice, the more the mind understands how to practice and it doesn’t have to think about how to practice."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_29 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_30 ;
    neo:id "9f5204148b7cabc4923e6d926b2f8630"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 11, sentence number 1 on page vi"^^xsd:string ;
    neo:text "Create your world."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2900 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "dd69dca5fb24b824695105f1d4da0a4b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 7 on page 127"^^xsd:string ;
    neo:text "It finds its way when wisdom starts to operate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2901 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1612,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_830 ;
    neo:id "030717352fd3b88aa7c334a840a6d2c1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 8, sentence number 1 on page 127"^^xsd:string ;
    neo:text "The real benefit of the Dhamma is not to stop engaging with life issues but to approach the same tasks with wisdom instead of defilements, having understood how they work."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2902 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2903 ;
    neo:id "beb99c1116d63c361861763e7fbf066a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: GATHERING MOMENTUM, COLLECTING GOLD DUST, paragraph number 9, sentence number 1 on page 127"^^xsd:string ;
    neo:text "May All Beings Be Happy!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2904 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1366,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1367,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2366,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "530842ee0ee48c0ae12d53fd1a1647a1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 2 on page 129"^^xsd:string ;
    neo:text "Everybody has wholesome and unwholesome qualities in the mind but learning to cultivate the wholesome qualities is meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2905 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2906 ;
    neo:id "4919a1ae693fe3941b6233cd98b48403"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 3 on page 129"^^xsd:string ;
    neo:text "How do we cultivate these good qualities?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2907 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2908,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2909,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "9f24570edf6f11b6b04b6f43c8238626"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 1 on page 129"^^xsd:string ;
    neo:text "Satipaṭṭhāna, or meditation on the four foundations of mindfulness (body, feelings, mind and dhamma) cultivates the good qualities in our minds."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2910 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "4d6cbcd94b1217bb957fd355210fffdd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 4 on page 129"^^xsd:string ;
    neo:text "Meditation involves the things we observe (called objects) and that which is observing (the mind)."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2911 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1119,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2912,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2913,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2914,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318 ;
    neo:id "7cbe105f0b92770008ce85e046641de3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 5 on page 129"^^xsd:string ;
    neo:text "It is important to remember that sights, sounds, touch, taste, smells, and thoughts or the experiences arising at the six sense doors do not meditate."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2915 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149 ;
    neo:id "02e662e0e3c7732cea79dc25120e877a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 6 on page 129"^^xsd:string ;
    neo:text "We do not have to do anything to these experiences because they will always be there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2916 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "ed2bd8c31bdd4e29230f38af6ddb6f83"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 7 on page 129"^^xsd:string ;
    neo:text "These objects are just happening in the body and / or mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2917 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "dd4931f4a85aa301ad6eebe73b9abb12"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 1, sentence number 8 on page 129"^^xsd:string ;
    neo:text "Meditation is this latter part, the work of the mind, and the work to transform the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2918 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2007,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "d7fe35811784d6129d2052297e35bb6a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 2, sentence number 1 on page 129"^^xsd:string ;
    neo:text "A yogi has three jobs, and we will cover these in turn: 1) to have right view, 2) to be aware, and finally, 3) to practice continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2919 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2920,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "a973bf878485fbdad85001be3b2ae8c7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 2, sentence number 2 on page 129"^^xsd:string ;
    neo:text "When we are experiencing something, we should remind ourselves that it is an object of meditation and that the mind is knowing it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_292 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_162,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_293,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_294 ;
    neo:id "7d7c7748b7d0ca0a767a6c038803fb51"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 5 on page 5"^^xsd:string ;
    neo:text "Practicing the Dhamma begins with a mindset change that, if we are able to take it on, may eventually lead to a lifestyle change."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2921 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "a31be160c8d6c90e1ed28e4099c40861"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 2, sentence number 3 on page 129"^^xsd:string ;
    neo:text "It should not be that this is a bad experience or this is a good experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2922 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_928 ;
    neo:id "bf90b15811228ff8e2650b5dfbe03d6b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 2 on page 130"^^xsd:string ;
    neo:text "We would like to see things and regard things as they are."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2923 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2924,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2925,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2926,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2927,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2928,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2929 ;
    neo:id "394e8beacda1a4bcfeb97bfd7e14d80a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 3 on page 130"^^xsd:string ;
    neo:text "What is being known is just to be known and not to be loved or hated or desired or pushed away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2930 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1635,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2931,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2932,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "77cc449143529378a3c52fc3081b039b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 4 on page 130"^^xsd:string ;
    neo:text "Instead we remind ourselves that what is happening, what we’re experiencing, and what we’re observing is all nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2933 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "33de6c8d996a6399f1fdf76ff7fa06b9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 5 on page 130"^^xsd:string ;
    neo:text "We should remind ourselves that objects will always follow their nature, that they are doing what they are doing, and that they are being seen, heard or experienced."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2934 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "c561b6eb522b8a49d1245437ac1615e7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 6 on page 130"^^xsd:string ;
    neo:text "If we don’t remind ourselves of this nature, the mind will vacillate, desiring in one moment and resisting in the next moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2935 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2190,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_721 ;
    neo:id "985e5957f2589070a1edbdf19734d98e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 7 on page 130"^^xsd:string ;
    neo:text "Desire and resistance distort the “lenses” of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2936 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "3c010b6208592a84715f4f62267e4b52"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 1 on page 130"^^xsd:string ;
    neo:text "While the object itself is not important, we do need to know the object and to see the object clearly."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2937 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2938 ;
    neo:id "d990e2deb90427c54d9118a07ab35ee8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 2 on page 130"^^xsd:string ;
    neo:text "Sometimes I say that we need a 60/40 awareness, which means we pay attention 60% to the observing mind and 40% to the object."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2939 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1231,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_170,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2938 ;
    neo:id "6cdd884b3667f745cff5dfeeb615b22f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 3 on page 130"^^xsd:string ;
    neo:text "We need to pay more attention to the observing mind because defilements like greed, anger, and delusion happen in the mind, and these defilements cover the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2940 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_138,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_642,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "28731baaafb80564698f50104a42d855"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 3, sentence number 4 on page 130"^^xsd:string ;
    neo:text "They prevent us from seeing clearly; we cannot see objects for what they truly are."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2941 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "350c961eb24dbffca4cb452752dda834"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 4, sentence number 1 on page 130"^^xsd:string ;
    neo:text "Let’s look more closely at the different pieces of meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2942 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1094,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_326 ;
    neo:id "c89726a17fd914923a2e731a5ba18227"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 4, sentence number 2 on page 130"^^xsd:string ;
    neo:text "There are five qualities in our minds that do the work of meditation."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2943 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_110,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2210,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2944,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_314 ;
    neo:id "bcd8af7432d37403222946e7e3264300"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 4, sentence number 3 on page 130"^^xsd:string ;
    neo:text "These qualities are awareness, perseverance, faith (or confidence), steadiness or stability of mind, and wisdom."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2945 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_326 ;
    neo:id "62c6923ee0bc739c79528e46659196dd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 2 on page 131"^^xsd:string ;
    neo:text "These are the five qualities that we are trying to cultivate in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2946 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2947 ;
    neo:id "cd70811267850c8aa6e2eb9b1a5e119a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 3 on page 131"^^xsd:string ;
    neo:text "There are also six sense objects arising at the six sense doors."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2948 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_130,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2949,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_316 ;
    neo:id "19fbbcd213549efdfbd3a23be8bd0f80"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 4 on page 131"^^xsd:string ;
    neo:text "These six sense objects are our stepping-stones in that we use the objects that arise at the six sense doors to cultivate the five good qualities of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_295 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_296,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_297 ;
    neo:id "fbc0f7684cf0c7fded095e64cf4b7f4a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 6 on page 5"^^xsd:string ;
    neo:text "It is really worth the effort."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2950 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2951,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "377226affc6cba31a1fc2c3eef5a17c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 1 on page 131"^^xsd:string ;
    neo:text "When we meditate, any phenomenon or experience that is being known becomes an object."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2952 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_794 ;
    neo:id "f7a8aea75cc98dc02f805121239aa208"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 2 on page 131"^^xsd:string ;
    neo:text "We also need to be consciously aware of what we know."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2953 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1421,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "abd062349d3305bdde39257d53383c90"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 3 on page 131"^^xsd:string ;
    neo:text "We also need to know how to regard objects, to have the right view toward the objects, and be able to consider them in the right way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2954 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "b2b6b691abb2e8edc741e652b720880a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 5, sentence number 4 on page 131"^^xsd:string ;
    neo:text "We can do one of these things: we can remember that the objects are just nature, or that the objects are just things that are being known."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2956 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2908,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2957 ;
    neo:id "8fb961f15051c49b4fa0d61a38041bad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 6, sentence number 1 on page 131"^^xsd:string ;
    neo:text "In Satipaṭṭhāna, mindfulness or awareness (as I use the two words interchangeably) is the first of the five wholesome faculties of the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2958 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2959 ;
    neo:id "56a4992c15053dff05dfe0ad752ec680"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 6, sentence number 2 on page 131"^^xsd:string ;
    neo:text "We then cultivate the other four faculties through continuous mindfulness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2960 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_316,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_710 ;
    neo:id "148c7a5bd6fa2c6cd2e79c1ea25405f9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 6, sentence number 3 on page 131"^^xsd:string ;
    neo:text "Simply, mindfulness is about remembering to be present in this moment, knowing any one of or all of the six sense objects (mind and/or body) that are happening right now."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2961 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_115,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_261,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_280,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_281,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2962,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2963,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2964 ;
    neo:id "d36361fde28889f15df8d811ce14a1c8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 6, sentence number 4 on page 131"^^xsd:string ;
    neo:text "In English, I like to use words like awareness, mindfulness, remembering, not forgetting, recognizing, and noticing for the Pāḷi word of sati."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2965 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2966,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2967,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2968,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2969,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "eeba98abe9a720decc906fc5bcd2c72a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 6, sentence number 5 on page 131"^^xsd:string ;
    neo:text "I prefer not to use terms like concentrate or penetrate into the object because I don’t like the strong sense of effortful energy that is suggested by those words."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2970 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "64e881198e45e281552e05b9f0adc40d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 1 on page 132"^^xsd:string ;
    neo:text "I was once sitting in a car driven by a yogi."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2971 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2972,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "f2481f2a400eb4bc61e434031f943c19"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 2 on page 132"^^xsd:string ;
    neo:text "When another car passed by us the yogi asked, “Is it enough for me to know it as meditation awareness if I knew that a car passed by?” No."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2973 a neo:Document ;
    neo:id "6a8e18c5503037c75213f55fd16f3059"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 3 on page 132"^^xsd:string ;
    neo:text "It’s not quite there yet."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2974 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677 ;
    neo:id "2793f13394c2fdd90216cf99506e6df9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 4 on page 132"^^xsd:string ;
    neo:text "We would all know that a car had passed by whether we are meditating or not."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2975 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2976,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2977 ;
    neo:id "9cac572971b8ddde1a937460b0a39ca9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 5 on page 132"^^xsd:string ;
    neo:text "How is meditation-knowing different from regular-knowing?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2978 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_55,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_841 ;
    neo:id "89dda0da26804325d1c8ba7c2df06b01"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 6 on page 132"^^xsd:string ;
    neo:text "There ’s seeing, hearing, and thinking and the meditator knows consciously that these things are being experienced."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2979 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2980 ;
    neo:id "c72f373712e9e93a21baa3c625d8c9bc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 7 on page 132"^^xsd:string ;
    neo:text "A non-meditator knows that a car has passed by but does not reference it to his own experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_298 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_299,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_300 ;
    neo:id "afa6b4dd0c53dae717ebbb0ea797856b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 7 on page 5"^^xsd:string ;
    neo:text "The right efforts bear fruit when sufficient conditions are fulfilled."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2981 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1701,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1900,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_65 ;
    neo:id "b0ff65021973db0360436d9928acfbf7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 8 on page 132"^^xsd:string ;
    neo:text "He may instead refer just to the concept of what has happened where the thought has already processed the whole experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2982 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_316 ;
    neo:id "bcb9048667961f2e1c38bcc7417989e8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 7, sentence number 9 on page 132"^^xsd:string ;
    neo:text "That is why I say awareness is when you are aware of the six sense objects as your direct experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2983 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2984,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "c032c76c9f66e43223cf89a1174747df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 1 on page 132"^^xsd:string ;
    neo:text "For example, if I am sitting on a rug right now and I’m aware of this rug, this is not considered meditation awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2985 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2984,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2986,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2987,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "4f3b26d9f739568064dc990b3bf27ae8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 2 on page 132"^^xsd:string ;
    neo:text "When I am aware of the process of seeing or feeling that allows me to see and feel and interpret this rug as a rug, this is my experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2988 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "18a9fb9ca22b5d48b514e76091816872"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 3 on page 132"^^xsd:string ;
    neo:text "I am aware of this experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2989 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2990,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "712e391528ff1ef71cfc821e1bb90e2f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 4 on page 132"^^xsd:string ;
    neo:text "Being aware of only the conceptual part of the experience is not sati."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2991 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2126,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_246,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2984,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823 ;
    neo:id "d9fea1d0aa2bca080a61e1da156740ed"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 5 on page 132"^^xsd:string ;
    neo:text "We are not as interested in the concept of a rug in-as-much as we are in the process of seeing or feeling."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2992 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1775,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "a33ea7dd1f7fc372d92e65964207612b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 8, sentence number 6 on page 132"^^xsd:string ;
    neo:text "We need concepts in order to function in daily life, but in meditation we want to know the underlying process of what is happening in the mind, of nature, and of reality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2993 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "eea77e26d2de14b38a91928764c1f0b3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 9, sentence number 1 on page 133"^^xsd:string ;
    neo:text "So you are aware and you maintain that awareness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2994 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1192,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "12355f518454dea00c0c07c4a7f68c44"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 9, sentence number 2 on page 133"^^xsd:string ;
    neo:text "You do not have to use much energy to be aware."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2995 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1649,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_901 ;
    neo:id "ce3dfb64bb8e6b107be73a46767aa737"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 9, sentence number 3 on page 133"^^xsd:string ;
    neo:text "There’s no need to focus hard but you do need to use right effort to keep reminding yourself to go continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2996 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_144,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "3d82c72fe8e44f86a25e08871519c3f1"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 9, sentence number 4 on page 133"^^xsd:string ;
    neo:text "If you can use energy in that right way, you can go on practicing the whole day without feeling tired."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2997 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_94 ;
    neo:id "0be09d7eeba4858295bd10a252a283d4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 9, sentence number 5 on page 133"^^xsd:string ;
    neo:text "Try to sustain that awareness for longer periods of time throughout the day."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2998 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2999 ;
    neo:id "08074298590a6fc08c67483610d7b3e9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 10, sentence number 1 on page 133"^^xsd:string ;
    neo:text "You can take one object that you know lightly and use that as a grounding object to explore more widely."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3000 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "2c909a0f949f4f26ddd674483a34f72c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 10, sentence number 2 on page 133"^^xsd:string ;
    neo:text "When I was practicing continuously in daily life, I would use feeling as my touchstone."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3001 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_536 ;
    neo:id "3fb83384a0ea025aacab04be9650169e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 10, sentence number 3 on page 133"^^xsd:string ;
    neo:text "From there I began to notice how thoughts affected feelings and how feelings affected thoughts."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3002 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_39 ;
    neo:id "0eb41c829c920d93e59c7a0e5cd105ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 10, sentence number 4 on page 133"^^xsd:string ;
    neo:text "I slowly learned and understood all these relationships."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3003 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_200,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3004,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_481,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_966 ;
    neo:id "b51d62d4c242b57d236b2017dfd42f7e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 11, sentence number 1 on page 133"^^xsd:string ;
    neo:text "You can sit, walk, and lie down as you meditate in your daily lives."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3005 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3006,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "9d45df0c0c29de2c6d4674e66ec3292b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 11, sentence number 2 on page 133"^^xsd:string ;
    neo:text "The posture is not important, and is even less so in daily life where you have to go about your business doing things."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3007 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3008,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3009,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_431 ;
    neo:id "0604ccd4617605d5730dc29cc8b51d61"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 11, sentence number 3 on page 133"^^xsd:string ;
    neo:text "The timetable, however, is all the time from the moment you wake up in the morning until the moment you fall asleep at night."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3010 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3011,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "2b1c017b327e743ecae5229e0f77db47"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 12, sentence number 1 on page 133"^^xsd:string ;
    neo:text "You also need to know how to view these objects that are arising."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3012 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2947,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "87889b716402bfd873fb6ab858b880c5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 12, sentence number 2 on page 133"^^xsd:string ;
    neo:text "Whether they are sense objects or your experience, you need to view them as nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3013 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "d955ccb317d74cfadf84f9fd1fde225e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 12, sentence number 3 on page 133"^^xsd:string ;
    neo:text "Nature means it is impossible to find a “you” or a “me.” Nature is all just a process of cause and effect."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3015 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "53cc52027a522d153feb2c78d177c687"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 12, sentence number 4 on page 133"^^xsd:string ;
    neo:text "There’s nothing inherently good or bad in these objects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3016 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3017,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3018,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "662a91115c67e7adf3ddb31849da28ad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 5 on page 135"^^xsd:string ;
    neo:text "If you are developing greed or aversion towards any kind of sound, it indicates that you have a wrong view of the experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3019 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_44,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "368c16f02e721bfe8f37c55e717832cf"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 1 on page 135"^^xsd:string ;
    neo:text "Come back to the right view when you face difficulties with certain objects: consider sound as just a sound."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_302 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_303,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "c915b571cf13d53618db55ae4a7beea9"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 8 on page 5"^^xsd:string ;
    neo:text "The Buddha said, “If you look after the Dhamma, the Dhamma will look after you.” Looking after the Dhamma simply means practicing it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3020 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "00161ff0df4ff544d61895e033efad81"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 2 on page 135"^^xsd:string ;
    neo:text "It is an object and it is just nature."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3021 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1421,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "a9e38b3c32b047e1eb56b6ab2db4112b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 3 on page 135"^^xsd:string ;
    neo:text "This is the view that you should take."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3022 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1127,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2124,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "c911bd92e3fa11944ae87ece4b4fbc09"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 4 on page 135"^^xsd:string ;
    neo:text "The instruction in the Satipaṭṭhāna Sutta is to recognize the experience as it is."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3023 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_769,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_862 ;
    neo:id "001f2169cad7553447a2261edbdb22a6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 14, sentence number 6 on page 135"^^xsd:string ;
    neo:text "For someone with right view, samādhi, or stability of mind is automatically there."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3024 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1701,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "710bcaff8c137e91f95873db205cf116"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 1 on page 135"^^xsd:string ;
    neo:text "A concept is just a name given to reality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3025 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "bc4cee140290f9208993bdb33203198e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 2 on page 135"^^xsd:string ;
    neo:text "When you become aware of reality, you can see both the mind that is conceptualizing and reality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3026 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3027,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859 ;
    neo:id "efb4c9a6eff6e59cf3a946187fb1399f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 3 on page 135"^^xsd:string ;
    neo:text "You will notice a sound as just a sound (reality) and also an interpretation of the particular sound (concept)."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3028 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1677,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_541,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "a25beff2cde5ea524ede6bf458475781"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 4 on page 135"^^xsd:string ;
    neo:text "When you are crossing the street and you hear a car coming, then you also need to watch out to see if a car is coming."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3029 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2282,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269 ;
    neo:id "977765dc4c8a0b2436777a7aff183d5b"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 5 on page 135"^^xsd:string ;
    neo:text "You can know that sound is just sound but wisdom must also understand what that sound means."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3030 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3031,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3032 ;
    neo:id "0b498381032736450a3415b63da9ea0f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 15, sentence number 6 on page 135"^^xsd:string ;
    neo:text "There are two kinds of wisdom at work here: the wisdom that understands the concept of an approaching car and the wisdom that understands reality of a sound is a sound."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3033 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "2ea41de8641082c226b6d9c08fd6937f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 16, sentence number 1 on page 135"^^xsd:string ;
    neo:text "Understanding is different from just experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3034 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_859,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "b27430fd4ec877a291db1df0ab385cb8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 16, sentence number 2 on page 135"^^xsd:string ;
    neo:text "Understanding means you get it: This is reality."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3035 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1421,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2247,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_323 ;
    neo:id "413ff40dc408e38128745a1a4b2480f4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 16, sentence number 3 on page 135"^^xsd:string ;
    neo:text "Sometimes experience does not mean that you truly understand it and the view changes."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3036 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_348 ;
    neo:id "18912573dca4566c4770feca80796c8a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 16, sentence number 4 on page 135"^^xsd:string ;
    neo:text "You can know that something is an object, which you can’t touch or feel but you just understand that this is something that is being known and therefore has the role of being an object."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3037 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591 ;
    neo:id "833c59a8ab57ee86d34bcf997f66720c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 1 on page 136"^^xsd:string ;
    neo:text "The same instructions apply for the thinking mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3038 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "bc7745cbb102895c6a89f1153c3660fd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 2 on page 136"^^xsd:string ;
    neo:text "When you notice that the mind is thinking, know it."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3039 a neo:Document ;
    neo:id "69ffe2241743d106d44abbbcdb2509a3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 3 on page 136"^^xsd:string ;
    neo:text "If there is less thinking, know that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_304 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "a9c1d714398cb121303f0674b27f285e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 9 on page 5"^^xsd:string ;
    neo:text "After a certain point, the Dhamma will carry you along on its wave."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3040 a neo:Document ;
    neo:id "1e4b56276a86d4db1df7fd1ab417dd23"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 4 on page 136"^^xsd:string ;
    neo:text "If there is more thinking, know that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3041 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_959 ;
    neo:id "15f3310140295d17747ffc2feb581c18"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 5 on page 136"^^xsd:string ;
    neo:text "If there is no thinking, know that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3042 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "7cadf4bfe2e87b813005b5cadbb1aae6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 6 on page 136"^^xsd:string ;
    neo:text "Thinking is the mind and the definition of mind is that which thinks and that which knows."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3043 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1359,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_96 ;
    neo:id "cd916431b89c9eeff884c3b3a59a5900"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 7 on page 136"^^xsd:string ;
    neo:text "Problems arise when there is aversion to thinking, when you have the idea that you should not be thinking when you are meditating."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3044 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1179,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2190 ;
    neo:id "6d7fcfe899de20b9c6082367c2c2ec90"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 8 on page 136"^^xsd:string ;
    neo:text "All sorts of resistance follow that idea."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3045 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1437,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1591 ;
    neo:id "b5f4a36f2870522a66a9f25e8bcc8ccb"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 9 on page 136"^^xsd:string ;
    neo:text "There is no need to struggle with your thoughts because the thinking mind is never a problem."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3046 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "afb9cc6ec00c2fb8e34f280f8a30ac4e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 10 on page 136"^^xsd:string ;
    neo:text "If there is a lot of thinking going on, there is no need to reduce it!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3047 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323 ;
    neo:id "d2c9d8ce5ffaba4c59ab8dcf383017f8"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 11 on page 136"^^xsd:string ;
    neo:text "All you have to do is acknowledge over and over again that the mind is thinking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3048 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1323,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "bef94f588f12a120d15330945d45f977"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 17, sentence number 12 on page 136"^^xsd:string ;
    neo:text "After all, you are only able to recognize that amount of thinking because there is awareness!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3049 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1057,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2800,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3050,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_40 ;
    neo:id "be26a3c3892000492cfe36a9568df6df"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 18, sentence number 1 on page 136"^^xsd:string ;
    neo:text "Yogis label the times when they are lost in thought and don’t know that they’re thinking because they are lost in thoughts as a wandering mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_305 a neo:Document ;
    neo:id "0cfcaaedd2bc88b288bf78f43aebf99d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 1, sentence number 10 on page 5"^^xsd:string ;
    neo:text "So keep going!"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3051 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "ec8dd46fd4060e768a653d4f14a5e1f4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 18, sentence number 2 on page 136"^^xsd:string ;
    neo:text "The mind arises in the present moment and passes away in the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3052 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_73,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_74 ;
    neo:id "26bc3fce27543e5b54665992df5a83f4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 18, sentence number 3 on page 136"^^xsd:string ;
    neo:text "Thoughts about home or work arise in the mind and we can acknowledge these thoughts arising each time it happens."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3053 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2352,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2372,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_857 ;
    neo:id "7801ec830786adc209b7a0972598914e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 18, sentence number 4 on page 136"^^xsd:string ;
    neo:text "Actually the mind does not wander anywhere nor does it go anywhere; it thinks about the past and future in the present moment."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3054 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014 ;
    neo:id "7a492174aa11ef684c995499f5efdd37"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 1 on page 137"^^xsd:string ;
    neo:text "You can relate to pain in the same way."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3055 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1219 ;
    neo:id "e2475c15cd1f9769d3b147c83c350f35"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 2 on page 137"^^xsd:string ;
    neo:text "When you notice even a little bit of pain, first check your attitude."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3056 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1219,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2690,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308 ;
    neo:id "327aaa9404e1a806ed940416b8265767"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 3 on page 137"^^xsd:string ;
    neo:text "If the mind is feeling uncomfortable, adjust the attitude, remind yourself that this is nature and then, having brought in the right view, watch the discomfort or the aversion in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3057 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_136,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2190,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3058 ;
    neo:id "7981154a3dc60a6c7b76dc729c1ab90e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 4 on page 137"^^xsd:string ;
    neo:text "First, watch the resistance and then you can watch the actual physical sensations."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3059 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014 ;
    neo:id "ff139da7c7ee40da36f0091bc7ae7cb7"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 5 on page 137"^^xsd:string ;
    neo:text "To begin with, why do you observe pain?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_306 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_35 ;
    neo:id "fa42d91f2c60834fca30170230e7d2c0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 2, sentence number 1 on page 5"^^xsd:string ;
    neo:text "What is dhamma?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3060 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_403 ;
    neo:id "704a0cbf00118f4a9dad6f39264318ae"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 6 on page 137"^^xsd:string ;
    neo:text "Do you want to make it go away?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3061 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3062 ;
    neo:id "9a821925b06184c51031bc909df51cdc"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 7 on page 137"^^xsd:string ;
    neo:text "It is natural for the body to become uncomfortable if we sit still for long periods."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3063 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3064 ;
    neo:id "563de59577f2d5516731bfba99677eb2"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 8 on page 137"^^xsd:string ;
    neo:text "We should observe pain because we want to understand something about the nature of pain; we don’t observe pain in hopes that it will go away."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3065 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3066,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3067 ;
    neo:id "0f5cd78cd463293a2333831a80cf3a8c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 9 on page 137"^^xsd:string ;
    neo:text "Why do you think your leg hurts when it hurts?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3068 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3066,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "b14171cbdd0b20de9bd4b7413b4da781"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 10 on page 137"^^xsd:string ;
    neo:text "The simplest answer is that your leg hurts because you have a leg."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3069 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3070 ;
    neo:id "10c04f76b544594be6c9009dc9455f04"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 11 on page 137"^^xsd:string ;
    neo:text "Where there is a body, there will also be physical pain."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_307 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_308,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_309,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_310 ;
    neo:id "e04dc964d20bfaff56f994257c1e3572"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 2, sentence number 2 on page 5"^^xsd:string ;
    neo:text "It is everything: all of nature, its causes and effects; the mind that is meditating (i.e."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3071 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_109,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "f3508e8d91af802521e08786e294be51"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 19, sentence number 12 on page 137"^^xsd:string ;
    neo:text "That is awareness and right view that we can develop."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3072 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3073,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_50,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_54 ;
    neo:id "cb596ec198436ecd99b073a651ee1ac4"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 1 on page 137"^^xsd:string ;
    neo:text "The final, important piece of a yogi’s three jobs is to practice continuously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3074 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3075,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_464 ;
    neo:id "8e1b5d4be08141122109dec2e6c1665c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 2 on page 137"^^xsd:string ;
    neo:text "Whatever you do, first be aware of yourself, and then go about your task."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3076 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26 ;
    neo:id "774d472beb2375c2bd931d793b475b95"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 3 on page 137"^^xsd:string ;
    neo:text "You may have fairly continuous mindfulness when you are sitting in meditation but you will eventually get up."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3077 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3078,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "95c469c833e6d15794ed446d97e595bd"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 4 on page 137"^^xsd:string ;
    neo:text "What do you know first when you get up?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3079 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3080,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3081,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_806 ;
    neo:id "c16374eb457ffc73befaf1c0613f70c3"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 5 on page 137"^^xsd:string ;
    neo:text "It could be your hand or legs moving or just the energy you’re using to put strength into what you do."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3082 a neo:Document ;
    neo:id "7d547e6142d542946b0ec7aa794d71e6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 6 on page 137"^^xsd:string ;
    neo:text "Know that and what’s happening after that."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3083 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3084 ;
    neo:id "be548d667114f4f7be5b83e583489a59"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 20, sentence number 7 on page 137"^^xsd:string ;
    neo:text "It’s even better when you know all your movements and if you know what is happening in the mind at the same time."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3085 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2229,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3086 ;
    neo:id "ff1c5b3bceea6a9ba7fc0bc55f628329"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 1 on page 138"^^xsd:string ;
    neo:text "When you do sitting meditation you can take the whole body as an object and know anything that becomes obvious and see it change."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3087 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1065 ;
    neo:id "83ab11ee5fa31f956c246be61122fdad"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 2 on page 138"^^xsd:string ;
    neo:text "If you are used to using an anchor, then use that anchor as a starting point."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3088 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1818,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1823,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2290,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_336,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_355 ;
    neo:id "eced7ac038352542b86a1fda3c01aa54"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 3 on page 138"^^xsd:string ;
    neo:text "You can use awareness of breathing in and out at the nostrils (ānāpānasati), rising and falling of the abdomen, or sounds as anchors."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3089 a neo:Document ;
    neo:id "8e92c7193a2a8daf1c46386784494c7e"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 4 on page 138"^^xsd:string ;
    neo:text "These are just a few examples."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3090 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1065,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "20c0b39e1bc9c7cd2380c9d64aa33223"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 5 on page 138"^^xsd:string ;
    neo:text "You can use any object that is easy for you to be aware of as an anchor to establish mindfulness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3091 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1065,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_266 ;
    neo:id "b0be27c5f5229b1e27973f1823be9e7a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 6 on page 138"^^xsd:string ;
    neo:text "The anchor just starts the mind off on being mindful and once you are aware of any object for some time, the mind will actually start to know other objects."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3092 a neo:Document ;
    neo:id "0ccb153b496bba3000ce6669783668ac"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 7 on page 138"^^xsd:string ;
    neo:text "That is good."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3093 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161 ;
    neo:id "df9b40a3d164c36a2e69b5cbf9ca0aa5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 8 on page 138"^^xsd:string ;
    neo:text "It means that mindfulness is getting better."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3094 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_647 ;
    neo:id "d642bea5cb52b7d46fa58db1de583a39"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 21, sentence number 9 on page 138"^^xsd:string ;
    neo:text "When the mindfulness is good, it begins to feel like it knows four or five objects simultaneously."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3095 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3096,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "eaebe6524d6ab4172ffc3dd75c5eb01a"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 22, sentence number 1 on page 138"^^xsd:string ;
    neo:text "You are observing everything to understand the nature of this mind- body experience."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3097 a neo:Document ;
    neo:id "2cb70e3d6ed6fb0700a341a55e88dc5f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 22, sentence number 2 on page 138"^^xsd:string ;
    neo:text "What can you understand about these experiences?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3098 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_784 ;
    neo:id "02c21230407ea4145642a4c33e8cdd04"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 22, sentence number 3 on page 138"^^xsd:string ;
    neo:text "You have been practicing for a long time, you have been watching the body, watching the mind, and you have been doing it for years."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3099 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1061,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3100 ;
    neo:id "5bc7add8f65f05a03c09bc17061d7a93"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 22, sentence number 4 on page 138"^^xsd:string ;
    neo:text "What more have you understood about this body and this mind and the interactions between body and mind?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_31 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_32 ;
    neo:id "e4e89d55165647d449ad10924d0e0cc5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: COLLECTING GOLD DUST, paragraph number 11, sentence number 2 on page vi"^^xsd:string ;
    neo:text "It’s a game called Master Mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3101 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2908,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3102 ;
    neo:id "14bf242befad17c21b94b24d8d26b4e0"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 23, sentence number 1 on page 138"^^xsd:string ;
    neo:text "The goal of Satipaṭṭhāna practice is to understand deeply."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3104 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1264,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3105,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3106,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_380 ;
    neo:id "43eb6aef190676b2485d7dbc86c329e5"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 23, sentence number 2 on page 138"^^xsd:string ;
    neo:text "When there is right understanding, when we have true realization into the nature of things, there will be calm in the mind."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3107 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3108,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_387,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_921 ;
    neo:id "60685691e79917c344ea761c9696ef6c"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 23, sentence number 3 on page 138"^^xsd:string ;
    neo:text "This calm state is a by-product of understanding or insight."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3109 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2247,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3102 ;
    neo:id "66c67c21a48451c1020c5f65cd53405d"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 23, sentence number 4 on page 138"^^xsd:string ;
    neo:text "The real goal of this meditation is to understand."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3110 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_135 ;
    neo:id "f5a62307d3e41ba8ae32722d22007ac6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 1 on page 139"^^xsd:string ;
    neo:text "How can we understand the nature of pain if we just stared at it and it disappeared?"^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3111 a neo:Document ;
    neo:id "5f63fb64c1ac9fad12a50015358a9261"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 2 on page 139"^^xsd:string ;
    neo:text "Please be patient."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3112 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2190 ;
    neo:id "1d23860fcd93065485cd7fb79f454712"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 3 on page 139"^^xsd:string ;
    neo:text "When there is pain, watch the resistance in the mind and do this only for as long as it is bearable."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3113 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3006,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3114,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_717 ;
    neo:id "83c21ae5b7eb38429496517d644c9f44"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 4 on page 139"^^xsd:string ;
    neo:text "When you change your posture, be aware of two possible motivations behind it: 1) greed to be more comfortable, or 2) understanding that if you continue to sit in that position, your aversion will grow."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3115 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_168,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169 ;
    neo:id "0b54e010209d2fb32a39ce0bf465ef60"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 5 on page 139"^^xsd:string ;
    neo:text "You don’t want to be growing aversion any more than you want to be growing greed."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3116 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1014,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_169 ;
    neo:id "245249209a250f48644d6510d4f3402f"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 24, sentence number 6 on page 139"^^xsd:string ;
    neo:text "Understanding that the pain might become too much, you let go of the pain and make yourself more comfortable to prevent the growth of aversion."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3117 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_965 ;
    neo:id "38878629537a7d7abdee020bd6285f11"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 25, sentence number 1 on page 139"^^xsd:string ;
    neo:text "Finally, let’s discuss talking."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3118 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_161,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_290 ;
    neo:id "80d04a000d847f99eb013148cbbca283"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 25, sentence number 2 on page 139"^^xsd:string ;
    neo:text "We should try to practice right speech and only say what is necessary and wholesome and for this we do need mindfulness."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3119 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_2095,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_97 ;
    neo:id "019529e51ee7c347055072735f570702"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 25, sentence number 3 on page 139"^^xsd:string ;
    neo:text "Speaking is all around us in daily life."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_312 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_110,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_121,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_149,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_26,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_269,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_313,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_314,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_315,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_316,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_317,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_318,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_319,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_320,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_321 ;
    neo:id "fe4d9c31fca3d54d98084ebf7d411711"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: A Note from the Teacher, paragraph number 2, sentence number 3 on page 5"^^xsd:string ;
    neo:text "the qualities of awareness, perseverance, stability of mind, faith, and wisdom); it is everything that becomes observed in meditation (the sensations, the six sense objects which include the mind as a sense object, the experiences, the events, the thoughts, the pleasant, unpleasant, and neutral feelings) and also that which we may or may not consciously notice yet."^^xsd:string .

ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_3120 a neo:Document ;
    neo:MENTIONS ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_1178,
        ex:node_4_cbedb183_7ddf_4a42_a9be_ef770b56f14a_19 ;
    neo:id "943045f7d9d442f25572e378534df4f6"^^xsd:string ;
    neo:source "Source document: COLLECTING GOLD DUST: Nurturing the Dhamma in Daily Living, Chapter: Appendix: Mindfulness in Brief, paragraph number 25, sentence number 4 on page 139"^^xsd:string ;
    neo:text "You do not want to cut off speech without awareness of what you need to do."^^xsd:string .

